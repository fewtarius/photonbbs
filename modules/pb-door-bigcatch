sub _bc_show_derby {
  my ($g) = @_;
  my $derby = door_load_shared($DOOR_NAME, "derby.dat");
  return unless $derby && $derby->{entries} && keys %{$derby->{entries}};
  writeline("", 1);
  writeline($config{'themecolor'} . " Fishing Derby Standings" . $RST, 1);
  my @s = sort { $derby->{entries}{$b}{biggest} <=> $derby->{entries}{$a}{biggest} }
          keys %{$derby->{entries}};
  door_hrule(58);
  writeline(sprintf("  %s%-18s %8s %8s %8s %8s%s",
    $config{'systemcolor'}, "Angler", "Biggest", "Caught", "Species", "Earned", $RST), 1);
  for my $n (@s[0 .. ($#s > 14 ? 14 : $#s)]) {
    my $e = $derby->{entries}{$n};
    my $c = (lc($n) eq lc($info{'handle'})) ? $config{'usercolor'} : $config{'datacolor'};
    writeline(sprintf("  %s%-18s %s%7.1flb %8d %8d %8s%s",
      $c, substr($n, 0, 18), $config{'datacolor'}, $e->{biggest},
      $e->{total}, $e->{species}, _bc_money($e->{earned} // 0), $RST), 1);
  }
  writeline("", 1);
}

sub _bc_show_tournament {
  my $t = door_load_shared($DOOR_NAME, "tournament.dat");
  return unless $t && $t->{active};
  my $now = time();
  writeline($config{'themecolor'} . " LIVE TOURNAMENT - " . $config{'usercolor'} . $t->{name} . $RST, 1);
  my $remaining = $t->{end_time} - $now;
  if ($remaining > 0) {
    my $mins = int($remaining / 60);
    writeline($config{'systemcolor'} . " Time remaining: " . $config{'datacolor'} . "$mins minutes" .
      $config{'systemcolor'} . "   Prize pool: " . $config{'usercolor'} . _bc_money($t->{prize_pool}) . $RST, 1);
    writeline("", 1);
    if (%{$t->{entries}}) {
      writeline($config{'systemcolor'} . sprintf("  %-18s %8s", "Angler", "Best Fish") . $RST, 1);
      for my $n (sort { $t->{entries}{$b} <=> $t->{entries}{$a} } keys %{$t->{entries}}) {
        my $c = (lc($n) eq lc($info{'handle'})) ? $config{'usercolor'} : $config{'datacolor'};
        writeline(sprintf("  %s%-18s %s%7.1flb%s", $c, substr($n,0,18),
          $config{'datacolor'}, $t->{entries}{$n}, $RST), 1);
      }
    }
  } else {
    writeline($config{'systemcolor'} . " Tournament ended." . $RST, 1);
  }
  writeline("", 1);
}

sub _bc_update_derby {
  my ($g) = @_;
  my $derby = door_load_shared($DOOR_NAME, "derby.dat") // { entries => {} };
  my $e = $derby->{entries}{$info{'handle'}} // { biggest => 0, total => 0, species => 0, earned => 0 };
  $e->{biggest} = $g->{biggest} if $g->{biggest} > ($e->{biggest} // 0);
  $e->{total} = $g->{total_caught};
  $e->{species} = scalar(keys %{$g->{species_caught}});
  $e->{earned} = $g->{lifetime_money};
  $derby->{entries}{$info{'handle'}} = $e;
  door_save_shared($DOOR_NAME, "derby.dat", $derby);

  if ($g->{biggest} > 0) {
    my $max = 0;
    for my $v (values %{$derby->{entries}}) { $max = $v->{biggest} if $v->{biggest} > $max; }
    if ($g->{biggest} >= $max) {
      door_broadcast($DOOR_NAME, sprintf("%s holds the Big Catch record: %.1f lbs!", $info{'handle'}, $g->{biggest}));
    }
  }

  # Update live tournament if active
  _bc_update_tournament($g);
}

sub _bc_update_tournament {
  my ($g) = @_;
  my $t = door_load_shared($DOOR_NAME, "tournament.dat");
  return unless $t && $t->{active};
  my $now = time();
  if ($now > $t->{end_time}) {
    # Tournament ended - award prize to winner
    if (%{$t->{entries}}) {
      my ($winner) = sort { $t->{entries}{$b} <=> $t->{entries}{$a} } keys %{$t->{entries}};
      my $prize = $t->{prize_pool};
      door_broadcast($DOOR_NAME, "$winner won the $t->{name} tournament with " .
        sprintf("%.1f", $t->{entries}{$winner}) . " lb! Prize: " . _bc_money($prize));
      door_send_message($DOOR_NAME, $winner, "You won the $t->{name} tournament! " . _bc_money($prize) . " added to your account.");
      door_add_credits($prize) if $winner eq $info{'handle'};
      door_submit_score($DOOR_NAME, int($t->{entries}{$winner} * 100), { tournament => $t->{name} });
    }
    $t->{active} = 0;
    door_save_shared($DOOR_NAME, "tournament.dat", $t);
    return;
  }
  if (exists $t->{entries}{$info{'handle'}} || $t->{registered}{$info{'handle'}}) {
    # Update our entry if we have a bigger fish
    if ($g->{biggest} > ($t->{entries}{$info{'handle'}} // 0)) {
      $t->{entries}{$info{'handle'}} = $g->{biggest};
      door_save_shared($DOOR_NAME, "tournament.dat", $t);
      door_broadcast($DOOR_NAME, sprintf("%s leads the %s tournament with %.1f lb!",
        $info{'handle'}, $t->{name}, $g->{biggest})) if $g->{biggest} > 10;
    }
  }
}

sub _bc_join_tournament {
  my ($g) = @_;
  my $t = door_load_shared($DOOR_NAME, "tournament.dat");
  my $entry_fee = 50;

  if (!$t || !$t->{active} || time() > $t->{end_time}) {
    # Start a new tournament
    if (door_yesno("No active tournament. Start one? (Entry fee: " . _bc_money($entry_fee) . ")")) {
      if ($g->{money} < $entry_fee) {
        writeline($config{'errorcolor'} . " Not enough money." . $RST, 1);
        return;
      }
      $g->{money} -= $entry_fee;
      $t = {
        active      => 1,
        name        => "Invitational Derby",
        start_time  => time(),
        end_time    => time() + 3600,  # 1 hour tournament
        prize_pool  => $entry_fee,
        entries     => { $info{'handle'} => 0 },
        registered  => { $info{'handle'} => 1 },
      };
      door_save_shared($DOOR_NAME, "tournament.dat", $t);
      door_broadcast($DOOR_NAME, "$info{'handle'} started the Big Catch Invitational Derby! Join with 'T' in Big Catch. 1 hour, \$50 entry.");
      writeline($config{'usercolor'} . " Tournament started! 1 hour. Good luck!" . $RST, 1);
    }
  } elsif ($t->{registered}{$info{'handle'}}) {
    writeline($config{'systemcolor'} . " You are already in the tournament." . $RST, 1);
  } else {
    # Join existing tournament
    if (door_yesno("Join '$t->{name}'? Entry fee: " . _bc_money($entry_fee))) {
      if ($g->{money} < $entry_fee) {
        writeline($config{'errorcolor'} . " Not enough money." . $RST, 1);
        return;
      }
      $g->{money} -= $entry_fee;
      $t->{prize_pool} += $entry_fee;
      $t->{entries}{$info{'handle'}} = 0;
      $t->{registered}{$info{'handle'}} = 1;
      door_save_shared($DOOR_NAME, "tournament.dat", $t);
      door_broadcast($DOOR_NAME, "$info{'handle'} joined the $t->{name}! Prize pool: " . _bc_money($t->{prize_pool}));
      writeline($config{'usercolor'} . " Joined! Good luck!" . $RST, 1);
    }
  }
  door_pause();
}

# Fishing duel - quick head-to-head competition
sub _bc_fishing_duel {
  my ($g) = @_;

  # Check for existing duel sessions to join
  my $sessions = door_session_list($DOOR_NAME);
  my @joinable;
  for my $s (@$sessions) {
    next if lc($s->{host}) eq lc($info{'handle'});
    next unless ($s->{game_state}{type} // '') eq 'fishing_duel';
    push @joinable, $s;
  }

  if (@joinable) {
    writeline("", 1);
    writeline($config{'usercolor'} . " " . $joinable[0]{host} . " wants a fishing duel!" . $RST, 1);
    if (door_yesno("Accept the challenge?")) {
      my $session = door_session_join($DOOR_NAME, $joinable[0]{id});
      if ($session) {
        _bc_duel_run($g, $session, $joinable[0]{host});
        return;
      }
      writeline($config{'errorcolor'} . " Couldn't join - they may have cancelled." . $RST, 1);
      door_pause();
      return;
    }
  }

  # Create a new duel
  my @online = door_get_online_players($DOOR_NAME);
  my @others = grep { lc($_) ne lc($info{'handle'}) } @online;

  unless (@others) {
    writeline($config{'systemcolor'} . " No other anglers on the lake." . $RST, 1);
    door_pause();
    return;
  }

  my $bet = 50;
  if ($g->{money} < $bet) {
    writeline($config{'errorcolor'} . " Need at least " . _bc_money($bet) . " for the duel bet." . $RST, 1);
    door_pause();
    return;
  }

  writeline("", 1);
  writeline($config{'systemcolor'} . " Fishing Duel: 5 casts each, biggest fish wins!" . $RST, 1);
  writeline($config{'systemcolor'} . " Bet: " . $config{'datacolor'} . _bc_money($bet) . $RST, 1);
  writeline("", 1);

  unless (door_yesno("Create a duel? (" . _bc_money($bet) . " bet)")) { return; }

  $g->{money} -= $bet;

  my $session = door_session_create($DOOR_NAME, {
    max_players => 2,
    game_state  => { type => 'fishing_duel', bet => $bet },
  });

  unless ($session) {
    $g->{money} += $bet;
    writeline($config{'errorcolor'} . " Couldn't create duel." . $RST, 1);
    door_pause();
    return;
  }

  door_broadcast($DOOR_NAME, "$info{'handle'} is looking for a fishing duel! (" . _bc_money($bet) . " bet)");
  writeline($config{'systemcolor'} . " Waiting for a challenger..." . $RST, 1);
  writeline($config{'datacolor'} . " Press Q to cancel, A to duel AI." . $RST, 1);

  my $result = door_session_wait($DOOR_NAME, $session->{id}, {
    timeout => 45, max_cycles => 2,
  });

  unless ($result && scalar @{$result->{players}} >= 2) {
    $g->{money} += $bet;
    writeline($config{'systemcolor'} . " No challenger. Bet refunded." . $RST, 1);
    door_session_destroy($DOOR_NAME, $session->{id});
    door_pause();
    return;
  }

  my $opponent = $result->{players}[1]{name};
  _bc_duel_run($g, $result, $opponent);
}

sub _bc_duel_run {
  my ($g, $session, $opponent) = @_;
  my $bet = $session->{game_state}{bet} // 50;
  my $casts = 5;

  iamat($info{'handle'}, "Fishing duel vs $opponent");

  door_clear();
  writeline($config{'errorcolor'} . " FISHING DUEL!" . $RST, 1);
  writeline($config{'systemcolor'} . " $info{'handle'} vs " . $config{'usercolor'} . $opponent . $RST, 1);
  writeline($config{'systemcolor'} . " $casts casts - biggest single fish wins!" . $RST, 1);
  writeline($config{'systemcolor'} . " Bet: " . $config{'datacolor'} . _bc_money($bet) . $RST, 1);
  writeline("", 1);
  door_pause("Press any key to start fishing...");

  my $my_best = 0;
  my $my_best_name = "nothing";

  for my $cast_num (1 .. $casts) {
    door_clear();
    writeline($config{'themecolor'} . " Duel Cast $cast_num/$casts" . $RST, 1);
    writeline($config{'systemcolor'} . " Your best: " . $config{'datacolor'} .
      sprintf("%.1f lbs (%s)", $my_best, $my_best_name) . $RST, 1);
    door_hrule(40);
    writeline("", 1);

    writeline($config{'systemcolor'} . " Casting..." . $RST, 1);
    sleep(1);

    # Simulate a catch attempt using lake conditions
    my $catch_chance = 40 + ($g->{rod_power} * 10) + ($g->{fish_finder} ? 15 : 0);
    $catch_chance += $g->{weather}{modifier} // 0;

    if (rand(100) < $catch_chance) {
      # Caught something - pick a random species from current lake
      my $lake = $LAKES[$g->{lake_idx}];
      my $sp_idx = $lake->{species}[int(rand(scalar @{$lake->{species}}))];
      my $sp = $FISH[$sp_idx];
      my $weight = $sp->{minw} + rand($sp->{maxw} - $sp->{minw});
      $weight *= (0.8 + rand(0.4));  # Some variation

      writeline($config{'usercolor'} . " Caught: " . $config{'datacolor'} . $sp->{name} .
        " - " . sprintf("%.1f lbs", $weight) . "!" . $RST, 1);

      if ($weight > $my_best) {
        $my_best = $weight;
        $my_best_name = $sp->{name};
        writeline($config{'usercolor'} . " New best catch!" . $RST, 1);
      }
    } else {
      writeline($config{'linecolor'} . " Nothing biting this cast." . $RST, 1);
    }
    writeline("", 1);
    door_pause("Next cast...") unless $cast_num == $casts;
  }

  # Simulate opponent's best catch (based on time/randomness)
  my $opp_best = rand(15) + rand(10);  # Random 0-25 lbs
  my $opp_species = "Unknown Catch";

  writeline("", 1);
  door_hrule(40);
  writeline($config{'themecolor'} . " DUEL RESULTS" . $RST, 1);
  writeline($config{'usercolor'} . " $info{'handle'}: " . $config{'datacolor'} .
    sprintf("%.1f lbs (%s)", $my_best, $my_best_name) . $RST, 1);
  writeline($config{'errorcolor'} . " $opponent: " . $config{'datacolor'} .
    sprintf("%.1f lbs", $opp_best) . $RST, 1);
  writeline("", 1);

  if ($my_best > $opp_best) {
    $g->{money} += $bet * 2;
    writeline($config{'usercolor'} . " YOU WIN! +" . _bc_money($bet) . "!" . $RST, 1);
    door_send_message($DOOR_NAME, $opponent,
      "$info{'handle'} beat you in a fishing duel! Their best: " . sprintf("%.1f lbs", $my_best));
    door_broadcast($DOOR_NAME, "$info{'handle'} won a fishing duel against $opponent!")
      if $my_best > 10;
  } elsif ($opp_best > $my_best) {
    writeline($config{'errorcolor'} . " $opponent wins! -" . _bc_money($bet) . $RST, 1);
    door_send_message($DOOR_NAME, $opponent,
      "You beat $info{'handle'} in a fishing duel! Your best was bigger.");
  } else {
    $g->{money} += $bet;
    writeline($config{'systemcolor'} . " TIE! Bet refunded." . $RST, 1);
  }

  door_session_destroy($DOOR_NAME, $session->{id});
  writeline("", 1);
  door_pause();
}

