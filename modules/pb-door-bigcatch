# ============================================================================
# LAKE SELECTION
# ============================================================================

sub _bc_choose_lake {
  my ($g) = @_;
  door_clear();
  writeline($config{'themecolor'} . " Choose a Lake" . $RST, 1);
  door_hrule(60);
  writeline("", 1);

  for my $i (0 .. $#LAKES) {
    my $l = $LAKES[$i];
    writeline(sprintf("  %s%2d%s %s%-24s%s %dft %d species",
      $config{'promptcolor'}, $i + 1, $config{'themecolor'},
      $config{'usercolor'}, $l->{name}, $config{'systemcolor'},
      $l->{max_depth}, scalar(@{$l->{species}})) . $RST, 1);
  }

  writeline("", 1);
  writeline($config{'systemcolor'} . " Select lake (1-" . scalar(@LAKES) . ", 0 quit): " . $RST);
  my $choice = int(getline('text', 2, "", 1));

  if ($choice < 1 || $choice > @LAKES) {
    $g->{quit} = 1;
    return;
  }
  $g->{lake_idx} = $choice - 1;
}

# ============================================================================
# LAKE GENERATION
# ============================================================================

sub _bc_generate_lake {
  my ($g) = @_;
  my $lake = $LAKES[$g->{lake_idx}];
  my $md = $lake->{max_depth};

  for my $y (0 .. $LAKE_H - 1) {
    for my $x (0 .. $LAKE_W - 1) {
      if ($y == 0 || $y == $LAKE_H-1 || $x == 0 || $x == $LAKE_W-1) {
        $g->{lake}[$y][$x] = -1;
        $g->{surface}[$y][$x] = -1;
        $g->{bottom}[$y][$x] = 0;
        next;
      }

      my $cx = ($x - $LAKE_W/2) / ($LAKE_W/2 - 2);
      my $cy = ($y - $LAKE_H/2) / ($LAKE_H/2 - 2);
      my $dist = sqrt($cx*$cx + $cy*$cy);
      my $noise = sin($x * 0.7) * 0.15 + cos($y * 0.9) * 0.12 + sin(($x+$y) * 0.5) * 0.1;
      $dist += $noise;

      if ($dist > 0.95) {
        $g->{lake}[$y][$x] = -1;
        $g->{surface}[$y][$x] = -1;
        $g->{bottom}[$y][$x] = 0;
      } else {
        my $depth_pct = (0.95 - $dist) / 0.95;
        my $depth = int($depth_pct * $md + rand(5) - 2);
        $depth = 1 if $depth < 1;
        $depth = $md if $depth > $md;
        $g->{lake}[$y][$x] = $depth;

        if ($depth <= 8 && rand(100) < 40) {
          $g->{surface}[$y][$x] = int(rand(5)) + 1;
        } elsif ($depth <= 15 && rand(100) < 15) {
          $g->{surface}[$y][$x] = int(rand(3)) + 1;
        } else {
          $g->{surface}[$y][$x] = 0;
        }

        if ($depth > 25) {
          $g->{bottom}[$y][$x] = rand(100) < 60 ? 0 : 1;
        } elsif ($depth > 10) {
          $g->{bottom}[$y][$x] = int(rand(3));
        } else {
          $g->{bottom}[$y][$x] = rand(100) < 40 ? 1 : (rand(100) < 50 ? 2 : 0);
        }
      }
    }
  }

  $g->{boat_y} = int($LAKE_H / 2);
  for my $x (1 .. $LAKE_W - 2) {
    if ($g->{lake}[$g->{boat_y}][$x] > 0) { $g->{boat_x} = $x; last; }
  }
}

# ============================================================================
# FISH STOCKING
# ============================================================================

sub _bc_stock_lake {
  my ($g) = @_;
  my $lake = $LAKES[$g->{lake_idx}];
  $g->{fish} = [];

  for (1 .. $MAX_FISH) {
    my $sp_idx = $lake->{species}[int(rand(scalar @{$lake->{species}}))];
    my $sp = $FISH[$sp_idx];
    my ($fy, $fx, $att) = (0, 0, 0);
    do {
      $fy = 1 + int(rand($LAKE_H - 2));
      $fx = 1 + int(rand($LAKE_W - 2));
      $att++;
    } while (($g->{lake}[$fy][$fx] < $sp->{mind} || $g->{lake}[$fy][$fx] > $sp->{maxd} ||
              $g->{lake}[$fy][$fx] < 0) && $att < 80);
    next if $att >= 80;

    my $range = $sp->{maxw} - $sp->{minw};
    my $weight = $sp->{minw} + $range * (rand(0.5) + rand(0.5));
    $weight = $sp->{minw} + $range * (0.8 + rand(0.2)) if rand(100) < 3;
    $weight = sprintf("%.2f", $weight) + 0;

    push @{$g->{fish}}, {
      species => $sp_idx, y => $fy, x => $fx,
      weight => $weight, depth => $g->{lake}[$fy][$fx],
      active => rand(100) < 60 ? 1 : 0,
    };
  }
}

