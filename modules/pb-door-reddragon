sub _rd_gamble {
  my ($p) = @_;

  if ($p->{gold} < 50) {
    writeline($config{'errorcolor'} . " You need at least 50 gold to gamble!" . $RST, 1);
    return;
  }

  $p->{gold} -= 50;
  writeline("", 1);
  writeline($config{'systemcolor'} . " You place 50 gold on the table..." . $RST, 1);

  my $roll = int(rand(100));
  if ($roll < 40) {
    writeline($config{'errorcolor'} . " You lose!" . $RST, 1);
  }
  elsif ($roll < 75) {
    $p->{gold} += 100;
    writeline($config{'usercolor'} . " You win 100 gold!" . $RST, 1);
  }
  elsif ($roll < 92) {
    $p->{gold} += 250;
    writeline($config{'usercolor'} . " Big win! You win 250 gold!" . $RST, 1);
  }
  else {
    $p->{gold} += 1000;
    writeline($config{'usercolor'} . " JACKPOT! You win 1,000 gold!" . $RST, 1);
  }
  door_save($DOOR_NAME, $p);
}

