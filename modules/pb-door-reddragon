# ============================================================================
# PLAYER DATA
# ============================================================================

sub _rd_load_player {
  my $p = door_load($DOOR_NAME);
  return $p if $p;
  return _rd_new_player();
}

sub _rd_new_player {
  my $lvl = $LEVELS[0];
  return {
    level        => 1,
    hp           => $lvl->{hp},
    max_hp       => $lvl->{hp},
    str          => $lvl->{str},
    def          => $lvl->{def},
    gold         => 500,
    bank         => 0,
    exp          => 0,
    weapon       => 0,
    armor        => 0,
    forest_fights=> $FOREST_FIGHTS,
    pvp_fights   => $PVP_FIGHTS,
    charm        => 0,
    gems         => 0,
    dragon_kills => 0,
    deaths       => 0,
    kills        => 0,
    last_reset   => time(),
    created      => time(),
    alive        => 1,
  };
}

sub _rd_daily_reset {
  my ($p) = @_;
  my $now = time();
  # Reset if it's been more than a day since last reset
  if (($now - ($p->{last_reset} // 0)) >= $DAILY_RESET) {
    $p->{forest_fights} = $FOREST_FIGHTS;
    $p->{pvp_fights}    = $PVP_FIGHTS;
    $p->{hp}            = $p->{max_hp};
    $p->{alive}         = 1;
    $p->{last_reset}    = $now;
    door_save($DOOR_NAME, $p);
  }
}

