# ============================================================================
# MAIN ENTRY POINT
# ============================================================================

my $DOOR_NAME = "druglord";

sub druglord_main {
  # Load door library
  # Set iamat for who's online
  iamat($info{'handle'}, "Playing DrugLord");

  door_broker_connect($DOOR_NAME, "door-druglord-streets");

  # Show title screen
  _dl_title_screen();

  # Initialize game state
  my %game = _dl_init_game();

  # Main game loop
  while ($game{turn} <= $MAX_TURNS && $game{health} > 0) {
    _dl_generate_prices(\%game);
    _dl_show_status(\%game);
    _dl_location_events(\%game);
    last if $game{quit};
    _dl_trade_menu(\%game);
    last if $game{quit};
    _dl_jet(\%game);
    last if $game{quit};
  }

  # Game over
  _dl_game_over(\%game);

  door_broker_disconnect();
  iamat($info{'handle'}, "Finished DrugLord");
}

# ============================================================================
# TITLE SCREEN
# ============================================================================

sub _dl_title_screen {
  door_clear();
  writeline("", 1);
  writeline($config{'themecolor'} . "                  D R U G L O R D" . $RST, 1);
  writeline($config{'linecolor'}  . "          --------------------------------" . $RST, 1);
  writeline($config{'systemcolor'} . "     Based on the classic Drug Wars BBS game" . $RST, 1);
  writeline($config{'systemcolor'} . "    Buy low, sell high, and don't get busted" . $RST, 1);
  writeline("", 1);
  writeline($config{'datacolor'} . "  You have 31 days to make as much money" . $RST, 1);
  writeline($config{'datacolor'} . "  as you can on the streets of New York." . $RST, 1);
  writeline($config{'datacolor'} . "  You start with \$2,000 cash and \$5,500 debt." . $RST, 1);
  writeline("", 1);
  door_pause("Press any key to start...");
}

# ============================================================================
# GAME INITIALIZATION
# ============================================================================

sub _dl_init_game {
  my %game = (
    turn       => 1,
    cash       => $START_CASH,
    debt       => $START_DEBT,
    bank       => 0,
    health     => 100,
    location   => 0,       # Start in The Bronx
    coat_size  => $COAT_SIZE,
    guns       => [],      # Array of gun indices owned
    drugs      => [],      # Array of {carried, price} per drug
    prices     => [],      # Current prices at this location
    events     => [],      # Event messages to display
    quit       => 0,
    max_score  => 0,
    turf       => {},      # Locations controlled by this player
    reputation => 0,       # Street rep
    total_profit => 0,     # Running total
    kills      => 0,       # Cops killed
  );

  # Initialize drug inventory (nothing carried)
  for my $i (0 .. $#DRUGS) {
    $game{drugs}[$i] = { carried => 0, total_value => 0 };
  }

  # Load shared economy state (prices affected by all players)
  _dl_load_economy(\%game);

  return %game;
}

# Load/save shared economy state
sub _dl_load_economy {
  my ($g) = @_;
  my $econ = door_load_shared($DOOR_NAME, "economy.dat");
  $g->{economy} = $econ // { trades => {}, kingpin => "", kingpin_score => 0, turf => {} };
}

sub _dl_save_economy {
  my ($g) = @_;
  door_save_shared($DOOR_NAME, "economy.dat", $g->{economy});
}

# ============================================================================
# PRICE GENERATION
# ============================================================================

sub _dl_generate_prices {
  my ($g) = @_;
  my $loc = $LOCATIONS[$g->{location}];
  $g->{events} = [];
  $g->{prices} = [];

  # Start with all prices zeroed
  for my $i (0 .. $#DRUGS) {
    $g->{prices}[$i] = 0;
  }

  # Generate special events (cheap/expensive)
  my $num_events = 0;
  $num_events = 1 if rand(100) < 70;
  $num_events = 2 if $num_events == 1 && rand(100) < 40;
  $num_events = 3 if $num_events == 2 && rand(100) < 5;

  while ($num_events > 0) {
    my $i = int(rand(scalar @DRUGS));
    next if $g->{prices}[$i] != 0;  # Already has event

    my $drug = $DRUGS[$i];
    if ($drug->{expensive} && (!$drug->{cheap} || rand(100) < 50)) {
      # Expensive event
      $g->{prices}[$i] = _dl_randprice($drug->{min}, $drug->{max}) * $EXPENSIVE_MULT;
      my $msg = sprintf($EXPENSIVE_MSG[int(rand(@EXPENSIVE_MSG))], $drug->{name});
      push @{$g->{events}}, $config{'errorcolor'} . "  $msg" . $RST;
      $num_events--;
    } elsif ($drug->{cheap}) {
      # Cheap event
      $g->{prices}[$i] = int(_dl_randprice($drug->{min}, $drug->{max}) / $CHEAP_DIVISOR);
      push @{$g->{events}}, $config{'usercolor'} . "  $drug->{cheap_msg}" . $RST;
      $num_events--;
    }
  }

  # Fill remaining drug slots with random availability
  my $num_drugs = $loc->{min_drug} + int(rand($loc->{max_drug} - $loc->{min_drug} + 1));
  $num_drugs = scalar @DRUGS if $num_drugs > scalar @DRUGS;

  # Count how many already have prices from events
  my $already = grep { $g->{prices}[$_] != 0 } 0 .. $#DRUGS;
  my $need = $num_drugs - $already;

  while ($need > 0) {
    my $i = int(rand(scalar @DRUGS));
    next if $g->{prices}[$i] != 0;
    $g->{prices}[$i] = _dl_randprice($DRUGS[$i]{min}, $DRUGS[$i]{max});
    $need--;
  }
}

sub _dl_randprice {
  my ($min, $max) = @_;
  return $min + int(rand($max - $min + 1));
}

# ============================================================================
# STATUS DISPLAY
# ============================================================================

sub _dl_show_status {
  my ($g) = @_;
  my $loc = $LOCATIONS[$g->{location}];

  door_clear();

  # Header
  writeline($config{'themecolor'} . " DrugLord" .
    $config{'systemcolor'} . "  Day " . $config{'datacolor'} . "$g->{turn}" .
    $config{'systemcolor'} . " of " . $config{'datacolor'} . "$MAX_TURNS" .
    $config{'systemcolor'} . "  |  " . $config{'usercolor'} . $loc->{name} . $RST, 1);

  # Financial summary
  my $net = $g->{cash} + $g->{bank} - $g->{debt};
  writeline($config{'systemcolor'} . " Cash: " . $config{'datacolor'} . door_money($g->{cash}) .
    $config{'systemcolor'} . "  Bank: " . $config{'datacolor'} . door_money($g->{bank}) .
    $config{'systemcolor'} . "  Debt: " . $config{'errorcolor'} . door_money($g->{debt}) .
    $config{'systemcolor'} . "  Net: " . ($net >= 0 ? $config{'usercolor'} : $config{'errorcolor'}) . door_money($net) . $RST, 1);

  # Space and health
  my $space = _dl_free_space($g);
  my $gun_count = scalar @{$g->{guns}};
  writeline($config{'systemcolor'} . " Health: " . _dl_health_color($g->{health}) . "$g->{health}%" .
    $config{'systemcolor'} . "  Space: " . $config{'datacolor'} . "$space" .
    $config{'systemcolor'} . "  Guns: " . $config{'datacolor'} . "$gun_count" .
    $RST, 1);

  door_hrule(60);

  # Show events
  for my $ev (@{$g->{events}}) {
    writeline($ev, 1);
  }
  writeline("", 1) if @{$g->{events}};
  # Show incoming chat from other dealers
  my @chat = door_chat_poll($DOOR_NAME);
  for my $m (@chat) {
    writeline($config{'linecolor'} . "  " . $m . $RST, 1);
  }

  # Drug price list
  writeline($config{'systemcolor'} . sprintf("  %-4s %-12s %10s %8s", "#", "Drug", "Price", "Owned") . $RST, 1);
  door_hrule(38, $config{'linecolor'});
  for my $i (0 .. $#DRUGS) {
    next if $g->{prices}[$i] == 0;  # Not available here
    my $carried = $g->{drugs}[$i]{carried};
    my $pcolor = $config{'datacolor'};
    my $ccolor = $carried > 0 ? $config{'usercolor'} : $config{'systemcolor'};
    writeline(sprintf("  %s%-4s%s %-12s %s%10s %s%8s%s",
      $config{'promptcolor'}, $i + 1, $config{'themecolor'},
      $DRUGS[$i]{name},
      $pcolor, door_money($g->{prices}[$i]),
      $ccolor, ($carried > 0 ? $carried : "-"),
      $RST), 1);
  }
  writeline("", 1);
}

sub _dl_health_color {
  my ($hp) = @_;
  return $config{'errorcolor'} if $hp <= 25;
  return $config{'promptcolor'} if $hp <= 50;
  return $config{'usercolor'};
}

sub _dl_free_space {
  my ($g) = @_;
  my $used = 0;
  for my $i (0 .. $#DRUGS) {
    $used += $g->{drugs}[$i]{carried};
  }
  for my $gi (@{$g->{guns}}) {
    $used += $GUNS[$gi]{space};
  }
  return $g->{coat_size} - $used;
}

# ============================================================================
# LOCATION EVENTS (loan shark, bank, gun shop, pub, cops)
# ============================================================================

sub _dl_location_events {
  my ($g) = @_;
  my $loc_idx = $g->{location};

  # Loan shark
  if ($loc_idx == $LOC_LOANSHARK && $g->{debt} > 0) {
    if (door_yesno("Visit the Loan Shark?")) {
      _dl_loanshark($g);
    }
  }

  # Bank
  if ($loc_idx == $LOC_BANK) {
    if (door_yesno("Visit the Bank?")) {
      _dl_bank($g);
    }
  }

  # Gun shop
  if ($loc_idx == $LOC_GUNSHOP) {
    if (door_yesno("Visit Dan's House of Guns?")) {
      _dl_gunshop($g);
    }
  }

  # Pub (hire a carrier)
  if ($loc_idx == $LOC_PUB && rand(100) < 40) {
    my $price = 50000 + int(rand(100000));
    writeline($config{'systemcolor'} . "  A shady character offers to expand your coat for " .
      $config{'datacolor'} . door_money($price) . $RST, 1);
    if (door_yesno("Accept the offer?")) {
      if ($g->{cash} >= $price) {
        $g->{cash} -= $price;
        $g->{coat_size} += 10;
        writeline($config{'usercolor'} . "  Your trenchcoat now holds " . $g->{coat_size} . " items." . $RST, 1);
      } else {
        writeline($config{'errorcolor'} . "  You don't have enough cash." . $RST, 1);
      }
      door_pause();
    }
  }

  # Random subway saying
  if (rand(100) < 15) {
    my $saying = $SAYINGS[int(rand(@SAYINGS))];
    writeline($config{'systemcolor'} . "  The lady next to you on the subway said," . $RST, 1);
    writeline($config{'datacolor'} . "  \"$saying\"" . $RST, 1);
    if (rand(100) < 30) {
      writeline($config{'systemcolor'} . "     (at least, you think that's what she said)" . $RST, 1);
    }
    writeline("", 1);
  }

  # Random: find drugs on the ground
  if (rand(100) < 8) {
    my $found_idx = int(rand(scalar @DRUGS));
    my $found_amt = 1 + int(rand(5));
    my $space = _dl_free_space($g);
    if ($space > 0) {
      $found_amt = $space if $found_amt > $space;
      $g->{drugs}[$found_idx]{carried} += $found_amt;
      writeline($config{'usercolor'} . "  You found $found_amt " . $DRUGS[$found_idx]{name} .
        " on a dead dude in the subway!" . $RST, 1);
      writeline("", 1);
    }
  }

  # Cop encounter
  my $cop_chance = 80 + $LOCATIONS[$loc_idx]{police};
  if (int(rand($cop_chance)) > 75) {
    _dl_cop_encounter($g);
  }
}

# ============================================================================
# LOAN SHARK
# ============================================================================

sub _dl_loanshark {
  my ($g) = @_;
  writeline("", 1);
  writeline($config{'themecolor'} . "  The Loan Shark" . $RST, 1);
  writeline($config{'systemcolor'} . "  You owe: " . $config{'errorcolor'} . door_money($g->{debt}) . $RST, 1);
  writeline("", 1);

  my $amount = door_getamount("How much do you want to repay? (\$0 to skip)", $g->{cash});
  if ($amount > 0) {
    if ($amount > $g->{cash}) {
      writeline($config{'errorcolor'} . "  You don't have that much cash." . $RST, 1);
    } elsif ($amount > $g->{debt}) {
      writeline($config{'errorcolor'} . "  You only owe " . door_money($g->{debt}) . "." . $RST, 1);
    } else {
      $g->{cash} -= $amount;
      $g->{debt} -= $amount;
      writeline($config{'usercolor'} . "  Paid " . door_money($amount) .
        ". Remaining debt: " . door_money($g->{debt}) . $RST, 1);
    }
  }
  door_pause();
}

# ============================================================================
# BANK
# ============================================================================

sub _dl_bank {
  my ($g) = @_;
  my $done = 0;
  while (!$done) {
    writeline("", 1);
    writeline($config{'themecolor'} . "  The Bank" . $RST, 1);
    writeline($config{'systemcolor'} . "  Cash: " . $config{'datacolor'} . door_money($g->{cash}) .
      $config{'systemcolor'} . "  Savings: " . $config{'datacolor'} . door_money($g->{bank}) . $RST, 1);
    writeline("", 1);

    my $choice = door_menu([
      ['D', 'Deposit'],
      ['W', 'Withdraw'],
      ['Q', 'Leave bank'],
    ], "Banking");

    if ($choice eq 'D') {
      my $amount = door_getamount("Deposit how much?", $g->{cash});
      if ($amount > 0 && $amount <= $g->{cash}) {
        $g->{cash} -= $amount;
        $g->{bank} += $amount;
        writeline($config{'usercolor'} . "  Deposited " . door_money($amount) . "." . $RST, 1);
      }
    } elsif ($choice eq 'W') {
      my $amount = door_getamount("Withdraw how much?", $g->{bank});
      if ($amount > 0 && $amount <= $g->{bank}) {
        $g->{bank} -= $amount;
        $g->{cash} += $amount;
        writeline($config{'usercolor'} . "  Withdrew " . door_money($amount) . "." . $RST, 1);
      }
    } else {
      $done = 1;
    }
  }
}

# ============================================================================
# GUN SHOP
# ============================================================================

sub _dl_gunshop {
  my ($g) = @_;
  writeline("", 1);
  writeline($config{'themecolor'} . "  Dan's House of Guns" . $RST, 1);
  writeline("", 1);

  for my $i (0 .. $#GUNS) {
    writeline(sprintf("  %s%d%s %-24s %s%10s%s  (takes %d space)",
      $config{'promptcolor'}, $i + 1, $config{'themecolor'},
      $GUNS[$i]{name},
      $config{'datacolor'}, door_money($GUNS[$i]{price}), $RST,
      $GUNS[$i]{space}), 1);
  }
  writeline("", 1);
  writeline($config{'systemcolor'} . "  You carry " . scalar(@{$g->{guns}}) .
    " gun(s). Max: " . int($g->{coat_size} / 10) . $RST, 1);

  my $choice = door_getnum("Buy which gun? (0 to leave)", scalar @GUNS);
  if ($choice > 0) {
    my $gi = $choice - 1;
    if ($g->{cash} < $GUNS[$gi]{price}) {
      writeline($config{'errorcolor'} . "  You can't afford that." . $RST, 1);
    } elsif (_dl_free_space($g) < $GUNS[$gi]{space}) {
      writeline($config{'errorcolor'} . "  Not enough room in your coat." . $RST, 1);
    } else {
      $g->{cash} -= $GUNS[$gi]{price};
      push @{$g->{guns}}, $gi;
      writeline($config{'usercolor'} . "  You bought a $GUNS[$gi]{name}." . $RST, 1);
    }
  }
  door_pause();
}

# ============================================================================
# COP ENCOUNTERS
# ============================================================================

sub _dl_cop_encounter {
  my ($g) = @_;
  return if @{$g->{guns}} == 0 && _dl_total_drugs($g) == 0;  # No contraband, no trouble

  # Determine cop tier based on cash + bank
  my $wealth = $g->{cash} + $g->{bank};
  my $cop_tier = 0;
  $cop_tier = 1 if $wealth > 100000;
  $cop_tier = 2 if $wealth > 1000000;

  my $cop = $COPS[$cop_tier];
  my $num_deputies = $cop->{min_dep} + int(rand($cop->{max_dep} - $cop->{min_dep} + 1));

  writeline("", 1);
  writeline($config{'errorcolor'} . "  $cop->{name} and $num_deputies deputies are on your tail!" . $RST, 1);
  writeline("", 1);

  my $fighting = 1;
  my $cops_health = $cop->{armor} + ($num_deputies * 3);

  while ($fighting && $g->{health} > 0) {
    my @options;
    push @options, ['R', 'Run'] if $g->{health} > 0;
    push @options, ['F', 'Fight'] if @{$g->{guns}} > 0;

    my $choice = door_menu(\@options, "Cops! What do you do");

    if ($choice eq 'R') {
      # Try to run
      if (rand(100) < 60) {
        writeline($config{'usercolor'} . "  You escape into a back alley!" . $RST, 1);
        $fighting = 0;
      } else {
        writeline($config{'errorcolor'} . "  You can't lose them!" . $RST, 1);
        # Cops shoot at you
        _dl_cops_shoot($g, $cop, $num_deputies);
      }
    } elsif ($choice eq 'F') {
      # Fight cops
      my $gun = $GUNS[$g->{guns}[0]];  # Use first gun
      my $dmg = $gun->{damage} + int(rand($gun->{damage}));
      if (rand(100) < 70) {
        $cops_health -= $dmg;
        $num_deputies-- if $num_deputies > 0;
        writeline($config{'usercolor'} . "  You shoot and injure a cop! ($dmg damage)" . $RST, 1);
      } else {
        writeline($config{'systemcolor'} . "  You shoot and miss." . $RST, 1);
      }

      if ($cops_health <= 0 || $num_deputies <= 0) {
        writeline($config{'usercolor'} . "  The cops retreat!" . $RST, 1);
        $fighting = 0;
      } else {
        # Cops return fire
        _dl_cops_shoot($g, $cop, $num_deputies);
      }
    } else {
      # No guns, must run
      if (rand(100) < 50) {
        writeline($config{'usercolor'} . "  You escape into a back alley!" . $RST, 1);
        $fighting = 0;
      } else {
        writeline($config{'errorcolor'} . "  You can't lose them!" . $RST, 1);
        _dl_cops_shoot($g, $cop, $num_deputies);
      }
    }
  }

  # If dead or caught
  if ($g->{health} <= 0) {
    writeline($config{'errorcolor'} . "  $cop->{name} guns you down." . $RST, 1);
  }

  door_pause();
}

sub _dl_cops_shoot {
  my ($g, $cop, $num_deputies) = @_;
  my $shots = 1 + int(rand($num_deputies > 0 ? $num_deputies : 1));
  my $total_damage = 0;

  for (1 .. $shots) {
    if (rand(100) < 40) {
      my $dmg = 5 + int(rand(15));
      $total_damage += $dmg;
    }
  }

  if ($total_damage > 0) {
    $g->{health} -= $total_damage;
    $g->{health} = 0 if $g->{health} < 0;
    writeline($config{'errorcolor'} . "  The cops wound you! (-${total_damage}% health, now $g->{health}%)" . $RST, 1);

    # Cops confiscate stuff if health low
    if ($g->{health} <= 0) {
      return;
    }
    if ($g->{health} < 20 && rand(100) < 60) {
      # Confiscate all drugs
      for my $i (0 .. $#DRUGS) {
        $g->{drugs}[$i]{carried} = 0;
        $g->{drugs}[$i]{total_value} = 0;
      }
      # Take some cash
      my $taken = int($g->{cash} * (50 + rand(50)) / 100);
      $g->{cash} -= $taken;
      writeline($config{'errorcolor'} . "  $cop->{name} relieves you of all your drugs and " .
        door_money($taken) . "!" . $RST, 1);

      # Take a gun too
      if (@{$g->{guns}} > 0) {
        pop @{$g->{guns}};
        writeline($config{'errorcolor'} . "  They confiscate one of your guns!" . $RST, 1);
      }
    }
  } else {
    writeline($config{'systemcolor'} . "  Bullets zing past your ear!" . $RST, 1);
  }
}

sub _dl_total_drugs {
  my ($g) = @_;
  my $total = 0;
  for my $i (0 .. $#DRUGS) {
    $total += $g->{drugs}[$i]{carried};
  }
  return $total;
}

# ============================================================================
# TRADING MENU
# ============================================================================

sub _dl_trade_menu {
  my ($g) = @_;

  # Compact status bar for trade menu - just enough to see current state
  my $_dl_trade_header = sub {
    my ($g) = @_;
    door_clear();
    my $loc  = $LOCATIONS[$g->{location}];
    my $net  = $g->{cash} + $g->{bank} - $g->{debt};
    my $space = _dl_free_space($g);
    writeline($config{'themecolor'} . " DrugLord" .
      $config{'systemcolor'} . "  Day " . $config{'datacolor'} . "$g->{turn}" .
      $config{'systemcolor'} . " of " . $config{'datacolor'} . "$MAX_TURNS" .
      $config{'systemcolor'} . "  |  " . $config{'usercolor'} . $loc->{name} . $RST, 1);
    writeline($config{'systemcolor'} . " Cash: " . $config{'datacolor'} . door_money($g->{cash}) .
      $config{'systemcolor'} . "  Net: " . ($net >= 0 ? $config{'usercolor'} : $config{'errorcolor'}) . door_money($net) .
      $config{'systemcolor'} . "  Space: " . $config{'datacolor'} . "$space" .
      $config{'systemcolor'} . "  Health: " . _dl_health_color($g->{health}) . "$g->{health}%" . $RST, 1);
    door_hrule(50);
  };

  my $trading = 1;
  while ($trading) {
    $_dl_trade_header->($g);

    # Layout:
    # Left cell: "  %-4s %-12s %10s %8s" = 2+4+1+12+1+10+1+8 = 39 visible chars
    # Separator:  " " + vertical + " " = 3 chars
    # Total row width: 42 + menu text
    # Full-width separator matches _dl_show_status: 60 chars
    my $FW  = 60;  # full-width separator
    my $h   = boxchar('horizontal');
    my $sep = $config{'linecolor'} . " " . ($h x $FW) . $RST;
    my $vl  = " " . $config{'linecolor'} . boxchar('vertical') . $RST . " ";

    # Events (full width, all together, then one separator)
    for my $ev (@{$g->{events}}) {
      writeline($ev, 1);
    }
    # Single separator after events (or after header if no events)
    writeline($sep, 1);

    # Column headers
    # Drug rows: "  " + "%-4s" + "%-12s " + "%10s " + "%8s" = 2+4+13+11+8 = 38 chars
    # Header must match: "  " + "#   " + "Drug         " + "     Price " + "   Owned" = 38
    writeline(
      "  " . $config{'systemcolor'} . sprintf("%-4s%-13s%10s %8s", "#", "Drug", "Price", "Owned") . $RST .
      $vl . $config{'systemcolor'} . "Commands" . $RST,
      1);
    writeline($sep, 1);

    # Drug list (left) paired with menu items (right)
    my @menu_labels = (
      $config{'promptcolor'} . "[B]" . $config{'usercolor'} . "uy drugs",
      $config{'promptcolor'} . "[S]" . $config{'usercolor'} . "ell drugs",
      $config{'promptcolor'} . "[J]" . $config{'usercolor'} . "et to location",
      $config{'promptcolor'} . "[I]" . $config{'usercolor'} . "nventory",
      $config{'promptcolor'} . "[R]" . $config{'usercolor'} . "ob a dealer",
      $config{'promptcolor'} . "[C]" . $config{'usercolor'} . "hat",
      $config{'promptcolor'} . "[N]" . $config{'usercolor'} . "ews",
      $config{'promptcolor'} . "[H]" . $config{'usercolor'} . "igh scores",
      $config{'promptcolor'} . "[Q]" . $config{'usercolor'} . "uit game",
    );

    my @drug_rows;
    for my $i (0 .. $#DRUGS) {
      next if $g->{prices}[$i] == 0;
      my $carried = $g->{drugs}[$i]{carried};
      my $ccolor  = $carried > 0 ? $config{'usercolor'} : $config{'linecolor'};
      # "  %-4s %-12s %10s %8s" = 39 visible chars
      push @drug_rows,
        "  " .
        $config{'promptcolor'} . sprintf("%-4s", $i + 1) .
        $config{'themecolor'}  . sprintf("%-12s ", $DRUGS[$i]{name}) .
        $config{'datacolor'}   . sprintf("%10s ", door_money($g->{prices}[$i])) .
        $ccolor                . sprintf("%8s", ($carried > 0 ? $carried : "-")) .
        $RST;
    }

    my $nrows = @drug_rows > @menu_labels ? scalar @drug_rows : scalar @menu_labels;
    for my $i (0 .. $nrows - 1) {
      # Left: drug row (38 visible) or 38 spaces if none
      my $lpart = $drug_rows[$i] // (" " x 38);
      my $rpart = $menu_labels[$i] // "";
      writeline($lpart . $vl . $rpart . $RST, 1);
    }

    # Bottom separator
    writeline($sep, 1);

    writeline("", 1);
    writeline($config{'promptcolor'} . " What now: " . $RST);
    my $choice = uc(waitkey(""));
    writeline("", 1);

    if ($choice eq 'B') {
      _dl_buy($g);
    } elsif ($choice eq 'S') {
      _dl_sell($g);
    } elsif ($choice eq 'J') {
      $trading = 0;
    } elsif ($choice eq 'I') {
      _dl_show_inventory($g);
    } elsif ($choice eq 'C') {
      door_chat_input($DOOR_NAME);
    } elsif ($choice eq 'N') {
      _dl_street_news($g);
    } elsif ($choice eq 'R') {
      _dl_rob_player($g);
    } elsif ($choice eq 'H') {
      door_show_scores($DOOR_NAME, "DrugLord High Scores", "Net Worth");
      door_pause();
      _dl_show_status($g);
    } elsif ($choice eq 'Q') {
      if (door_noyes("Really quit?")) {
        $g->{quit} = 1;
        $trading = 0;
      }
    }
  }
}

# ============================================================================
# BUY / SELL
# ============================================================================

sub _dl_buy {
  my ($g) = @_;
  _dl_show_status($g);
  my $space = _dl_free_space($g);
  if ($space <= 0) {
    writeline($config{'errorcolor'} . "  Your coat is full!" . $RST, 1);
    return;
  }

  writeline($config{'themecolor'} . "  Buy which drug?" . $RST, 1);
  my $drug_num = door_getnum("Drug #? (0 to cancel)", scalar @DRUGS);
  return if $drug_num == 0;

  my $di = $drug_num - 1;
  if ($g->{prices}[$di] == 0) {
    writeline($config{'errorcolor'} . "  Not available here." . $RST, 1);
    return;
  }

  my $price = $g->{prices}[$di];
  my $max_afford = $price > 0 ? int($g->{cash} / $price) : 0;
  my $max_buy = $max_afford < $space ? $max_afford : $space;

  writeline($config{'systemcolor'} . "  $DRUGS[$di]{name} at " . door_money($price) .
    " each. You can afford $max_afford, space for $space." . $RST, 1);

  my $amount = door_getamount("Buy how many?", $max_buy);
  return if $amount <= 0;

  if ($amount > $max_afford) {
    writeline($config{'errorcolor'} . "  You can't afford that many." . $RST, 1);
    return;
  }
  if ($amount > $space) {
    writeline($config{'errorcolor'} . "  Not enough room." . $RST, 1);
    return;
  }

  my $cost = $amount * $price;
  $g->{cash} -= $cost;
  $g->{drugs}[$di]{carried} += $amount;
  $g->{drugs}[$di]{total_value} += $cost;
  writeline($config{'usercolor'} . "  Bought $amount $DRUGS[$di]{name} for " . door_money($cost) . "." . $RST, 1);
}

sub _dl_sell {
  my ($g) = @_;
  _dl_show_status($g);
  if (_dl_total_drugs($g) == 0) {
    writeline($config{'errorcolor'} . "  You have nothing to sell!" . $RST, 1);
    return;
  }

  writeline($config{'themecolor'} . "  Sell which drug?" . $RST, 1);
  my $drug_num = door_getnum("Drug #? (0 to cancel)", scalar @DRUGS);
  return if $drug_num == 0;

  my $di = $drug_num - 1;
  if ($g->{drugs}[$di]{carried} == 0) {
    writeline($config{'errorcolor'} . "  You don't have any $DRUGS[$di]{name}." . $RST, 1);
    return;
  }

  if ($g->{prices}[$di] == 0) {
    writeline($config{'errorcolor'} . "  No buyers for $DRUGS[$di]{name} here." . $RST, 1);
    return;
  }

  my $price = $g->{prices}[$di];
  my $max_sell = $g->{drugs}[$di]{carried};

  writeline($config{'systemcolor'} . "  $DRUGS[$di]{name} at " . door_money($price) .
    " each. You have $max_sell." . $RST, 1);

  my $amount = door_getamount("Sell how many?", $max_sell);
  return if $amount <= 0;

  if ($amount > $max_sell) {
    writeline($config{'errorcolor'} . "  You don't have that many." . $RST, 1);
    return;
  }

  my $revenue = $amount * $price;
  $g->{cash} += $revenue;
  $g->{drugs}[$di]{carried} -= $amount;
  # Adjust tracked value proportionally
  if ($g->{drugs}[$di]{carried} == 0) {
    $g->{drugs}[$di]{total_value} = 0;
  } else {
    my $ratio = $g->{drugs}[$di]{carried} / ($g->{drugs}[$di]{carried} + $amount);
    $g->{drugs}[$di]{total_value} = int($g->{drugs}[$di]{total_value} * $ratio);
  }
  writeline($config{'usercolor'} . "  Sold $amount $DRUGS[$di]{name} for " . door_money($revenue) . "." . $RST, 1);
}

