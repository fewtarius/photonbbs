sub _rd_healer {
  my ($p) = @_;

  door_header("The Healer");
  writeline($config{'systemcolor'} . " A kind old woman looks up from her herbs." . $RST, 1);
  writeline("", 1);

  unless ($p->{alive}) {
    my $cost = int($p->{gold} * 0.15);
    $cost = 100 if $cost < 100;
    writeline($config{'errorcolor'} . " You are dead!" . $RST, 1);
    writeline($config{'systemcolor'} . " The healer can resurrect you for " .
      $config{'datacolor'} . _fmt($cost) . " gold" . $RST, 1);
    writeline("", 1);
    writeline($config{'systemcolor'} . " Resurrect? (Y/N) " . $RST);
    my $ch = uc(waitkey("")); writeline("", 1);
    if ($ch eq 'Y') {
      if ($p->{gold} >= $cost) {
        $p->{gold} -= $cost;
        $p->{alive} = 1;
        $p->{hp} = int($p->{max_hp} * 0.5);
        writeline($config{'usercolor'} . " You feel life flow back into your body!" . $RST, 1);
        door_save($DOOR_NAME, $p);
      } else {
        writeline($config{'errorcolor'} . " You can't afford resurrection!" . $RST, 1);
        # Free resurrection if broke
        if ($p->{gold} < 50) {
          writeline($config{'systemcolor'} . " The healer takes pity on you..." . $RST, 1);
          $p->{alive} = 1;
          $p->{hp} = int($p->{max_hp} * 0.25);
          $p->{gold} = 0;
          writeline($config{'usercolor'} . " You are brought back weakly." . $RST, 1);
          door_save($DOOR_NAME, $p);
        }
      }
    }
    door_pause();
    return;
  }

  if ($p->{hp} >= $p->{max_hp}) {
    writeline($config{'systemcolor'} . " You are already at full health!" . $RST, 1);
    door_pause();
    return;
  }

  my $missing = $p->{max_hp} - $p->{hp};
  my $cost_per_hp = int($p->{level} * 1.5) + 1;
  my $full_cost = $missing * $cost_per_hp;

  writeline($config{'systemcolor'} . " HP: " . $config{'datacolor'} . "$p->{hp}/$p->{max_hp}" .
    $config{'systemcolor'} . "  Gold: " . $config{'datacolor'} . _fmt($p->{gold}) . $RST, 1);
  writeline($config{'systemcolor'} . " Full heal cost: " . $config{'datacolor'} . _fmt($full_cost) . " gold" .
    $config{'systemcolor'} . " ($cost_per_hp gold per HP)" . $RST, 1);
  writeline("", 1);

  writeline("  " . $config{'promptcolor'} . "F" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Full Heal" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "H" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Heal Half" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "Q" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Leave" . $RST, 1);
  writeline("", 1);
  writeline($config{'systemcolor'} . " Choice? " . $RST);
  my $ch = uc(getline('text', 1, "", 1));

  if ($ch eq 'F') {
    if ($p->{gold} >= $full_cost) {
      $p->{gold} -= $full_cost;
      $p->{hp} = $p->{max_hp};
      writeline($config{'usercolor'} . " You are fully healed!" . $RST, 1);
    } else {
      # Heal what they can afford
      my $can_heal = int($p->{gold} / $cost_per_hp);
      if ($can_heal > 0) {
        $p->{gold} -= $can_heal * $cost_per_hp;
        $p->{hp} += $can_heal;
        $p->{hp} = $p->{max_hp} if $p->{hp} > $p->{max_hp};
        writeline($config{'systemcolor'} . " Healed $can_heal HP (all you could afford)." . $RST, 1);
      } else {
        writeline($config{'errorcolor'} . " You can't afford any healing!" . $RST, 1);
      }
    }
  }
  elsif ($ch eq 'H') {
    my $half = int($missing / 2);
    $half = 1 if $half < 1;
    my $cost = $half * $cost_per_hp;
    if ($p->{gold} >= $cost) {
      $p->{gold} -= $cost;
      $p->{hp} += $half;
      writeline($config{'usercolor'} . " Healed $half HP." . $RST, 1);
    } else {
      writeline($config{'errorcolor'} . " You can't afford that!" . $RST, 1);
    }
  }

  door_save($DOOR_NAME, $p);
  door_pause();
}

