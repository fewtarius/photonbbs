# ============================================================================
# UNIFIED SLASH COMMANDS
# ============================================================================
# Door games call door_check_command() when the user presses '/' during input.
# It reads a command via getline and dispatches it. Returns 1 if handled.

my %_DOOR_COMMANDS = (
  'who'     => \&_door_cmd_who,
  'online'  => \&_door_cmd_who,
  'w'       => \&_door_cmd_who,
  'scores'  => \&_door_cmd_scores,
  'top'     => \&_door_cmd_scores,
  'chat'    => \&_door_cmd_chat,
  'c'       => \&_door_cmd_chat,
  'help'    => \&_door_cmd_help,
  'h'       => \&_door_cmd_help,
  '?'       => \&_door_cmd_help,
);

# Quick single-key shortcut handler for door games.
# Call from waitkey() loop: next if door_check_shortcut($key, $DOOR_NAME);
# Returns 1 if the key was a shortcut (handled), 0 if not.
sub door_check_shortcut {
  my ($key, $doorname) = @_;
  if ($key eq '#') {
    door_keepalive();
    whosonline() if defined &whosonline;
    door_pause();
    return 1;
  }
  if ($key eq '%') {
    door_keepalive();
    oneliners() if defined &oneliners;
    return 1;
  }
  return 0;
}

# Main entry: call when user presses '/' during a door game prompt.
# $doorname = current game name, used for /scores and /chat
# Returns: 'quit' if user wants to exit, 1 if command handled, 0 if not
sub door_check_command {
  my ($doorname) = @_;
  writeline($config{'promptcolor'} . "/" . $RST);
  my $cmd_line = getline('text', 60, "", 1);
  return 0 unless defined $cmd_line && $cmd_line =~ /\S/;
  $cmd_line =~ s/^\s+|\s+$//g;

  my ($cmd, $args) = split(/\s+/, $cmd_line, 2);
  $cmd = lc($cmd // '');
  $args //= '';

  # Check for quit/exit
  if ($cmd eq 'quit' || $cmd eq 'exit' || $cmd eq 'q') {
    return 'quit';
  }

  my $handler = $_DOOR_COMMANDS{$cmd};
  if ($handler) {
    $handler->($doorname, $args);
    return 1;
  }

  writeline($config{'errorcolor'} . " Unknown command: /$cmd  (try /help)" . $RST, 1);
  return 0;
}

sub _door_cmd_who {
  my ($doorname, $args) = @_;
  writeline("", 1);
  if (defined &whosonline) {
    whosonline();
  } else {
    # Fallback: show online players from door broker
    my @players = door_get_online_players();
    if (@players) {
      writeline($config{'themecolor'} . " Online:" . $RST, 1);
      for my $p (@players) {
        writeline("  " . $config{'usercolor'} . $p . $RST, 1);
      }
    } else {
      writeline($config{'systemcolor'} . " No other players online." . $RST, 1);
    }
  }
  writeline("", 1);
}

sub _door_cmd_scores {
  my ($doorname, $args) = @_;
  writeline("", 1);
