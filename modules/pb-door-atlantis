sub _atl_equipment_shop {
  my ($p) = @_;

  my $done = 0;
  while (!$done) {
    door_header("Port Meridian - Equipment Shop");
    writeline($config{'systemcolor'} . " Gold: " . $config{'datacolor'} . _afmt($p->{gold}) . $RST, 1);
    writeline("", 1);

    writeline("  " . $config{'promptcolor'} . "G" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Diving Gear" .
      $config{'systemcolor'} . " (current: $DIVING_GEAR[$p->{gear}]{name})" . $RST, 1);
    writeline("  " . $config{'promptcolor'} . "W" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Weapons" .
      $config{'systemcolor'} . " (current: $WEAPONS[$p->{weapon}]{name})" . $RST, 1);
    writeline("  " . $config{'promptcolor'} . "T" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Tools" .
      $config{'systemcolor'} . " (current: $TOOLS[$p->{tool}]{name})" . $RST, 1);
    writeline("  " . $config{'promptcolor'} . "Q" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Leave" . $RST, 1);
    writeline("", 1);
    writeline($config{'systemcolor'} . " Choice? " . $RST);
    my $ch = uc(getline('text', 1, "", 1));

    if    ($ch eq 'G') { _atl_buy_list($p, 'gear', \@DIVING_GEAR, "Diving Gear", "O2"); }
    elsif ($ch eq 'W') { _atl_buy_list($p, 'weapon', \@WEAPONS, "Weapons", "ATK"); }
    elsif ($ch eq 'T') { _atl_buy_list($p, 'tool', \@TOOLS, "Salvage Tools", "Salvage"); }
    elsif ($ch eq 'Q') { $done = 1; }
  }
}

sub _atl_buy_list {
  my ($p, $slot, $items, $title, $stat_label) = @_;

  door_header($title);
  writeline($config{'systemcolor'} . " Gold: " . $config{'datacolor'} . _afmt($p->{gold}) . $RST, 1);
  writeline("", 1);

  my $idx = 0;
  for my $item (@$items) {
    next if $idx == 0 && $item->{price} == 0; # Skip free starting items in display
    my $afford = ($p->{gold} >= $item->{price} || $idx == 0) ? $config{'datacolor'} : $config{'linecolor'};
    my $own = ($idx == $p->{$slot}) ? $config{'usercolor'} . " (owned)" : "";
    my $stat;
    if ($slot eq 'gear')   { $stat = "O2:$item->{oxygen} Depth:$item->{depth}"; }
    elsif ($slot eq 'weapon') { $stat = "ATK:$item->{atk}"; }
    else                   { $stat = "Salvage:$item->{salvage}"; }

    writeline(sprintf("  %s%-2d%s %s%-22s%s %-16s %s%s%s",
      $config{'promptcolor'}, $idx, $config{'themecolor'},
      $afford, $item->{name}, $config{'themecolor'},
      $stat,
      $config{'systemcolor'}, ($item->{price} > 0 ? _afmt($item->{price}) . " gold" : "Free"),
      $own . $RST), 1);
    $idx++;
  }

  writeline("", 1);
  writeline($config{'systemcolor'} . " Buy which? (0 to leave) " . $RST);
  my $choice = int(getline('text', 2, "", 1));

  if ($choice > 0 && $choice <= $#$items) {
    my $item = $items->[$choice];
    if ($choice == $p->{$slot}) {
      writeline($config{'systemcolor'} . " You already own that!" . $RST, 1);
    }
    elsif ($p->{gold} < $item->{price}) {
      writeline($config{'errorcolor'} . " Not enough gold!" . $RST, 1);
    }
    else {
      # Trade in old for 40%
      if ($p->{$slot} > 0) {
        my $sell = int($items->[$p->{$slot}]{price} * 0.4);
        $p->{gold} += $sell;
        writeline($config{'systemcolor'} . " Traded in " . $items->[$p->{$slot}]{name} . " for " .
          $config{'datacolor'} . _afmt($sell) . " gold" . $RST, 1);
      }
      $p->{gold} -= $item->{price};
      $p->{$slot} = $choice;
      # Update max oxygen if gear changed
      if ($slot eq 'gear') {
        $p->{max_oxygen} = $item->{oxygen};
      }
      writeline($config{'usercolor'} . " Purchased $item->{name}!" . $RST, 1);
      door_save($DOOR_NAME, $p);
    }
  }
  door_pause();
}

