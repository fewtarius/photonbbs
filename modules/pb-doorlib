# ============================================================================
# MULTIPLAYER SESSION SYSTEM
# ============================================================================
#
# File-based session management for real-time multiplayer door games.
# Sessions are shared game state files that multiple players poll.
#
# Flow:
#   1. Host calls door_session_create() - creates session, waits for joiners
#   2. Joiner calls door_session_list() - sees open sessions
#   3. Joiner calls door_session_join() - adds themselves to session
#   4. Host sees joiner via door_session_poll() - starts game
#   5. During game: door_session_update/read for shared state
#   6. Game over: door_session_destroy()
#
# Session files: data/doors/<game>/sessions/<id>.dat
#

# Create a new multiplayer session. Returns session hashref.
sub door_session_create {
  my ($doorname, $opts) = @_;
  $opts //= {};
  my $max_players = $opts->{max_players} // 2;
  my $session_id = _door_session_id();
  my $dir = door_data_dir($doorname) . "/sessions";
  mkdir $dir unless -d $dir;

  my $session = {
    id          => $session_id,
    doorname    => $doorname,
    host        => $info{'handle'},
    host_node   => $info{'node'} // 0,
    max_players => $max_players,
    players     => [{
      name => $info{'handle'},
      node => $info{'node'} // 0,
      type => 'human',
    }],
    status      => 'waiting',   # waiting, playing, done
    created     => time(),
    updated     => time(),
    game_state  => $opts->{game_state} // {},
  };

  my $file = "$dir/$session_id.dat";
  eval { lock_store($session, $file); };
  if ($@) {
    door_debug($doorname, "Session create failed: $@");
    return undef;
  }

  # Announce via broker
  my $need = $max_players - 1;
  my $plr = $need == 1 ? "player" : "players";
  door_broadcast($doorname, "$info{'handle'} started a $max_players-player $doorname game! Need $need more $plr.");

  return $session;
}

# Generate a short session ID
sub _door_session_id {
  my @chars = ('A'..'Z', '0'..'9');
  my $id = '';
  $id .= $chars[int(rand(@chars))] for 1..6;
  return $id;
}

# List open sessions for a game (status=waiting)
sub door_session_list {
  my ($doorname) = @_;
  my $dir = door_data_dir($doorname) . "/sessions";
  return [] unless -d $dir;

  my @sessions;
  if (opendir(my $dh, $dir)) {
    for my $f (readdir($dh)) {
      next unless $f =~ /^(.+)\.dat$/;
      my $file = "$dir/$f";
      my $session;
      eval { $session = lock_retrieve($file); };
      next if $@ || !$session;
      # Clean up stale sessions (>5 min waiting, >30 min playing)
      if ($session->{status} eq 'waiting' && time() - $session->{created} > 300) {
        unlink $file;
        next;
      }
      if ($session->{status} eq 'playing' && time() - $session->{updated} > 1800) {
        unlink $file;
        next;
      }
      push @sessions, $session if $session->{status} eq 'waiting';
    }
    closedir($dh);
  }
  return \@sessions;
}

# Join an existing session. Returns updated session or undef on failure.
sub door_session_join {
  my ($doorname, $session_id) = @_;
  my $dir = door_data_dir($doorname) . "/sessions";
  my $file = "$dir/$session_id.dat";
  return undef unless -e $file;

  my $session;
  eval { $session = lock_retrieve($file); };
  return undef if $@ || !$session;
  return undef if $session->{status} ne 'waiting';
  return undef if scalar @{$session->{players}} >= $session->{max_players};

  # Check if already in session
  for my $p (@{$session->{players}}) {
    return $session if lc($p->{name}) eq lc($info{'handle'});
  }

  push @{$session->{players}}, {
    name => $info{'handle'},
    node => $info{'node'} // 0,
    type => 'human',
  };
  $session->{updated} = time();

  # Auto-start if full
  if (scalar @{$session->{players}} >= $session->{max_players}) {
    $session->{status} = 'playing';
  }

  eval { lock_store($session, $file); };
  return $@ ? undef : $session;
}

# Poll a session for updates (check if new players joined, state changed)
sub door_session_poll {
  my ($doorname, $session_id) = @_;
  my $dir = door_data_dir($doorname) . "/sessions";
  my $file = "$dir/$session_id.dat";
  return undef unless -e $file;
  my $session;
  eval { $session = lock_retrieve($file); };
  return $@ ? undef : $session;
}

# Update session game state (called by the active player after their turn)
sub door_session_update {
  my ($doorname, $session_id, $updates) = @_;
  my $dir = door_data_dir($doorname) . "/sessions";
  my $file = "$dir/$session_id.dat";
  return undef unless -e $file;

  my $session;
  eval { $session = lock_retrieve($file); };
  return undef if $@ || !$session;

  # Merge updates
  for my $key (keys %$updates) {
    $session->{$key} = $updates->{$key};
  }
  $session->{updated} = time();

  eval { lock_store($session, $file); };
  return $@ ? undef : $session;
}

# Destroy a session (game over)
sub door_session_destroy {
  my ($doorname, $session_id) = @_;
  my $dir = door_data_dir($doorname) . "/sessions";
  my $file = "$dir/$session_id.dat";
  unlink $file if -e $file;
}

# Wait for players to join a session. Returns session when full or timed out.
# Options: timeout (seconds per cycle, default 60), max_cycles (default 3)
sub door_session_wait {
  my ($doorname, $session_id, $opts) = @_;
  $opts //= {};
  my $timeout = $opts->{timeout} // 60;
  my $max_cycles = $opts->{max_cycles} // 3;

  for my $cycle (1 .. $max_cycles) {
    my $deadline = time() + $timeout;
    my $last_count = 0;

    while (time() < $deadline) {
      my $session = door_session_poll($doorname, $session_id);
      return undef unless $session;

      my $count = scalar @{$session->{players}};
      if ($count != $last_count) {
        # New player joined
        my $newest = $session->{players}[$count - 1]{name};
        writeline($config{'usercolor'} . " $newest joined!" . $RST, 1) if $count > 1;
        $last_count = $count;
      }

      # Session full?
      if ($count >= $session->{max_players}) {
        $session->{status} = 'playing';
        door_session_update($doorname, $session_id, { status => 'playing' });
        return $session;
      }

      # Show countdown
      my $remaining = $deadline - time();
      my $need = $session->{max_players} - $count;
      writeline("\r" . $config{'systemcolor'} . " Waiting for $need more... ${remaining}s " . $RST, 0);

      # Brief sleep then check for input (allow early start/cancel)
      my $key = "";
      eval {
        local $SIG{ALRM} = sub { die "timeout\n"; };
        alarm(2);
        $key = waitkey("", 2);
        alarm(0);
      };
      alarm(0);

      if ($key && uc($key) eq 'Q') {
        writeline("", 1);
        door_session_destroy($doorname, $session_id);
        return undef;
      }
      if ($key && uc($key) eq 'A') {
        # Fill with AI
        writeline("", 1);
        return $session;
      }
    }

    writeline("", 1);
    my $session = door_session_poll($doorname, $session_id);
    return undef unless $session;
    my $need = $session->{max_players} - scalar @{$session->{players}};

    if ($need > 0) {
      writeline($config{'systemcolor'} . " Still need $need player(s)." . $RST, 1);
      my $choice = door_menu([
        ['W', 'Keep waiting'],
        ['A', 'Fill with AI'],
        ['Q', 'Cancel game'],
      ], "Action");

      if ($choice eq 'Q') {
        door_session_destroy($doorname, $session_id);
        return undef;
      }
      if ($choice eq 'A') {
        return $session;
      }
      # else keep waiting (next cycle)
    }
  }

  # Max cycles exceeded - return what we have
  return door_session_poll($doorname, $session_id);
}

# ============================================================================
# MULTIPLAYER TURN SYNC (broker-based)
# ============================================================================
# These functions enable real-time multiplayer across separate telnet sessions.
# Each player joins a game-specific broker room. The active player broadcasts
# game state after each action. Waiting players poll for updates.
#
# Usage pattern:
#   1. Host creates session, all players door_game_room_join()
#   2. Active player takes turn, then calls door_game_state_send()
#   3. Other players call door_game_state_recv() to get updates
#   4. door_game_wait_turn() blocks until it's this player's turn

# Join a game-specific broker room for multiplayer sync
sub door_game_room_join {
  my ($doorname, $session_id) = @_;
  return unless $_DOOR_BROKER_SOCK && $_HAS_BROKER_CLIENT;
  my $room = "door-$doorname-$session_id";
  broker_join_room($_DOOR_BROKER_SOCK, $room);
  $_DOOR_BROKER_ROOM = $room;
}

# Send game state to all players in the session room
# state is a hashref that will be JSON-encoded in the message
sub door_game_state_send {
  my ($doorname, $state) = @_;
  return unless $_DOOR_BROKER_SOCK && $_DOOR_BROKER_ROOM && $_HAS_BROKER_CLIENT;
  my $json = eval { encode_json($state) };
  return unless $json;
  broker_send_room_message($_DOOR_BROKER_SOCK, $_DOOR_BROKER_ROOM,
    "GAMESTATE:$json");
}

# Receive game state updates (non-blocking)
# Returns arrayref of state hashrefs, plus any chat messages
sub door_game_state_recv {
  my ($doorname) = @_;
  my @states;
  my @chats;
  if ($_DOOR_BROKER_SOCK && $_HAS_BROKER_CLIENT) {
    eval {
      my @msgs = broker_poll($_DOOR_BROKER_SOCK);
      for my $m (@msgs) {
        if ($m->{type} eq 'room_message' && $m->{message}) {
          if ($m->{message} =~ /^GAMESTATE:(.+)$/) {
            my $state = eval { decode_json($1) };
            push @states, $state if $state;
          } else {
            push @chats, $m->{message};
          }
        } elsif ($m->{type} eq 'player_entered' && $m->{player}) {
          push @chats, "[$doorname] $m->{player} joined.";
        } elsif ($m->{type} eq 'player_left' && $m->{player}) {
          push @chats, "[$doorname] $m->{player} left.";
        }
      }
    };
  }
  return (\@states, \@chats);
}

# Wait for this player's turn, displaying board updates as they arrive.
# Args:
#   doorname    - door game name
#   my_pidx     - this player's index in the game
#   render_fn   - coderef called with ($game_state) to redraw the screen
#   timeout     - max seconds to wait (default 120)
# Returns: latest game state hashref, or undef on timeout/disconnect
sub door_game_wait_turn {
  my ($doorname, $my_pidx, $render_fn, $timeout) = @_;
  $timeout //= 120;
  my $deadline = time() + $timeout;
  my $last_state;

  while (time() < $deadline) {
    my ($states, $chats) = door_game_state_recv($doorname);

    # Process any state updates
    for my $s (@$states) {
      $last_state = $s;
      # Render the updated board
      if ($render_fn && ref $render_fn eq 'CODE') {
        $render_fn->($s);
      }
    }

    # Show chat messages
    for my $c (@$chats) {
      writeline($config{'linecolor'} . " $c" . $RST, 1);
    }

    # Is it our turn?
    if ($last_state && defined $last_state->{current}) {
      return $last_state if $last_state->{current} == $my_pidx;
    }

    # Check for game over
    if ($last_state && $last_state->{over}) {
      return $last_state;
    }

    # Brief sleep, check for chat input
    my $key = "";
    eval {
      local $SIG{ALRM} = sub { die "timeout\n"; };
      alarm(1);
      $key = waitkey("", 1);
      alarm(0);
    };
    alarm(0);

    if ($key && lc($key) eq 'c') {
      door_chat_input($doorname);
    }
  }

  return $last_state;  # timeout
}


1;
