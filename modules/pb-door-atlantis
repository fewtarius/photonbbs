# ============================================================================
# DIVING - Core gameplay
# ============================================================================

sub _atl_dive {
  my ($p) = @_;

  if ($p->{turns} <= 0) {
    writeline("", 1);
    writeline($config{'systemcolor'} . " No turns remaining. Return tomorrow!" . $RST, 1);
    door_pause();
    return;
  }

  if ($p->{hp} <= 0) {
    writeline("", 1);
    writeline($config{'errorcolor'} . " You are too injured to dive! Rest until tomorrow." . $RST, 1);
    door_pause();
    return;
  }

  # Choose depth
  my $max_d = $DIVING_GEAR[$p->{gear}]{depth};
  writeline("", 1);
  writeline($config{'systemcolor'} . " Choose depth (1-$max_d): " . $RST);
  my $depth = int(getline('text', 1, "", 1) || 1);
  $depth = 1 if $depth < 1;
  $depth = $max_d if $depth > $max_d;
  $p->{depth} = $depth;

  # Set oxygen for this dive
  $p->{oxygen} = $DIVING_GEAR[$p->{gear}]{oxygen};

  $p->{dives}++;

  # Track max depth reached
  $p->{max_depth} = $depth if $depth > $p->{max_depth};

  my $surfaced = 0;
  while (!$surfaced && $p->{turns} > 0 && $p->{hp} > 0 && $p->{oxygen} > 0) {
    _atl_dive_screen($p);
    writeline("  " . $config{'promptcolor'} . "N" . $config{'themecolor'} . "orth  " .
              $config{'promptcolor'} . "S" . $config{'themecolor'} . "outh  " .
              $config{'promptcolor'} . "E" . $config{'themecolor'} . "ast  " .
              $config{'promptcolor'} . "W" . $config{'themecolor'} . "est  " .
              $config{'promptcolor'} . "X" . $config{'themecolor'} . "plore  " .
              $config{'promptcolor'} . "U" . $config{'themecolor'} . "p (Surface)" . $RST, 1);
    writeline("", 1);
    writeline($config{'systemcolor'} . " > " . $RST);
    my $ch = uc(getline('text', 1, "", 1));

    if    ($ch eq 'N') { _atl_move($p, 0, -1); }
    elsif ($ch eq 'S') { _atl_move($p, 0, 1); }
    elsif ($ch eq 'E') { _atl_move($p, 1, 0); }
    elsif ($ch eq 'W') { _atl_move($p, -1, 0); }
    elsif ($ch eq 'X') { _atl_explore_tile($p); }
    elsif ($ch eq 'U') { $surfaced = 1; }

    # Consume oxygen each action
    my $o2_cost = 3 + ($depth - 1) * 2;
    $p->{oxygen} -= $o2_cost;

    # Random encounter (30%)
    if (!$surfaced && rand(100) < 30) {
      _atl_encounter($p);
    }

    if ($p->{oxygen} <= 0) {
      writeline("", 1);
      writeline($config{'errorcolor'} . " WARNING: Oxygen depleted! Emergency surface!" . $RST, 1);
      my $dmg = int($p->{max_hp} * 0.2);
      $p->{hp} -= $dmg;
      writeline($config{'errorcolor'} . " You take $dmg damage from the bends!" . $RST, 1);
      $surfaced = 1;
    }
  }

  if ($p->{hp} <= 0) {
    $p->{hp} = 0;
    writeline("", 1);
    writeline($config{'errorcolor'} . " You have drowned in the depths!" . $RST, 1);
    writeline($config{'systemcolor'} . " A rescue team recovers your body." . $RST, 1);
    # Lose some gold and artifacts
    my $lost = int($p->{gold} * 0.15);
    $p->{gold} -= $lost;
    $p->{gold} = 0 if $p->{gold} < 0;
    writeline($config{'errorcolor'} . " You lost " . _afmt($lost) . " gold." . $RST, 1);
    $p->{hp} = int($p->{max_hp} * 0.3);
  }

  if ($surfaced) {
    writeline("", 1);
    writeline($config{'usercolor'} . " You surface safely." . $RST, 1);
  }

  door_save($DOOR_NAME, $p);
  door_pause();
}

sub _atl_dive_screen {
  my ($p) = @_;
  my $d = $p->{depth} - 1;
  my $tile = $p->{map}[$d][$p->{y}][$p->{x}];
  my $tinfo = $TERRAIN{$tile};

  door_clear();
  writeline($config{'themecolor'} . " Depth Level $p->{depth}" . $RST, 1);
  writeline($config{'linecolor'} . " " . ("-" x 50) . $RST, 1);
  writeline($config{'systemcolor'} . " O2: " . $config{'datacolor'} . "$p->{oxygen}" .
    $config{'systemcolor'} . "  HP: " . $config{'datacolor'} . "$p->{hp}/$p->{max_hp}" .
    $config{'systemcolor'} . "  Turns: " . $config{'datacolor'} . "$p->{turns}" .
    $config{'systemcolor'} . "  Pos: " . $config{'datacolor'} . "$p->{x},$p->{y}" . $RST, 1);
  writeline("", 1);

  # Mini-map (5x5 viewport)
  my $view = 2;
  for my $vy (-$view .. $view) {
    my $line = "  ";
    for my $vx (-$view .. $view) {
      my $mx = $p->{x} + $vx;
      my $my = $p->{y} + $vy;
      if ($vx == 0 && $vy == 0) {
        $line .= $config{'usercolor'} . "@" . $RST;
      }
      elsif ($mx >= 0 && $mx < $MAP_SIZE && $my >= 0 && $my < $MAP_SIZE) {
        my $t = $p->{map}[$d][$my][$mx];
        my $key = "$d:$mx:$my";
        if ($p->{explored}{$key}) {
          $line .= $config{$TERRAIN{$t}{color}} . $t . $RST;
        } else {
          $line .= $config{'linecolor'} . "." . $RST;
        }
      }
      else {
        $line .= " ";
      }
    }
    writeline($line, 1);
  }

  writeline("", 1);
  writeline($config{'systemcolor'} . " Location: " . $config{$tinfo->{color}} . $tinfo->{name} . $RST, 1);
  writeline("", 1);

  # Mark current tile explored
  my $key = "$d:$p->{x}:$p->{y}";
  $p->{explored}{$key} = 1;
}

sub _atl_move {
  my ($p, $dx, $dy) = @_;
  my $nx = $p->{x} + $dx;
  my $ny = $p->{y} + $dy;

  if ($nx < 0 || $nx >= $MAP_SIZE || $ny < 0 || $ny >= $MAP_SIZE) {
    writeline($config{'systemcolor'} . " You can't go that way." . $RST, 1);
    return;
  }

  my $d = $p->{depth} - 1;
  my $tile = $p->{map}[$d][$ny][$nx];
  my $cost = $TERRAIN{$tile}{move};

  $p->{x} = $nx;
  $p->{y} = $ny;
  $p->{turns} -= $cost;
}

# ============================================================================
# TILE EXPLORATION
# ============================================================================

sub _atl_explore_tile {
  my ($p) = @_;
  my $d = $p->{depth} - 1;
  my $tile = $p->{map}[$d][$p->{y}][$p->{x}];

  $p->{turns}--;

  if ($tile eq 'R' || $tile eq 'T') {
    _atl_salvage($p, $tile);
  }
  elsif ($tile eq 'C') {
    _atl_cave($p);
  }
  elsif ($tile eq 'V') {
    _atl_vent($p);
  }
  elsif ($tile eq 'A') {
    _atl_atlantis_gate($p);
  }
  else {
    writeline($config{'systemcolor'} . " Nothing of interest here." . $RST, 1);
    door_pause();
  }
}

sub _atl_salvage {
  my ($p, $tile) = @_;
  my $tool_bonus = $TOOLS[$p->{tool}]{salvage};
  my $find_chance = 40 + ($tool_bonus * 5);
  $find_chance = 95 if $find_chance > 95;

  writeline("", 1);
  if ($tile eq 'R') {
    writeline($config{'datacolor'} . " You search the sunken ruins..." . $RST, 1);
  } else {
    writeline($config{'usercolor'} . " You examine the treasure site..." . $RST, 1);
  }

  if (rand(100) < $find_chance) {
    # Found something - pick artifact based on rarity
    my $roll = rand(100);
    my $cumulative = 0;
    my $found;
    for my $art (@ARTIFACTS) {
      $cumulative += $art->{rarity};
      if ($roll < $cumulative) {
        $found = $art;
        last;
      }
    }
    $found //= $ARTIFACTS[0];

    # Depth bonus on value
    my $value = int($found->{value} * (1 + ($p->{depth} - 1) * 0.3));

    writeline($config{'usercolor'} . " You found: $found->{name}!" . $RST, 1);
    writeline($config{'systemcolor'} . " Estimated value: " . $config{'datacolor'} . _afmt($value) . " gold" . $RST, 1);

    push @{$p->{artifacts}}, { name => $found->{name}, value => $value };
    $p->{artifacts_found}++;
    $p->{exp} += int($value / 10);
  }
  else {
    my $gold = int(rand(20 * $p->{depth})) + 5;
    writeline($config{'systemcolor'} . " You find some loose coins: " . $config{'datacolor'} . "$gold gold" . $RST, 1);
    $p->{gold} += $gold;
  }
  door_pause();
}

sub _atl_cave {
  my ($p) = @_;
  writeline("", 1);
  writeline($config{'linecolor'} . " You enter the dark underwater cave..." . $RST, 1);

  my $roll = rand(100);
  if ($roll < 30) {
    # Treasure cache
    my $gold = int(rand(100 * $p->{depth})) + 50;
    writeline($config{'usercolor'} . " A hidden treasure cache!" . $RST, 1);
    writeline($config{'datacolor'} . " You find " . _afmt($gold) . " gold!" . $RST, 1);
    $p->{gold} += $gold;
  }
  elsif ($roll < 50) {
    # Oxygen pocket
    my $o2 = int(rand(30)) + 20;
    writeline($config{'themecolor'} . " An air pocket! You refill some oxygen." . $RST, 1);
    $p->{oxygen} += $o2;
    $p->{oxygen} = $p->{max_oxygen} if $p->{oxygen} > $p->{max_oxygen};
    writeline($config{'datacolor'} . " +$o2 oxygen" . $RST, 1);
  }
  elsif ($roll < 70) {
    # Ambush!
    writeline($config{'errorcolor'} . " Something lurks in the darkness!" . $RST, 1);
    _atl_encounter($p);
    return;
  }
  else {
    writeline($config{'systemcolor'} . " The cave is empty." . $RST, 1);
  }
  door_pause();
}

sub _atl_vent {
  my ($p) = @_;
  writeline("", 1);
  writeline($config{'errorcolor'} . " Hot water bubbles from a thermal vent!" . $RST, 1);

  if (rand(100) < 40) {
    my $dmg = int(rand($p->{depth} * 5)) + 3;
    writeline($config{'errorcolor'} . " The heat scorches you! -$dmg HP" . $RST, 1);
    $p->{hp} -= $dmg;
  } else {
    # Mineral deposits
    my $gold = int(rand(50 * $p->{depth})) + 30;
    writeline($config{'datacolor'} . " You collect mineral deposits worth " . _afmt($gold) . " gold!" . $RST, 1);
    $p->{gold} += $gold;
    $p->{exp} += int($gold / 5);
  }
  door_pause();
}

sub _atl_atlantis_gate {
  my ($p) = @_;
  writeline("", 1);
  writeline($config{'promptcolor'} . " An ancient gate rises before you!" . $RST, 1);
  writeline($config{'promptcolor'} . " Runes glow with an otherworldly light." . $RST, 1);
  writeline($config{'themecolor'} . " This is the entrance to Atlantis!" . $RST, 1);
  writeline("", 1);

  if ($p->{atlantis_found}) {
    writeline($config{'systemcolor'} . " You have already conquered Atlantis." . $RST, 1);
    writeline($config{'systemcolor'} . " The gate stands open in tribute." . $RST, 1);
    door_pause();
    return;
  }

  writeline($config{'systemcolor'} . " Enter the gate? (Y/N) " . $RST);
  my $ch = uc(waitkey("")); writeline("", 1);
  return unless $ch eq 'Y';

  writeline("", 1);
  writeline($config{'errorcolor'} . " The $GUARDIAN{name} blocks your path!" . $RST, 1);
  writeline("", 1);

  my $ghp = $GUARDIAN{hp};
  my $gatk = $GUARDIAN{atk};

  while ($ghp > 0 && $p->{hp} > 0) {
    my $ghp_pct = int(($ghp / $GUARDIAN{hp}) * 100);
    writeline($config{'systemcolor'} . " Your HP: " . $config{'datacolor'} . "$p->{hp}/$p->{max_hp}" .
      $config{'systemcolor'} . "   Guardian: " . $config{'errorcolor'} . "$ghp_pct%" . $RST, 1);
    writeline("  " . $config{'promptcolor'} . "A" . $config{'themecolor'} . "ttack  " .
              $config{'promptcolor'} . "R" . $config{'themecolor'} . "un  ? " . $RST);
    my $move = uc(getline('text', 1, "", 1));

    if ($move eq 'A') {
      my $patk = $WEAPONS[$p->{weapon}]{atk} + int(rand(10));
      my $pdmg = $patk + int(rand($patk));
      $pdmg = 1 if $pdmg < 1;
      $ghp -= $pdmg;
      writeline($config{'usercolor'} . " You strike for $pdmg damage!" . $RST, 1);
    }
    elsif ($move eq 'R') {
      if (rand(100) < 40) {
        writeline($config{'systemcolor'} . " You flee the gate!" . $RST, 1);
        door_pause();
        return;
      }
      writeline($config{'errorcolor'} . " The Guardian blocks your escape!" . $RST, 1);
    }

    if ($ghp > 0) {
      my $mdmg = int(rand($gatk) * 0.5) + int($gatk * 0.3);
      # Gear reduces damage
      $mdmg -= int($DIVING_GEAR[$p->{gear}]{depth} * 5);
      $mdmg = 1 if $mdmg < 1;

      if (rand(100) < 20) {
        $mdmg = int($mdmg * 1.5);
        writeline($config{'errorcolor'} . " The Guardian summons a tidal wave! $mdmg damage!" . $RST, 1);
      } else {
        writeline($config{'errorcolor'} . " The Guardian strikes for $mdmg damage!" . $RST, 1);
      }
      $p->{hp} -= $mdmg;
    }
    writeline("", 1);
  }

  if ($p->{hp} <= 0) {
    $p->{hp} = 0;
    writeline($config{'errorcolor'} . " The Guardian has defeated you!" . $RST, 1);
    writeline($config{'systemcolor'} . " You are swept back to the surface." . $RST, 1);
    $p->{hp} = int($p->{max_hp} * 0.2);
  } else {
    writeline("", 1);
    writeline($config{'usercolor'} . " *** YOU HAVE DISCOVERED ATLANTIS! ***" . $RST, 1);
    writeline("", 1);
    writeline($config{'themecolor'} . " The ancient city opens before you in all" . $RST, 1);
    writeline($config{'themecolor'} . " its glory. Crystal spires and golden streets" . $RST, 1);
    writeline($config{'themecolor'} . " shimmer in the deep water light." . $RST, 1);
    writeline("", 1);

    $p->{atlantis_found} = 1;
    $p->{exp}  += $GUARDIAN{exp};
    $p->{gold} += $GUARDIAN{gold};
    writeline($config{'systemcolor'} . " Experience: " . $config{'datacolor'} . "+" . _afmt($GUARDIAN{exp}) . $RST, 1);
    writeline($config{'systemcolor'} . " Gold: " . $config{'datacolor'} . "+" . _afmt($GUARDIAN{gold}) . $RST, 1);

    door_submit_score($DOOR_NAME, $p->{max_depth}, { artifacts => $p->{artifacts_found} });
    door_broadcast($DOOR_NAME, "$info{'handle'} has discovered the lost city of Atlantis!");
  }

  door_save($DOOR_NAME, $p);
  door_pause();
}

