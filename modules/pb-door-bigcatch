sub _bc_display {
  my ($g) = @_;
  door_clear();
  my $lake = $LAKES[$g->{lake_idx}];
  my $lure = _bc_current_lure_name($g);
  my $boat_depth = $g->{lake}[$g->{boat_y}][$g->{boat_x}];

  writeline($config{'themecolor'} . " " . $lake->{name} .
    $config{'systemcolor'} . "  " . $g->{weather}{name} .
    "  Livewell: " . $config{'datacolor'} . scalar(@{$g->{livewell}}) . "/$LIVEWELL" .
    $config{'systemcolor'} . "  " . $config{'datacolor'} . _bc_money($g->{money}) . $RST, 1);

  for my $y (0 .. $LAKE_H - 1) {
    my $line = " ";
    for my $x (0 .. $LAKE_W - 1) {
      if ($y == $g->{boat_y} && $x == $g->{boat_x}) {
        $line .= $config{'usercolor'} . "@" . $RST; next;
      }
      if ($g->{fish_finder}) {
        my $dist = abs($y - $g->{boat_y}) + abs($x - $g->{boat_x});
        if ($dist <= 5) {
          my $fh = 0;
          for my $f (@{$g->{fish}}) {
            if ($f->{y} == $y && $f->{x} == $x && $f->{active}) {
              $line .= $config{'errorcolor'} . "o" . $RST; $fh = 1; last;
            }
          }
          next if $fh;
        }
      }
      my $depth = $g->{lake}[$y][$x];
      if ($depth < 0) {
        $line .= $config{'promptcolor'} . "#" . $RST;
      } else {
        my $surf = $g->{surface}[$y][$x];
        if ($surf > 0 && $surf <= $#SURFACE_TYPES) {
          $line .= $SURFACE_TYPES[$surf]{color} . $SURFACE_TYPES[$surf]{char} . $RST;
        } elsif ($depth <= 5) {  $line .= "\e[36m~" . $RST;
        } elsif ($depth <= 15) { $line .= "\e[34m~" . $RST;
        } elsif ($depth <= 30) { $line .= "\e[34;1m~" . $RST;
        } else {                 $line .= "\e[35m~" . $RST;
        }
      }
    }
    writeline($line, 1);
  }

  writeline("", 1);
  my $sn = $g->{surface}[$g->{boat_y}][$g->{boat_x}] >= 0
    ? $SURFACE_TYPES[$g->{surface}[$g->{boat_y}][$g->{boat_x}]]{name} : "Land";
  my $bn = $BOTTOM_TYPES[$g->{bottom}[$g->{boat_y}][$g->{boat_x}]]{name};
  writeline($config{'systemcolor'} . " Depth:" . $config{'datacolor'} . " ${boat_depth}ft" .
    $config{'systemcolor'} . " Surface:" . $config{'datacolor'} . " $sn" .
    $config{'systemcolor'} . " Bottom:" . $config{'datacolor'} . " $bn" .
    $config{'systemcolor'} . " Lure:" . $config{'datacolor'} . " $lure" . $RST, 1);
  writeline($config{'linecolor'} . " WASD=move C=cast T=tackle L=livewell F=finder S=shop" . $RST, 1);
  writeline($config{'linecolor'} . " H=scores R=tournament V=duel N=chat /=cmds Q=quit" . $RST, 1);

  # Show any incoming lake chat
  my @chat = door_chat_poll($DOOR_NAME);
  for my $m (@chat) {
    writeline($config{'linecolor'} . $m . $RST, 1);
  }
}

# ============================================================================
# DEPTH FINDER
# ============================================================================

sub _bc_depth_finder {
  my ($g) = @_;
  door_clear();
  writeline($config{'themecolor'} . " Depth Finder" . $RST, 1);
  door_hrule(45);

  my $range = 5;
  my ($by, $bx) = ($g->{boat_y}, $g->{boat_x});

  my $hdr = "     ";
  for my $dx (-$range .. $range) {
    my $x = $bx + $dx;
    if ($dx == 0) { $hdr .= $config{'usercolor'} . " @@ " . $RST; }
    elsif ($x >= 0 && $x < $LAKE_W && $g->{lake}[$by][$x] >= 0) { $hdr .= "    "; }
    else { $hdr .= " ## "; }
  }
  writeline($hdr, 1);

  for my $row (0 .. 9) {
    my $depth_at = ($row + 1) * 5;
    my $line = sprintf(" %s%3dft%s", $config{'linecolor'}, $depth_at, $RST);
    for my $dx (-$range .. $range) {
      my $x = $bx + $dx;
      if ($x < 0 || $x >= $LAKE_W) { $line .= " ## "; next; }
      my $d = $g->{lake}[$by][$x];
      if ($d < 0) {
        $line .= $config{'promptcolor'} . " ## " . $RST;
      } elsif ($d < $depth_at) {
        my @ch = ('..', '**', 'OO', '~~');
        $line .= $config{'promptcolor'} . " " . $ch[$g->{bottom}[$by][$x]] . " " . $RST;
      } else {
        my $fish_here = 0;
        if ($g->{fish_finder}) {
          for my $f (@{$g->{fish}}) {
            if ($f->{x} == $x && $f->{y} == $by && abs($f->{depth} - $depth_at) < 5) {
              $fish_here = 1; last;
            }
          }
        }
        if ($fish_here) { $line .= $config{'errorcolor'} . " <> " . $RST; }
        elsif ($g->{surface}[$by][$x] > 0 && $depth_at <= 10) {
          my $s = $g->{surface}[$by][$x];
          $line .= $SURFACE_TYPES[$s]{color} . " " . $SURFACE_TYPES[$s]{char} x 2 . " " . $RST;
        } else { $line .= "\e[34m .. " . $RST; }
      }
    }
    writeline($line, 1);
  }

  writeline("", 1);
  my $bd = $g->{lake}[$by][$bx];
  my $sn = $g->{surface}[$by][$bx] >= 0 ? $SURFACE_TYPES[$g->{surface}[$by][$bx]]{name} : "Land";
  my $bn = $BOTTOM_TYPES[$g->{bottom}[$by][$bx]]{name};
  writeline($config{'systemcolor'} . " Under boat: ${bd}ft  Surface: $sn  Bottom: $bn" . $RST, 1);
  door_pause();
}

# ============================================================================
# COMMAND HANDLER
# ============================================================================

sub _bc_command {
  my ($g) = @_;
  writeline($config{'promptcolor'} . " > " . $RST);
  my $cmd = lc(waitkey(""));
  writeline("", 1);

  if    ($cmd eq 'w' || $cmd eq "\e[A") { _bc_move($g, -1, 0); }
  elsif ($cmd eq 'x' || $cmd eq "\e[B") { _bc_move($g, 1, 0); }
  elsif ($cmd eq 'a' || $cmd eq "\e[D") { _bc_move($g, 0, -1); }
  elsif ($cmd eq 'd' || $cmd eq "\e[C") { _bc_move($g, 0, 1); }
  elsif ($cmd eq 'c') { _bc_cast($g); }
  elsif ($cmd eq 't') { _bc_tackle_box($g); }
  elsif ($cmd eq 'l') { _bc_show_livewell($g); }
  elsif ($cmd eq 'f') { _bc_depth_finder($g); }
  elsif ($cmd eq 's') { _bc_shop($g); }
  elsif ($cmd eq 'h') { _bc_scores($g); }
  elsif ($cmd eq 'r') { _bc_join_tournament($g); }
  elsif ($cmd eq 'v') { _bc_fishing_duel($g); }
  elsif ($cmd eq 'n') { door_chat_input($DOOR_NAME); }
  elsif (door_check_shortcut($cmd, $DOOR_NAME)) { }
  elsif ($cmd eq '/') {
    my $result = door_check_command($DOOR_NAME);
    if ($result && $result eq 'quit') { $g->{quit} = 1; }
    else { door_pause() unless $result; }
  }
  elsif ($cmd eq 'q') {
    writeline($config{'systemcolor'} . " Quit fishing? (Y/N) " . $RST);
    my $yn = uc(waitkey("")); writeline("", 1);
    $g->{quit} = 1 if $yn eq 'Y';
  }
  _bc_move_fish($g);
}

sub _bc_move {
  my ($g, $dy, $dx) = @_;
  my ($ny, $nx) = ($g->{boat_y} + $dy, $g->{boat_x} + $dx);
  return if $ny < 0 || $ny >= $LAKE_H || $nx < 0 || $nx >= $LAKE_W;
  return if $g->{lake}[$ny][$nx] < 0;
  $g->{boat_y} = $ny; $g->{boat_x} = $nx;
}

sub _bc_move_fish {
  my ($g) = @_;
  for my $f (@{$g->{fish}}) {
    next if rand(100) < 30;
    my $sp = $FISH[$f->{species}];
    my ($dy, $dx) = (int(rand(3)) - 1, int(rand(3)) - 1);
    my ($ny, $nx) = ($f->{y} + $dy, $f->{x} + $dx);
    next if $ny < 1 || $ny >= $LAKE_H-1 || $nx < 1 || $nx >= $LAKE_W-1;
    my $depth = $g->{lake}[$ny][$nx];
    next if $depth < 0;
    if ($depth >= $sp->{mind} && $depth <= $sp->{maxd}) {
      $f->{y} = $ny; $f->{x} = $nx; $f->{depth} = $depth;
    } elsif (rand(100) < 15) {
      $f->{y} = $ny; $f->{x} = $nx; $f->{depth} = $depth;
    }
    $f->{active} = (rand(100) < 50 * $g->{weather}{bite_mod}) ? 1 : 0;
  }
}

# ============================================================================
# TACKLE BOX
# ============================================================================

sub _bc_tackle_box {
  my ($g) = @_;
  door_clear();
  writeline($config{'themecolor'} . " Tackle Box" . $RST, 1);
  door_hrule(55);
  writeline("", 1);

  my @owned;
  my $idx = 1;
  for my $ti (0 .. $#LURE_TYPES) {
    for my $si (0 .. $#LURE_SIZES) {
      my $name = "$LURE_SIZES[$si]{name} $LURE_TYPES[$ti]{type}";
      next unless $g->{lures_owned}{$name};
      my $lt = $LURE_TYPES[$ti];
      my $di;
      if ($lt->{behavior} eq 'top') { $di = "Surface"; }
      elsif ($lt->{behavior} eq 'dive') {
        $di = sprintf("S:%d M:%d F:%dft", $lt->{depths}[1], $lt->{depths}[2], $lt->{depths}[3]);
      } else {
        $di = sprintf("S:%d M:%d F:%dft", $lt->{depths}[0], $lt->{depths}[1], $lt->{depths}[2]);
      }
      my $cur = ($ti == $g->{lure_type} && $si == $g->{lure_size}) ? " <--" : "";
      writeline(sprintf("  %s%2d%s %s%-20s%s %s%s%s",
        $config{'promptcolor'}, $idx, $config{'themecolor'},
        $config{'usercolor'}, $name, $config{'systemcolor'}, $di,
        $config{'errorcolor'}, $cur . $RST), 1);
      push @owned, { ti => $ti, si => $si, name => $name };
      $idx++;
    }
  }

  writeline("", 1);
  writeline($config{'systemcolor'} . " Select lure (0 cancel): " . $RST);
  my $choice = int(getline('text', 2, "", 1));
  if ($choice >= 1 && $choice <= @owned) {
    my $sel = $owned[$choice - 1];
    $g->{lure_type} = $sel->{ti}; $g->{lure_size} = $sel->{si};
    writeline($config{'usercolor'} . " Equipped: $sel->{name}" . $RST, 1);
    door_pause();
  }
}

