# ============================================================================
# ACTION LOG
# ============================================================================

sub _pw_log {
  my ($g, $msg) = @_;
  push @{$g->{action_log}}, $msg;
  # Keep last 30 entries
  if (@{$g->{action_log}} > 30) {
    splice @{$g->{action_log}}, 0, @{$g->{action_log}} - 30;
  }
}

# ============================================================================
# MAIN ENTRY POINT
# ============================================================================

sub propertywars_main {
  iamat($info{'handle'}, "Playing Property Wars");
  door_broker_connect($DOOR_NAME, "door-$DOOR_NAME-lobby");

  # Init color codes (must happen after config is loaded)
  # Match classic board game colors using raw ANSI codes
  @COLOR_CODES = (
    $MAG,  # Purple (Mediterranean, Baltic) - dark magenta/brown
    $BCN,  # Lt Blue (Oriental, Vermont, Connecticut)
    $BMG,  # Violet/Pink (St. Charles, States, Virginia)
    $YLW,  # Orange (St. James, Tennessee, New York)
    $BRD,  # Red (Kentucky, Indiana, Illinois)
    $BYL,  # Yellow (Atlantic, Ventnor, Marvin Gardens)
    $BGN,  # Green (Pacific, N. Carolina, Pennsylvania)
    $BBL,  # Dark Blue (Park Place, Boardwalk)
  );

  my $playing = 1;
  while ($playing) {
    door_clear();
    writeline("", 1);
    writeline($config{'themecolor'} . "         P R O P E R T Y   W A R S" . $RST, 1);
    writeline($config{'linecolor'}  . "       -----------------------------------" . $RST, 1);
    writeline($config{'systemcolor'} . "     Roll dice, buy property, bankrupt your rivals!" . $RST, 1);
    writeline("", 1);

    door_show_messages($DOOR_NAME);

    # Show incoming lobby chat
    my @chat = door_chat_poll($DOOR_NAME);
    for my $m (@chat) {
      writeline($config{'linecolor'} . "  " . $m . $RST, 1);
    }

    my @online = door_get_online_players($DOOR_NAME);
    if (@online) {
      my $others = join(", ", map { $config{'usercolor'} . $_ . $RST } @online);
      writeline($config{'datacolor'} . "  Also here: " . $others, 1);
      writeline("", 1);
    }

    # Check for sessions to join
    my $sessions = door_session_list($DOOR_NAME);
    if ($sessions && @$sessions) {
      writeline($config{'themecolor'} . "  Open games:" . $RST, 1);
      for my $s (@$sessions) {
        my $pcount = scalar @{$s->{players} // []};
        writeline("  " . $config{'datacolor'} . "  $s->{host}'s game ($pcount/$s->{data}{max_players} players)" . $RST, 1);
      }
      writeline("", 1);
    }

    my $choice = door_menu([
      ['N', 'New Game (solo + AI)'],
      ['M', 'Multiplayer Game'],
      ['J', 'Join Game'],
      ['S', 'High Scores'],
      ['C', 'Lobby Chat'],
      ['Q', 'Quit'],
    ], "What'll it be");

    if ($choice eq 'N') {
      _pw_new_game(0);
    } elsif ($choice eq 'M') {
      _pw_new_game(1);
    } elsif ($choice eq 'J') {
      _pw_join_game();
    } elsif ($choice eq 'S') {
      door_show_scores($DOOR_NAME, "Property Wars Moguls", "Net Worth");
      door_pause();
    } elsif ($choice eq 'C') {
      door_chat_input($DOOR_NAME);
    } elsif ($choice eq 'Q') {
      $playing = 0;
    }
  }

  door_broker_disconnect();
  iamat($info{'handle'}, "Left Property Wars");
}

