sub _bc_money { return sprintf("\$%.2f", $_[0]); }

sub _bc_current_lure_name {
  my ($g) = @_;
  return "$LURE_SIZES[$g->{lure_size}]{name} $LURE_TYPES[$g->{lure_type}]{type}";
}

