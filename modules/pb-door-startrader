sub _st_land_planet {
  my ($u, $p) = @_;
  my $sector = $u->{sectors}[$p->{sector}];
  unless ($sector->{planet}) {
    writeline($config{'errorcolor'} . " No planet in this sector." . $RST, 1);
    door_pause();
    return;
  }

  my $pl = $sector->{planet};
  writeline("", 1);
  writeline($config{'themecolor'} . " Landing on " . $pl->{name} . $RST, 1);
  door_hrule(30);
  writeline($config{'systemcolor'} . " Owner: " . $config{'datacolor'} . ($pl->{owner} || "Unclaimed") . $RST, 1);
  writeline($config{'systemcolor'} . " Ore: " . $config{'datacolor'} . $pl->{ore} .
    $config{'systemcolor'} . "  Organics: " . $config{'datacolor'} . $pl->{organics} .
    $config{'systemcolor'} . "  Equipment: " . $config{'datacolor'} . $pl->{equipment} . $RST, 1);
  writeline($config{'systemcolor'} . " Colonists: " . $config{'datacolor'} . $pl->{colonists} .
    $config{'systemcolor'} . "  Fighters: " . $config{'datacolor'} . $pl->{fighters} . $RST, 1);

  if ($pl->{owner} eq "" || $pl->{owner} eq $p->{name}) {
    if ($pl->{owner} eq "") {
      if (door_yesno("Claim this planet?")) {
        $pl->{owner} = $p->{name};
        writeline($config{'usercolor'} . " Planet claimed!" . $RST, 1);
        $p->{experience} += 50;
      }
    }

    if ($pl->{owner} eq $p->{name}) {
      # Transfer resources
      my @opts = (['D', 'Deposit cargo'], ['W', 'Withdraw resources'], ['Q', 'Leave']);
      my $choice = door_menu(\@opts, "Planet");
      if ($choice eq 'D') {
        for my $i (0 .. 2) {
          if ($p->{cargo}[$i] > 0) {
            my $amt = door_getamount("Deposit how much $COMMODITIES[$i]{name}:", $p->{cargo}[$i]);
            if ($amt > 0) {
              $p->{cargo}[$i] -= $amt;
              if ($i == 0) { $pl->{ore} += $amt; }
              elsif ($i == 1) { $pl->{organics} += $amt; }
              else { $pl->{equipment} += $amt; }
            }
          }
        }
      } elsif ($choice eq 'W') {
        my $free = _st_free_holds($p);
        for my $i (0 .. 2) {
          my $avail = ($i == 0) ? $pl->{ore} : ($i == 1) ? $pl->{organics} : $pl->{equipment};
          if ($avail > 0 && $free > 0) {
            my $max = $avail < $free ? $avail : $free;
            my $amt = door_getamount("Take how much $COMMODITIES[$i]{name} (avail: $avail):", $max);
            if ($amt > 0) {
              $p->{cargo}[$i] += $amt;
              $free -= $amt;
              if ($i == 0) { $pl->{ore} -= $amt; }
              elsif ($i == 1) { $pl->{organics} -= $amt; }
              else { $pl->{equipment} -= $amt; }
            }
          }
        }
      }
    }
  } else {
    writeline($config{'errorcolor'} . " This planet belongs to " . $pl->{owner} . "." . $RST, 1);
  }
  door_pause();
}

