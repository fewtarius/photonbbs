#!/usr/bin/perl
#
# PhotonBBS Door Editor
# Operator tool for managing all native door games
#
# Provides CRUD operations on:
#   - Per-user game saves (Storable .dat)
#   - Shared game data (scores, economies, leaderboards)
#   - Bulk operations (reset, backup, restore)
#

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../modules";
use Storable qw(store retrieve lock_store lock_retrieve dclone);
use Fcntl qw(:flock);
use File::Copy;
use POSIX qw(strftime);

# --- Load config and framework ---
our %config;
our %info;
our %theme;
our ($CLR, $RST, $BLD);

require "$FindBin::Bin/../modules/pb-defaults";
require "$config{'home'}/modules/pb-framework";

chomp(my $os = `uname`);
$| = 1;
$info{'ext'} = "ans";
applytheme($config{'deftheme'});
colorize();

my $datadir = "$config{'home'}$config{'data'}";
my $doordir = "$datadir/doors";

# ============================================================================
# GAME REGISTRY
