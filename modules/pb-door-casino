# ============================================================================
# MAIN ENTRY POINT
# ============================================================================

my $DOOR_NAME = "casino";

sub casino_main {
  iamat($info{'handle'}, "At the Casino");

  door_broker_connect($DOOR_NAME, "door-$DOOR_NAME-floor");
  door_show_messages($DOOR_NAME);

  # Load/init player casino balance
  my $balance = door_get_credits();
  if ($balance <= 0) {
    # Give new players a starting stake
    door_add_credits(1000);
    $balance = 1000;
  }

  my $playing = 1;
  while ($playing) {
    $balance = door_get_credits();
    door_clear();
    writeline("", 1);
    writeline($config{'themecolor'} . "              T H E   C A S I N O" . $RST, 1);
    writeline($config{'linecolor'}  . "          --------------------------------" . $RST, 1);
    writeline("", 1);
    writeline($config{'systemcolor'} . "  Your balance: " . $config{'usercolor'} . door_money($balance) . $RST, 1);
    writeline("", 1);

    # Show who else is at the casino and jackpot size
    my @online = door_get_online_players($DOOR_NAME);
    my $pool = door_load_shared($DOOR_NAME, "jackpot.dat") // { amount => 500 };
    if (@online) {
      my $others = join(", ", map { $config{'usercolor'} . $_ . $RST } @online);
      writeline($config{'datacolor'} . "  Also playing: " . $others, 1);
    }
    writeline($config{'datacolor'} . "  Jackpot pool: " . $config{'themecolor'} . door_money($pool->{amount}) . $RST, 1);
    writeline("", 1);

    # Show any incoming floor chat
    my @chat = door_chat_poll($DOOR_NAME);
    for my $m (@chat) {
      writeline($config{'linecolor'} . $m . $RST, 1);
    }

    # Show recent casino activity
    _casino_show_news();

    my $choice = door_menu([
      ['B', 'Blackjack'],
      ['R', 'Roulette'],
      ['S', 'Slot Machine'],
      ['P', 'Video Poker'],
      ['J', 'Jackpot Pool'],
      ['C', 'Casino Floor Chat'],
      ['H', 'High Scores'],
      ['Q', 'Leave Casino'],
    ], "What'll it be");

    if ($choice eq 'B') {
      _casino_blackjack();
    } elsif ($choice eq 'R') {
      _casino_roulette();
    } elsif ($choice eq 'S') {
      _casino_slots();
    } elsif ($choice eq 'P') {
      _casino_video_poker();
    } elsif ($choice eq 'J') {
      _casino_jackpot();
    } elsif ($choice eq 'C') {
      door_chat_input($DOOR_NAME);
    } elsif ($choice eq 'H') {
      door_show_scores($DOOR_NAME, "Casino High Rollers", "Winnings");
      door_pause();
    } elsif ($choice eq 'Q') {
      $playing = 0;
    }
  }

  door_broker_disconnect();
  iamat($info{'handle'}, "Left the Casino");
}

# Show recent casino activity (last 5 broadcasts)
sub _casino_show_news {
  my $news = door_load_shared($DOOR_NAME, "news.dat") // { items => [] };
  my @items = @{$news->{items}};
  return unless @items;
  writeline($config{'linecolor'} . "  -- Casino Floor News --" . $RST, 1);
  for my $item (reverse @items[-5..-1]) {
    next unless defined $item;
    writeline($config{'datacolor'} . "  " . $item . $RST, 1);
  }
  writeline("", 1);
}

# Post a news item to the casino floor
sub _casino_post_news {
  my ($msg) = @_;
  my $news = door_load_shared($DOOR_NAME, "news.dat") // { items => [] };
  push @{$news->{items}}, $msg;
  # Keep last 20
  if (scalar @{$news->{items}} > 20) {
    splice @{$news->{items}}, 0, scalar(@{$news->{items}}) - 20;
  }
  door_save_shared($DOOR_NAME, "news.dat", $news);
}

# ============================================================================
# BLACKJACK
# ============================================================================

sub _casino_blackjack {
  my $balance = door_get_credits();

  door_clear();
  writeline($config{'themecolor'} . " Blackjack" . $RST, 1);
  door_hrule(50);
  writeline($config{'systemcolor'} . " Balance: " . $config{'usercolor'} . door_money($balance) . $RST, 1);
  writeline("", 1);

  if ($balance <= 0) {
    writeline($config{'errorcolor'} . " You're broke! Come back when you have credits." . $RST, 1);
    door_pause();
    return;
  }

  my $max_bet = $balance > 10000 ? 10000 : $balance;
  my $bet = door_getamount("Place your bet (max " . door_money($max_bet) . "):", $max_bet);
  return if $bet <= 0;

  door_sub_credits($bet);
  # Refresh screen - remove bet prompt, show clean game state
  door_clear();
  writeline($config{'themecolor'} . " Blackjack" . $RST, 1);
  door_hrule(50);
  writeline($config{'systemcolor'} . " Balance: " . $config{'usercolor'} . door_money(door_get_credits()) .
    $config{'systemcolor'} . "   Bet: " . $config{'usercolor'} . door_money($bet) . $RST, 1);
  writeline("", 1);

  my $deck = _casino_new_deck();
  my @player = (_casino_deal($deck), _casino_deal($deck));
  my @dealer = (_casino_deal($deck), _casino_deal($deck));

  my $playing = 1;
  my $doubled = 0;

  while ($playing) {
    my $pval = _bj_hand_value(@player);
    my $dval = _bj_hand_value($dealer[0]);

    door_clear();
    writeline($config{'themecolor'} . " Blackjack" . $RST, 1);
    door_hrule(50);
    writeline($config{'systemcolor'} . " Balance: " . $config{'usercolor'} . door_money(door_get_credits()) .
      $config{'systemcolor'} . "   Bet: " . $config{'usercolor'} . door_money($bet) . $RST, 1);
    writeline("", 1);
    door_draw_cards([_casino_card_code($dealer[0]), '?'], $config{'linecolor'}, "Dealer:");
    writeline("", 1);
    door_draw_cards([map { _casino_card_code($_) } @player], $config{'linecolor'}, "You: (" . $pval . ")");
    writeline("", 1);

    # Natural blackjack
    if ($pval == 21 && @player == 2) {
      writeline($config{'usercolor'} . " Blackjack!" . $RST, 1);
      $playing = 0;
      last;
    }

    if ($pval > 21) {
      writeline($config{'errorcolor'} . " Bust!" . $RST, 1);
      $playing = 0;
      last;
    }

    my @opts = (['H', 'Hit'], ['S', 'Stand']);
    if (@player == 2 && !$doubled && door_get_credits() >= $bet) {
      push @opts, ['D', 'Double Down'];
    }

    my $action = door_menu(\@opts, "Action");

    if ($action eq 'H') {
      push @player, _casino_deal($deck);
    } elsif ($action eq 'D') {
      door_sub_credits($bet);
      $bet *= 2;
      $doubled = 1;
      push @player, _casino_deal($deck);
      $playing = 0;  # Must stand after double
    } else {
      $playing = 0;
    }
  }

  my $pval = _bj_hand_value(@player);

  # Dealer plays
  writeline("", 1);
  door_draw_cards([map { _casino_card_code($_) } @dealer], $config{'linecolor'}, "Dealer reveals:");
  writeline("", 1);

  if ($pval <= 21) {
    my $dval = _bj_hand_value(@dealer);
    while ($dval < 17) {
      push @dealer, _casino_deal($deck);
      $dval = _bj_hand_value(@dealer);
      door_draw_cards([map { _casino_card_code($_) } @dealer], $config{'linecolor'}, "Dealer draws ($dval):");
      writeline("", 1);
    }
  }

  my $dval = _bj_hand_value(@dealer);
  writeline("", 1);
  writeline($config{'systemcolor'} . " Your hand: " . $config{'datacolor'} . $pval .
    $config{'systemcolor'} . "   Dealer: " . $config{'datacolor'} . $dval . $RST, 1);

  # Determine winner
  my $winnings = 0;
  if ($pval > 21) {
    writeline($config{'errorcolor'} . " You bust. Dealer wins." . $RST, 1);
  } elsif ($dval > 21) {
    $winnings = $bet * 2;
    writeline($config{'usercolor'} . " Dealer busts! You win " . door_money($winnings) . "!" . $RST, 1);
  } elsif ($pval == 21 && @player == 2 && !($dval == 21 && @dealer == 2)) {
    # Blackjack pays 3:2
    $winnings = int($bet * 2.5);
    writeline($config{'usercolor'} . " Blackjack pays 3:2! You win " . door_money($winnings) . "!" . $RST, 1);
  } elsif ($pval > $dval) {
    $winnings = $bet * 2;
    writeline($config{'usercolor'} . " You win " . door_money($winnings) . "!" . $RST, 1);
  } elsif ($pval == $dval) {
    $winnings = $bet;  # Push - return bet
    writeline($config{'systemcolor'} . " Push. Bet returned." . $RST, 1);
  } else {
    writeline($config{'errorcolor'} . " Dealer wins." . $RST, 1);
  }

  if ($winnings > 0) {
    door_add_credits($winnings);
    my $profit = $winnings - $bet;
    if ($profit > 0) {
      door_submit_score($DOOR_NAME, $profit, { game => "Blackjack" });
      if ($profit >= 500) {
        my $msg = "$info{'handle'} won " . door_money($profit) . " at Blackjack!";
        _casino_post_news($msg);
        door_broadcast($DOOR_NAME, $msg) if $profit >= 2000;
      }
    }
  }

  door_pause();
}

