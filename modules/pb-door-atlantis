sub _atl_map {
  my ($p) = @_;

  door_header("Depth Chart");
  my $d = $p->{depth} - 1;

  writeline($config{'systemcolor'} . " Depth Level $p->{depth} (explored areas shown)" . $RST, 1);
  writeline("", 1);

  # Column header
  my $hdr = "    ";
  for my $x (0 .. $MAP_SIZE - 1) { $hdr .= sprintf("%X", $x); }
  writeline($config{'linecolor'} . $hdr . $RST, 1);

  for my $y (0 .. $MAP_SIZE - 1) {
    my $line = sprintf(" %s%X%s  ", $config{'linecolor'}, $y, $RST);
    for my $x (0 .. $MAP_SIZE - 1) {
      my $key = "$d:$x:$y";
      if ($x == $p->{x} && $y == $p->{y} && $d == $p->{depth} - 1) {
        $line .= $config{'usercolor'} . "@" . $RST;
      }
      elsif ($p->{explored}{$key}) {
        my $t = $p->{map}[$d][$y][$x];
        $line .= $config{$TERRAIN{$t}{color}} . $t . $RST;
      }
      else {
        $line .= $config{'linecolor'} . "." . $RST;
      }
    }
    writeline($line, 1);
  }

  writeline("", 1);
  writeline($config{'systemcolor'} . " Legend: " .
    $config{'systemcolor'} . "~ Water  " .
    $config{'errorcolor'} . "# Reef  " .
    $config{'datacolor'} . "R Ruins  " .
    $config{'linecolor'} . "C Cave  " .
    $config{'usercolor'} . "T Treasure  " .
    $config{'themecolor'} . "K Kelp  " .
    $config{'errorcolor'} . "V Vent  " .
    $config{'promptcolor'} . "A Gate" . $RST, 1);
  writeline("", 1);
  door_pause();
}

