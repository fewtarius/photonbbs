# ============================================================================
# MULTIPLAYER - Rob Another Dealer
# ============================================================================

sub _dl_rob_player {
  my ($g) = @_;

  # Need at least 1 gun to rob someone
  if (!@{$g->{guns}}) {
    writeline($config{'errorcolor'} . "  You need a gun to rob someone." . $RST, 1);
    door_pause();
    return;
  }

  # Get list of other players - mark who's online
  my @all = door_get_all_players($DOOR_NAME);
  @all = grep { $_ ne $info{'handle'} } @all;
  my @online = door_get_online_players($DOOR_NAME);
  my %online_map = map { lc($_) => 1 } @online;

  unless (@all) {
    writeline($config{'errorcolor'} . "  No other dealers to rob." . $RST, 1);
    door_pause();
    return;
  }

  door_clear();
  writeline($config{'themecolor'} . "  ROB A DEALER" . $RST, 1);
  door_hrule(30);
  writeline("", 1);
  writeline($config{'systemcolor'} . "  Known dealers on the street:" . $RST, 1);
  my $i = 1;
  for my $p (@all) {
    my $status = $online_map{lc($p)} ? $config{'usercolor'} . " [ONLINE]" : "";
    writeline($config{'datacolor'} . "  $i. " . $config{'usercolor'} . $p . $status . $RST, 1);
    $i++;
  }
  writeline("", 1);

  my $num = door_getnum("Rob which dealer (0=cancel):", scalar @all);
  return if $num == 0;

  my $target = $all[$num - 1];

  # If target is online, offer live confrontation
  if ($online_map{lc($target)}) {
    writeline("", 1);
    writeline($config{'errorcolor'} . "  $target is on the street right now!" . $RST, 1);
    if (door_yesno("  Confront them face to face?")) {
      _dl_live_confrontation($g, $target);
      return;
    }
    writeline($config{'systemcolor'} . "  Going for the sneak attack instead..." . $RST, 1);
  }

  writeline("", 1);
  writeline($config{'systemcolor'} . "  Attempting to rob " . $config{'usercolor'} . $target . $config{'systemcolor'} . "..." . $RST, 1);
  door_pause("Press any key to try...");

  # Rob chance: guns help attacker
  my $attacker_power = scalar(@{$g->{guns}}) * 20 + 30 + int(rand(20));
  my $defender_power = 40 + int(rand(30));  # Unknown opponent, moderate defense
  my $success_chance = int($attacker_power / ($attacker_power + $defender_power) * 100);

  if (rand(100) < $success_chance) {
    # Success - steal from a bounty pool (symbolic since DL doesn't persist mid-game)
    my $stolen = 500 + int(rand(2500));

    $g->{cash} += $stolen;
    writeline($config{'usercolor'} . "  Score! You grabbed " . door_money($stolen) . " from $target!" . $RST, 1);

    # Notify the victim
    door_send_message($DOOR_NAME, $target,
      "$info{'handle'} hit you on the street and grabbed " . door_money($stolen) . ". Get them back!");

    # Post to street news
    _dl_post_news("$info{'handle'} robbed $target for " . door_money($stolen) . ".");
    door_broadcast($DOOR_NAME, "$info{'handle'} hit $target on the street!")
      if $stolen > 1500;

    # Risky business - small health cost
    my $health_loss = 5 + int(rand(10));
    $g->{health} -= $health_loss;
    writeline($config{'systemcolor'} . "  (Lost $health_loss health in the scuffle)" . $RST, 1);
  } else {
    # Failed - lose health and possibly cash
    my $health_loss = 10 + int(rand(25));
    $g->{health} -= $health_loss;
    writeline($config{'errorcolor'} . "  They fought back! You lost $health_loss health." . $RST, 1);

    if (rand(100) < 40) {
      my $lost = int($g->{cash} * (0.05 + rand(0.15)));
      if ($lost > 0 && $lost <= $g->{cash}) {
        $g->{cash} -= $lost;
        writeline($config{'errorcolor'} . "  They grabbed " . door_money($lost) . " off you!" . $RST, 1);
        door_send_message($DOOR_NAME, $target,
          "$info{'handle'} tried to rob you but failed - you took " . door_money($lost) . " from them!");
        _dl_post_news("$info{'handle'} tried to rob $target and got stomped.");
      } else {
        _dl_post_news("$info{'handle'} tried to rob $target and failed.");
      }
    } else {
      _dl_post_news("$info{'handle'} tried to rob $target and failed.");
    }
  }

  $g->{health} = 0 if $g->{health} < 0;
  door_pause();
}

# Live confrontation - face-to-face robbery with choices
sub _dl_live_confrontation {
  my ($g, $target) = @_;

  iamat($info{'handle'}, "Confronting $target");

  my $session = door_session_create($DOOR_NAME, {
    max_players => 2,
    game_state  => {
      attacker => $info{'handle'},
      target   => $target,
      type     => 'confrontation',
    },
  });

  door_send_message($DOOR_NAME, $target,
    "$info{'handle'} is confronting you on the street! Watch your back!");

  my $guns = scalar @{$g->{guns}};
  my $att_power = $guns * 25 + 30;

  door_clear();
  writeline($config{'errorcolor'} . "  STREET CONFRONTATION" . $RST, 1);
  door_hrule(35);
  writeline($config{'systemcolor'} . "  You step up to " .
    $config{'usercolor'} . $target . $config{'systemcolor'} . "..." . $RST, 1);
  writeline("", 1);

  my $round = 0;
  my $total_stolen = 0;
  my $total_lost_health = 0;

  while ($round < 3 && $g->{health} > 0) {
    $round++;
    writeline($config{'themecolor'} . "  Round $round" . $RST, 1);
    writeline("", 1);

    my $choice = door_menu([
      ['G', 'Grab their cash'],
      ['S', 'Steal their stash'],
      ['I', 'Intimidate (demand tribute)'],
      ['R', 'Run away'],
    ], "Action");

    if ($choice eq 'R') {
      writeline($config{'systemcolor'} . "  You back off and disappear into the crowd." . $RST, 1);
      last;
    }

    # Each action has a success/fail with consequences
    my $roll = int(rand(100));
    my $threshold = $att_power + int(rand(20));

    if ($choice eq 'G') {
      if ($roll < $threshold) {
        my $grabbed = 500 + int(rand(3000 + $g->{turn} * 100));
        $g->{cash} += $grabbed;
        $total_stolen += $grabbed;
        writeline($config{'usercolor'} . "  Snatched " . door_money($grabbed) . "!" . $RST, 1);
      } else {
        my $dmg = 10 + int(rand(20));
        $g->{health} -= $dmg;
        $total_lost_health += $dmg;
        writeline($config{'errorcolor'} . "  They fought back! -$dmg health" . $RST, 1);
      }
    } elsif ($choice eq 'S') {
      if ($roll < $threshold - 10) {
        # Steal a random drug
        my $drug_idx = int(rand(scalar @DRUGS));
        my $amount = 1 + int(rand(5));
        my $space = 100 - _dl_total_drugs($g);
        $amount = $space if $amount > $space;
        if ($amount > 0) {
          $g->{trenchcoat}[$drug_idx] += $amount;
          writeline($config{'usercolor'} . "  Grabbed $amount " . $DRUGS[$drug_idx]{name} . "!" . $RST, 1);
        } else {
          writeline($config{'systemcolor'} . "  No room in your trenchcoat!" . $RST, 1);
        }
      } else {
        my $dmg = 15 + int(rand(25));
        $g->{health} -= $dmg;
        $total_lost_health += $dmg;
        writeline($config{'errorcolor'} . "  Caught! They stabbed you. -$dmg health" . $RST, 1);
      }
    } elsif ($choice eq 'I') {
      if ($roll < $threshold + 10) {
        my $tribute = 1000 + int(rand(5000));
        $g->{cash} += $tribute;
        $total_stolen += $tribute;
        writeline($config{'usercolor'} . "  They handed over " . door_money($tribute) . " in tribute!" . $RST, 1);
        last;  # Intimidation ends the confrontation
      } else {
        writeline($config{'errorcolor'} . "  They laughed at you and pulled a knife!" . $RST, 1);
        my $dmg = 20 + int(rand(30));
        $g->{health} -= $dmg;
        $total_lost_health += $dmg;
        writeline($config{'errorcolor'} . "  -$dmg health" . $RST, 1);
      }
    }
    writeline("", 1);
  }

  $g->{health} = 0 if $g->{health} < 0;

  writeline("", 1);
  if ($total_stolen > 0) {
    writeline($config{'usercolor'} . "  Total take: " . door_money($total_stolen) . $RST, 1);
    door_send_message($DOOR_NAME, $target,
      "$info{'handle'} robbed you face to face for " . door_money($total_stolen) . "!");
    _dl_post_news("$info{'handle'} confronted $target and took " . door_money($total_stolen) . ".");
    door_broadcast($DOOR_NAME, "$info{'handle'} confronted $target on the street!")
      if $total_stolen > 3000;
  }
  if ($total_lost_health > 0) {
    writeline($config{'errorcolor'} . "  Health lost: $total_lost_health" . $RST, 1);
  }

  door_session_destroy($DOOR_NAME, $session->{id}) if $session;
  door_pause();
}

sub _dl_game_over {
  my ($g) = @_;

  # Sell all remaining drugs at average price
  my $drug_value = 0;
  for my $i (0 .. $#DRUGS) {
    if ($g->{drugs}[$i]{carried} > 0) {
      my $avg = int(($DRUGS[$i]{min} + $DRUGS[$i]{max}) / 2);
      $drug_value += $g->{drugs}[$i]{carried} * $avg;
    }
  }

  # Calculate net worth
  my $net = $g->{cash} + $g->{bank} + $drug_value - $g->{debt};

  door_clear();
  writeline("", 1);
  writeline($config{'themecolor'} . "                  G A M E   O V E R" . $RST, 1);
  writeline($config{'linecolor'}  . "          --------------------------------" . $RST, 1);
  writeline("", 1);

  if ($g->{health} <= 0) {
    writeline($config{'errorcolor'} . "  You were killed on the streets of New York." . $RST, 1);
  } else {
    writeline($config{'systemcolor'} . "  Your 31 days are up." . $RST, 1);
  }

  writeline("", 1);
  writeline($config{'systemcolor'} . "  Cash on hand:  " . $config{'datacolor'} . door_money($g->{cash}) . $RST, 1);
  writeline($config{'systemcolor'} . "  Bank savings:  " . $config{'datacolor'} . door_money($g->{bank}) . $RST, 1);
  writeline($config{'systemcolor'} . "  Drug value:    " . $config{'datacolor'} . door_money($drug_value) . $RST, 1);
  writeline($config{'systemcolor'} . "  Debt:         " . $config{'errorcolor'} . "-" . door_money($g->{debt}) . $RST, 1);
  door_hrule(30);
  writeline($config{'systemcolor'} . "  Net Worth:     " .
    ($net >= 0 ? $config{'usercolor'} : $config{'errorcolor'}) . door_money($net) . $RST, 1);
  writeline("", 1);

  # Submit high score
  my $scores = door_submit_score($DOOR_NAME, $net, { days => $g->{turn} - 1 });

  # Find player's rank
  my $rank = 0;
  for my $i (0 .. $#$scores) {
    if ($scores->[$i]{handle} eq $info{'handle'} && $scores->[$i]{score} == $net) {
      $rank = $i + 1;
      last;
    }
  }
  if ($rank > 0) {
    writeline($config{'usercolor'} . "  You ranked #$rank on the high score board!" . $RST, 1);
  }

  # Update shared economy - check for new kingpin
  my $econ = $g->{economy} // {};
  if ($net > ($econ->{kingpin_score} // 0)) {
    my $old_kingpin = $econ->{kingpin} // "";
    $econ->{kingpin} = $info{'handle'};
    $econ->{kingpin_score} = $net;
    _dl_save_economy($g);
    writeline("", 1);
    writeline($config{'usercolor'} . "  * You are the new KINGPIN! *" . $RST, 1);
    my $bc;
    if ($old_kingpin && $old_kingpin ne $info{'handle'}) {
      $bc = "$info{'handle'} has dethroned $old_kingpin as the Kingpin of Drug Lord!";
      door_broadcast($DOOR_NAME, $bc);
      door_send_message($DOOR_NAME, $old_kingpin, "$info{'handle'} has taken your Kingpin title with " . door_money($net) . " net worth!");
    } else {
      $bc = "$info{'handle'} is the Kingpin of Drug Lord with " . door_money($net) . " net worth!";
      door_broadcast($DOOR_NAME, $bc);
    }
    _dl_post_news($bc);
  }

  # Log to activity feed
  door_log_activity($DOOR_NAME, $info{'handle'} . " finished DrugLord with " . door_money($net) . " net worth");

  writeline("", 1);
  if (door_yesno("View high scores?")) {
    door_show_scores($DOOR_NAME, "DrugLord High Scores", "Net Worth");
  }

  door_pause("Press any key to return to the BBS...");
}

1;
