              " ... " . $config{'usercolor'} . "Attack (drones or players)", 1);
    writeline("  " . $config{'promptcolor'} . "P" . $config{'themecolor'} .
              " ... " . $config{'usercolor'} . "Port (dock at trading base)", 1);
    writeline("  " . $config{'promptcolor'} . "L" . $config{'themecolor'} .
              " ... " . $config{'usercolor'} . "Land (colonize/use planet)", 1);
    writeline("  " . $config{'promptcolor'} . "F" . $config{'themecolor'} .
              " ... " . $config{'usercolor'} . "Fold (hyperspace jump)", 1);
    writeline("  " . $config{'promptcolor'} . "S" . $config{'themecolor'} .
              " ... " . $config{'usercolor'} . "Scan (long range scanner)", 1);
    writeline("  " . $config{'promptcolor'} . "G" . $config{'themecolor'} .
              " ... " . $config{'usercolor'} . "Guild (create/manage guild)", 1);
    writeline("  " . $config{'promptcolor'} . "I" . $config{'themecolor'} .
              " ... " . $config{'usercolor'} . "Info (player statistics)", 1);
    writeline("  " . $config{'promptcolor'} . "N" . $config{'themecolor'} .
              " ... " . $config{'usercolor'} . "miNes (deploy sector mines)", 1);
    writeline("  " . $config{'promptcolor'} . "B" . $config{'themecolor'} .
