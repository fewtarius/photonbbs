# ============================================================================
# DEPTH RECORDS - Competitive multiplayer tracking
# ============================================================================

sub _atl_depth_records {
  door_header("Depth Records - All Divers");

  my @all = door_get_all_players($DOOR_NAME);
  my @records;

  for my $name (@all) {
    my $pd = door_load_player($DOOR_NAME, $name);
    next unless $pd;
    push @records, {
      name      => $name,
      depth     => $pd->{max_depth} // 1,
      artifacts => $pd->{artifacts_found} // 0,
      kills     => $pd->{creatures_killed} // 0,
      atlantis  => $pd->{atlantis_found} // 0,
    };
  }

  @records = sort { $b->{depth} <=> $a->{depth} || $b->{artifacts} <=> $a->{artifacts} } @records;

  writeline(sprintf("  %s%-3s %-18s %-6s %-10s %-6s %-8s%s",
    $config{'systemcolor'}, "#", "Diver", "Depth", "Artifacts", "Kills", "Atlantis", $RST), 1);
  writeline($config{'linecolor'} . " " . ("-" x 56) . $RST, 1);

  my $rank = 1;
  for my $r (@records) {
    my $color = ($r->{name} eq $info{'handle'}) ? $config{'usercolor'} : $config{'datacolor'};
    writeline(sprintf("  %s%-3d %s%-18s %s%-6d %-10d %-6d %s%s",
      $config{'systemcolor'}, $rank,
      $color, substr($r->{name}, 0, 18),
      $config{'datacolor'}, $r->{depth}, $r->{artifacts}, $r->{kills},
      ($r->{atlantis} ? $config{'usercolor'} . "Found!" : $config{'linecolor'} . "No"),
      $RST), 1);
    $rank++;
    last if $rank > 15;
  }
  writeline("", 1);
  door_pause();
}

# ============================================================================
