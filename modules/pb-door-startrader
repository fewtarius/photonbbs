  writeline($config{'systemcolor'} . " Galaxy: " . $config{'datacolor'} . "$NUM_SECTORS sectors, $NUM_PORTS ports, $NUM_PLANETS planets" . $RST, 1);
}

# ============================================================================
# MULTIPLAYER - Galactic News Feed
# ============================================================================

sub _st_galactic_news {
  my ($u, $p) = @_;
  door_clear();
  writeline($config{'themecolor'} . " Galactic News Network" . $RST, 1);
  door_hrule(40);
  writeline("", 1);

  my $news = door_load_shared($DOOR_NAME, "news.dat") // { items => [] };
  my @items = @{$news->{items}};

  if (@items) {
    for my $item (reverse @items[-15..-1]) {
      next unless defined $item;
      writeline($config{'datacolor'} . "  " . $item . $RST, 1);
    }
  } else {
    writeline($config{'systemcolor'} . "  No recent galactic news." . $RST, 1);
  }

  # Show active players
  writeline("", 1);
  my @online = door_get_online_players($DOOR_NAME);
  if (@online) {
    writeline($config{'systemcolor'} . " Active captains: " .
      join(", ", map { $config{'usercolor'} . $_ . $RST } @online), 1);
  }
  writeline("", 1);
  door_pause();
}

# Post a news item to the galactic feed
sub _st_post_news {
  my ($msg) = @_;
  my $news = door_load_shared($DOOR_NAME, "news.dat") // { items => [] };
  push @{$news->{items}}, $msg;
  if (scalar @{$news->{items}} > 25) {
    splice @{$news->{items}}, 0, scalar(@{$news->{items}}) - 25;
  }
  door_save_shared($DOOR_NAME, "news.dat", $news);
}

# ============================================================================
# MULTIPLAYER - Player Trade Exchange
# ============================================================================

sub _st_trade_exchange {
  my ($u, $p) = @_;
  my $playing = 1;
  while ($playing) {
    door_clear();
    writeline($config{'themecolor'} . " Galactic Trade Exchange" . $RST, 1);
    door_hrule(40);
    writeline("", 1);

    # Show open offers
    my $board = door_load_shared($DOOR_NAME, "exchange.dat") // { offers => [] };
    my @offers = @{$board->{offers}};
    # Expire offers older than 24 hours
    my $now = time();
    @offers = grep { $now - $_->{posted} < 86400 } @offers;

    if (@offers) {
      writeline($config{'systemcolor'} . " Open Trade Offers:" . $RST, 1);
      my $i = 1;
      for my $offer (@offers) {
        next if $offer->{seller} eq $info{'handle'};  # Skip own offers
        my $comm = $COMMODITIES[$offer->{commodity}]{name};
        writeline($config{'datacolor'} . "  $i. " . $config{'usercolor'} . $offer->{seller} .
          $config{'systemcolor'} . " selling " . $config{'datacolor'} .
          "$offer->{amount} $comm" . $config{'systemcolor'} . " at " .
          $config{'usercolor'} . door_money($offer->{price_each}) . "/unit" . $RST, 1);
        $i++;
      }
    } else {
      writeline($config{'systemcolor'} . "  No open offers right now." . $RST, 1);
    }
    writeline("", 1);

    my $choice = door_menu([
      ['P', 'Post a sell offer'],
      ['A', 'Accept an offer'],
      ['R', 'Remove my offers'],
      ['Q', 'Leave exchange'],
    ], "Exchange");

    if ($choice eq 'P') {
      # Post a sell offer
      writeline($config{'systemcolor'} . " What do you want to sell?" . $RST, 1);
      my $ci = 0;
      for my $c (@COMMODITIES) {
        writeline($config{'datacolor'} . "  $ci. " . $config{'systemcolor'} . $c->{name} .
          " (you have " . $config{'datacolor'} . $p->{cargo}[$ci] . $RST . ")", 1);
        $ci++;
      }
      my $cnum = door_getnum("Commodity number:", scalar(@COMMODITIES) - 1);
      if ($p->{cargo}[$cnum] <= 0) {
        writeline($config{'errorcolor'} . " You have none of that to sell." . $RST, 1);
        door_pause();
        next;
      }
      my $amt = door_getnum("How many units:", $p->{cargo}[$cnum]);
      next unless $amt > 0;
      my $price = door_getnum("Price per unit:", 9999);
      next unless $price > 0;

      push @{$board->{offers}}, {
        seller    => $info{'handle'},
        commodity => $cnum,
        amount    => $amt,
        price_each => $price,
        posted    => time(),
      };
      door_save_shared($DOOR_NAME, "exchange.dat", $board);
      writeline($config{'usercolor'} . " Offer posted!" . $RST, 1);
      door_pause();

    } elsif ($choice eq 'A') {
      # Accept an offer
      my @buyable = grep { $_->{seller} ne $info{'handle'} } @offers;
      unless (@buyable) {
        writeline($config{'errorcolor'} . " No offers to accept." . $RST, 1);
        door_pause();
        next;
      }
      my $onum = door_getnum("Offer number:", scalar(@buyable));
      next unless $onum > 0 && $onum <= scalar(@buyable);
      my $offer = $buyable[$onum - 1];

      my $total = $offer->{amount} * $offer->{price_each};
      writeline($config{'systemcolor'} . " Buy $offer->{amount} " . $COMMODITIES[$offer->{commodity}]{name} .
        " from " . $config{'usercolor'} . $offer->{seller} . $config{'systemcolor'} .
        " for " . $config{'datacolor'} . door_money($total) . "?" . $RST, 1);

      # Check capacity and credits
      my $free_holds = $SHIP_CLASSES[$p->{ship_class}]{holds} - _st_cargo_used($p);
      if ($offer->{amount} > $free_holds) {
        writeline($config{'errorcolor'} . " Not enough cargo space (need $offer->{amount}, have $free_holds)." . $RST, 1);
        door_pause();
        next;
      }
      if ($p->{credits} < $total) {
        writeline($config{'errorcolor'} . " You can't afford that." . $RST, 1);
        door_pause();
        next;
      }

      if (door_yesno("Confirm purchase?")) {
        $p->{credits} -= $total;
        $p->{cargo}[$offer->{commodity}] += $offer->{amount};

        # Pay the seller via their save file
        my $seller_save = door_load($DOOR_NAME, $offer->{seller});
        if ($seller_save) {
          $seller_save->{credits} = ($seller_save->{credits} // 0) + $total;
          door_save($DOOR_NAME, $seller_save, $offer->{seller});
        }
        # Send message to seller
        door_send_message($DOOR_NAME, $offer->{seller},
          "$info{'handle'} bought $offer->{amount} " . $COMMODITIES[$offer->{commodity}]{name} .
          " from your exchange offer for " . door_money($total) . ".");

        # Remove fulfilled offer from board
        @{$board->{offers}} = grep {
          !($_->{seller} eq $offer->{seller} &&
            $_->{commodity} == $offer->{commodity} &&
            $_->{posted} == $offer->{posted})
        } @{$board->{offers}};
        door_save_shared($DOOR_NAME, "exchange.dat", $board);

        my $news_msg = "$info{'handle'} bought " . $COMMODITIES[$offer->{commodity}]{name} .
          " from " . $offer->{seller} . " on the Exchange.";
        _st_post_news($news_msg);

        writeline($config{'usercolor'} . " Purchase complete!" . $RST, 1);
        door_pause();
      }

    } elsif ($choice eq 'R') {
      # Remove own offers
      my $before = scalar @{$board->{offers}};
      @{$board->{offers}} = grep { $_->{seller} ne $info{'handle'} } @{$board->{offers}};
      my $removed = $before - scalar @{$board->{offers}};
      door_save_shared($DOOR_NAME, "exchange.dat", $board);
      writeline($config{'systemcolor'} . " Removed $removed offer(s)." . $RST, 1);
      door_pause();

    } elsif ($choice eq 'Q') {
      $playing = 0;
    }
  }
}

# ============================================================================
# MULTIPLAYER - Mine laying
# ============================================================================

sub _st_lay_mines {
  my ($u, $p) = @_;
  my $sector = $u->{sectors}[$p->{sector}];

  if ($p->{sector} == 0 || $p->{sector} == 1) {
    writeline($config{'errorcolor'} . " You cannot lay mines in Federation space!" . $RST, 1);
    door_pause();
    return;
  }

  my $mine_cost = 100;  # Credits per mine
  my $max_mines = int($p->{fighters} / 2);

  writeline("", 1);
  writeline($config{'systemcolor'} . " Lay mines (cost: $mine_cost credits each)" . $RST, 1);
  writeline($config{'systemcolor'} . " Current mines in sector: " . $config{'datacolor'} .
    ($sector->{mines} // 0) . $RST, 1);
  writeline($config{'systemcolor'} . " Your fighters available: " . $config{'datacolor'} . $p->{fighters} . $RST, 1);

  my $count = door_getnum("How many mines?", $max_mines);
  return if $count <= 0;

  my $cost = $count * $mine_cost;
  if ($p->{credits} < $cost) {
    writeline($config{'errorcolor'} . " Not enough credits!" . $RST, 1);
    door_pause();
    return;
  }

  $p->{credits} -= $cost;
  $p->{fighters} -= $count;
  $sector->{mines} = ($sector->{mines} // 0) + $count;
  $sector->{mine_owner} = $info{'handle'};
  $p->{mines_laid} += $count;
  _st_save_universe($u);
  _st_save_player($p);

  writeline($config{'usercolor'} . " Deployed $count mines in sector " . ($p->{sector} + 1) . $RST, 1);
  door_pause();
}

# ============================================================================
# MULTIPLAYER - Player scanning and PvP
# ============================================================================

sub _st_scan_players {
  my ($u, $p) = @_;

  door_header("Long Range Scanner");
  my @all_players = door_get_all_players($DOOR_NAME);

  if (@all_players <= 1) {
    writeline($config{'systemcolor'} . " No other traders detected in the galaxy." . $RST, 1);
    door_pause();
    return;
  }

  writeline(sprintf("  %s%-20s %-6s %-8s %-18s %-6s%s",
    $config{'systemcolor'}, "Trader", "Kills", "Credits", "Ship", "Align", $RST), 1);
  door_hrule(62);

  for my $name (@all_players) {
    next if lc($name) eq lc($info{'handle'});
    my $pd = door_load_player($DOOR_NAME, $name);
    next unless $pd;
    my $ship = $SHIP_CLASSES[$pd->{ship_class} // 0]{name};
    my $align = $pd->{alignment} // 0;
    my $align_str = $align >= 0 ? "+$align" : "$align";
    writeline(sprintf("  %s%-20s %s%-6d %s%-8s %s%-18s %s%-6s%s",
      $config{'usercolor'}, substr($name, 0, 20),
      $config{'datacolor'}, $pd->{kills} // 0,
      $config{'datacolor'}, door_money($pd->{credits} // 0),
      $config{'systemcolor'}, substr($ship, 0, 18),
      ($align >= 0 ? $config{'usercolor'} : $config{'errorcolor'}), $align_str,
      $RST), 1);
  }
  writeline("", 1);

  # Show messages
  door_show_messages($DOOR_NAME);
  door_pause();
}

1;
