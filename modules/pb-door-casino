my %POKER_PAYOUTS = (
  'Royal Flush'     => 250,
  'Straight Flush'  => 50,
  'Four of a Kind'  => 25,
  'Full House'      => 9,
  'Flush'           => 6,
  'Straight'        => 4,
  'Three of a Kind' => 3,
  'Two Pair'        => 2,
  'Jacks or Better' => 1,
);

sub _casino_video_poker {
  my $balance = door_get_credits();

  door_clear();
  writeline($config{'themecolor'} . " Video Poker - Jacks or Better" . $RST, 1);
  door_hrule(50);
  writeline("", 1);

  # Show payout table
  writeline($config{'systemcolor'} . " Payouts (per credit bet):" . $RST, 1);
  for my $hand (sort { $POKER_PAYOUTS{$b} <=> $POKER_PAYOUTS{$a} } keys %POKER_PAYOUTS) {
    writeline(sprintf("  %s%-20s %s%4dx%s",
      $config{'usercolor'}, $hand,
      $config{'datacolor'}, $POKER_PAYOUTS{$hand}, $RST), 1);
  }
  writeline("", 1);

  writeline($config{'systemcolor'} . " Balance: " . $config{'usercolor'} . door_money($balance) . $RST, 1);

  if ($balance <= 0) {
    writeline($config{'errorcolor'} . " You're broke!" . $RST, 1);
    door_pause();
    return;
  }

  my $max_bet = $balance > 5000 ? 5000 : $balance;
  my $bet = door_getamount("Place your bet (max " . door_money($max_bet) . "):", $max_bet);
  return if $bet <= 0;

  door_sub_credits($bet);

  my $deck = _casino_new_deck();
  my @hand;
  for (1 .. 5) {
    push @hand, _casino_deal($deck);
  }

  # Show initial hand
  writeline("", 1);
  door_draw_cards([map { _casino_card_code($_) } @hand], $config{'linecolor'}, "Your hand:");
  writeline(" " . join(" ", map { $config{'promptcolor'} . "    " . ($_ + 1) . "    " . $RST } 0 .. 4), 1);
  writeline("", 1);

  # Ask which cards to hold
  writeline($config{'systemcolor'} . " Enter card numbers to HOLD (e.g. 135), or blank to redraw all:" . $RST, 1);
  writeline($config{'promptcolor'} . " Hold: " . $RST);
  my $hold_input = getline(text, 6, "", 1);
  chomp $hold_input;

  my %hold;
  for my $ch (split //, $hold_input) {
    $hold{$ch - 1} = 1 if $ch >= 1 && $ch <= 5;
  }

  # Replace non-held cards
  for my $i (0 .. 4) {
    unless ($hold{$i}) {
      $hand[$i] = _casino_deal($deck);
    }
  }

  # Show final hand
  writeline("", 1);
  door_draw_cards([map { _casino_card_code($_) } @hand], $config{'linecolor'}, "Final hand:");
  writeline(" " . join(" ", map {
    $hold{$_} ? $config{'usercolor'} . "   HELD  " . $RST
              : $config{'linecolor'} . "         " . $RST
  } 0 .. 4), 1);
  writeline("", 1);

  # Evaluate hand
  my $result = _poker_evaluate(@hand);

  if ($result && exists $POKER_PAYOUTS{$result}) {
    my $winnings = $bet * ($POKER_PAYOUTS{$result} + 1);
    door_add_credits($winnings);
    writeline($config{'usercolor'} . " $result! You win " . door_money($winnings) . "!" . $RST, 1);
    if ($POKER_PAYOUTS{$result} >= 25) {
      door_submit_score($DOOR_NAME, $winnings, { game => "Video Poker", hand => $result });
      door_log_activity($DOOR_NAME, $info{'handle'} . " hit a $result on Video Poker for " . door_money($winnings) . "!");
    }
  } else {
    writeline($config{'errorcolor'} . " No winning hand. Better luck next time." . $RST, 1);
  }

  door_pause();
}

# Evaluate a 5-card poker hand
sub _poker_evaluate {
  my (@hand) = @_;

  # Count ranks and suits
  my %rank_count;
  my %suit_count;
  my @rank_vals;
  for my $card (@hand) {
    $rank_count{$card->[0]}++;
    $suit_count{$card->[1]}++;
    push @rank_vals, $card->[0];
  }
  @rank_vals = sort { $a <=> $b } @rank_vals;

  my $is_flush = (scalar keys %suit_count == 1);

  # Check for straight
  my $is_straight = 0;
  if (scalar keys %rank_count == 5) {
    my $diff = $rank_vals[4] - $rank_vals[0];
    if ($diff == 4) {
      $is_straight = 1;
    }
    # Ace-low straight (A,2,3,4,5)
    if ($rank_vals[0] == 0 && $rank_vals[1] == 1 && $rank_vals[2] == 2 &&
        $rank_vals[3] == 3 && $rank_vals[4] == 12) {
      $is_straight = 1;
    }
    # Ace-high straight (10,J,Q,K,A)
    if ($rank_vals[0] == 0 && $rank_vals[1] == 9 && $rank_vals[2] == 10 &&
        $rank_vals[3] == 11 && $rank_vals[4] == 12) {
      $is_straight = 1;
    }
  }

  # Royal flush
  if ($is_flush && $is_straight && $rank_vals[0] == 0 && $rank_vals[1] == 9) {
    return 'Royal Flush';
  }

  # Straight flush
  if ($is_flush && $is_straight) {
    return 'Straight Flush';
  }

  # Four of a kind
  for my $count (values %rank_count) {
    return 'Four of a Kind' if $count == 4;
  }

  # Full house
  my @counts = sort { $b <=> $a } values %rank_count;
  if ($counts[0] == 3 && $counts[1] == 2) {
    return 'Full House';
  }

  # Flush
  return 'Flush' if $is_flush;

  # Straight
  return 'Straight' if $is_straight;

  # Three of a kind
  if ($counts[0] == 3) {
    return 'Three of a Kind';
  }

  # Two pair
  my $pairs = grep { $_ == 2 } values %rank_count;
  if ($pairs == 2) {
    return 'Two Pair';
  }

  # Jacks or better (pair of J, Q, K, or A)
  if ($pairs == 1) {
    for my $rank (keys %rank_count) {
      if ($rank_count{$rank} == 2 && ($rank == 0 || $rank >= 10)) {
        return 'Jacks or Better';
      }
    }
  }

  return undef;  # No winning hand
}

