sub _st_computer {
  my ($u, $p) = @_;
  my @opts = (
    ['S', 'Sector display'],
    ['P', 'Port report (nearby)'],
    ['N', 'Nearest port finder'],
    ['Q', 'Exit computer'],
  );

  my $choice = door_menu(\@opts, "Computer");

  if ($choice eq 'S') {
    _st_sector_map($u, $p);
  } elsif ($choice eq 'P') {
    _st_port_report($u, $p);
  } elsif ($choice eq 'N') {
    _st_nearest_port($u, $p);
  }
  door_pause();
}

sub _st_sector_map {
  my ($u, $p) = @_;
  writeline("", 1);
  writeline($config{'themecolor'} . " Sector Map (nearby)" . $RST, 1);
  my $sector = $u->{sectors}[$p->{sector}];
  writeline($config{'usercolor'} . " [" . ($p->{sector}+1) . "] <-- You are here" . $RST, 1);
  for my $w (@{$sector->{warps}}) {
    my $ws = $u->{sectors}[$w];
    my $info_str = "";
    $info_str .= " (Port)" if $ws->{port};
    $info_str .= " (Planet)" if $ws->{planet};
    $info_str .= " (Fighters: $ws->{fighters})" if $ws->{fighters} > 0;
    writeline($config{'datacolor'} . "   -> [" . ($w+1) . "]$info_str" . $RST, 1);
    for my $w2 (@{$ws->{warps}}) {
      next if $w2 == $p->{sector};
      writeline($config{'systemcolor'} . "       -> [" . ($w2+1) . "]" . $RST, 1);
    }
  }
}

sub _st_port_report {
  my ($u, $p) = @_;
  writeline("", 1);
  writeline($config{'themecolor'} . " Port Report (1 hop)" . $RST, 1);
  writeline($config{'systemcolor'} . sprintf(" %-8s %-20s %s", "Sector", "Name", "Type") . $RST, 1);
  my $sector = $u->{sectors}[$p->{sector}];

  # Current sector
  if ($sector->{port}) {
    writeline($config{'usercolor'} . sprintf(" %-8d %-20s %s",
      $p->{sector}+1, $sector->{port}{name}, $sector->{port}{type}) . $RST, 1);
  }
  # Adjacent sectors
  for my $w (@{$sector->{warps}}) {
    my $ws = $u->{sectors}[$w];
    if ($ws->{port}) {
      writeline($config{'datacolor'} . sprintf(" %-8d %-20s %s",
        $w+1, $ws->{port}{name}, $ws->{port}{type}) . $RST, 1);
    }
  }
}

sub _st_nearest_port {
  my ($u, $p) = @_;
  # BFS to find nearest port
  my @queue = ($p->{sector});
  my %visited;
  $visited{$p->{sector}} = 1;
  my $found = 0;

  writeline("", 1);
  writeline($config{'themecolor'} . " Nearest Ports:" . $RST, 1);
  my $depth = 0;
  my @next_queue;

  while (@queue && $found < 5 && $depth < 5) {
    @next_queue = ();
    for my $s (@queue) {
      my $sector = $u->{sectors}[$s];
      if ($sector->{port} && $s != $p->{sector}) {
        writeline($config{'datacolor'} . "  Sector " . ($s+1) . ": " .
          $sector->{port}{name} . " [" . $sector->{port}{type} . "] (${depth} hop" .
          ($depth != 1 ? "s" : "") . ")" . $RST, 1);
        $found++;
      }
      for my $w (@{$sector->{warps}}) {
        unless ($visited{$w}) {
          $visited{$w} = 1;
          push @next_queue, $w;
        }
      }
    }
    @queue = @next_queue;
    $depth++;
  }
  writeline($config{'systemcolor'} . " No ports found nearby." . $RST, 1) unless $found;
}

