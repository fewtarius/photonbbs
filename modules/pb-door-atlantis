sub atlantis_main {
  my $p = _atl_load_player();
  _atl_daily_reset($p);
  _atl_title_screen();
  door_pause();

  my $quit = 0;
  while (!$quit) {
    _atl_main_menu($p);
    my $ch = uc(getline('text', 1, "", 1));

    if    ($ch eq 'D') { _atl_dive($p); }
    elsif ($ch eq 'M') { _atl_map($p); }
    elsif ($ch eq 'E') { _atl_equipment_shop($p); }
    elsif ($ch eq 'S') { _atl_sell_artifacts($p); }
    elsif ($ch eq 'V') { _atl_view_stats($p); }
    elsif ($ch eq 'H') { door_show_scores($DOOR_NAME, "Atlantis Explorers", "Depth", 10); door_pause(); }
    elsif ($ch eq 'R') { _atl_depth_records(); }
    elsif ($ch eq 'Q') { $quit = 1; }
  }

  door_save($DOOR_NAME, $p);
  writeline("", 1);
  writeline($config{'themecolor'} . " You surface and return to port..." . $RST, 1);
  writeline("", 1);
  door_pause();
}

