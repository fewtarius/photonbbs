# ============================================================================
# WORLD INITIALIZATION (calls sub-module loaders)
# ============================================================================

sub mw_world_init {
    mw_universe_load();
    mw_bases_load();
    mw_drones_load();
    mw_planets_load();
    mw_fortresses_load();
    mw_teams_load();
}

# ============================================================================
# MODULE LOADER
# ============================================================================

sub _mw_require_modules {
    my $home = $config{'home'} // '/opt/photonbbs';
    my @modules = qw(
        mw-universe
        mw-player
        mw-bases
        mw-drones
        mw-combat
        mw-movement
        mw-economy
        mw-planets
        mw-fortresses
        mw-teams
        mw-entities
        mw-ui
    );

    for my $mod (@modules) {
        eval { require_module($mod); };
        if ($@) {
            writeline($config{'errorcolor'} . " Failed to load $mod: $@" . $RST, 1);
        }
    }
}

1;
