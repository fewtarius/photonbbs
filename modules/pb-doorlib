# Log a door event to the activity feed (if pb-activity is loaded)
sub door_log_activity {
  my ($doorname, $message, $extra) = @_;
  eval {
    log_activity(ACTIVITY_DOOR_SCORE, $message, $info{'handle'}, {
      door => $doorname,
      %{$extra // {}},
    });
  };
  # Silently ignore if pb-activity not loaded
}

# ============================================================================
# MULTIPLAYER SUPPORT
# ============================================================================

# Alias for door_log_activity (used by some games)
sub door_post_activity {
  my ($doorname, $message) = @_;
  door_log_activity($doorname, $message);
}

# Broadcast a message to all online BBS users via page system
sub door_broadcast {
  my ($doorname, $message) = @_;
  my $formatted = "\@DATACLR[\@USERCLR$doorname\@DATACLR] \@SYSTEMCLR$message";

  # Send via global broker to all logged-in sessions
  if ($_BBS_BROKER_SOCK && defined &broker_send_room_message) {
    eval {
      broker_send_room_message($_BBS_BROKER_SOCK, "bbs-global", $formatted);
    };
  } elsif (defined &main::pageall) {
    # Last-resort: fall back to pageall
    my $saved = $info{'handle'};
    $info{'handle'} = $doorname;
    main::pageall($message);
    $info{'handle'} = $saved;
  }

  door_log_activity($doorname, $message);
}

# Get list of currently online player handles
sub door_get_online_players {
  my ($doorname) = @_;
  my @players;
  my @nodefiles = glob("$config{'home'}$config{'nodes'}/*");
  my $my_handle = $info{'handle'} // '';
  for my $nf (@nodefiles) {
    eval {
      open(my $fh, '<', $nf);
      my $line = <$fh>;
      close($fh);
      chomp $line if $line;
      if ($line && $line =~ /\S/) {
        # Node file format: ip|node|pid|timestamp|handle|proto|location
        my @fields = split(/\|/, $line);
        my $handle = $fields[4] // $line;
        # Skip system entries and the current user
        next if !$handle || $handle eq 'CONNECT' || $handle eq '*** HIDDEN ***';
        next if $handle eq $my_handle;
        push @players, $handle;
      }
    };
  }
  return @players;
}

# Get list of all players who have save data for a door
sub door_get_all_players {
  my ($doorname) = @_;
  my $dir = door_data_dir($doorname);
  my @players;
  if (opendir(my $dh, $dir)) {
    for my $f (readdir($dh)) {
      next unless $f =~ /^(.+)\.dat$/ && $f ne 'scores.dat' && $f !~ /^(universe|world|galaxy|shared)/;
      my $name = $1;
      $name =~ s/_/ /g;
      push @players, $name;
    }
    closedir($dh);
  }
  return sort @players;
}

# Load another player's save data (for PvP attacks on sleeping players)
sub door_load_player {
  my ($doorname, $handle) = @_;
  my $file = door_user_file($doorname, $handle);
  return undef unless -e $file;
  my $data;
  eval { $data = lock_retrieve($file); };
  return $@ ? undef : $data;
}

# Save another player's data (after PvP attack modifies it)
sub door_save_player {
  my ($doorname, $handle, $data) = @_;
  my $file = door_user_file($doorname, $handle);
  eval { lock_store($data, $file); };
  return $@ ? 0 : 1;
}

# Send a message to a specific player (delivered on their next login/check)
sub door_send_message {
  my ($doorname, $target_handle, $message) = @_;

  # Persist message for offline/missed delivery
  my $dir = door_data_dir($doorname);
  my $msgfile = "$dir/messages.dat";
  my $messages = [];
  if (-e $msgfile) {
    eval { $messages = lock_retrieve($msgfile); };
    $messages = [] if $@;
  }
  push @$messages, {
    from      => $info{'handle'},
    to        => $target_handle,
    message   => $message,
    timestamp => time(),
    read      => 0,
  };
  # Keep only last 100 messages
  splice(@$messages, 0, @$messages - 100) if @$messages > 100;
  eval { lock_store($messages, $msgfile); };

  # Also deliver immediately via broker direct message if target is online
  my $dm = "\@DATACLR[$doorname\@DATACLR] \@USERCLR" . ($info{'handle'} // $doorname) .
           "\@DATACLR: \@SYSTEMCLR$message";
  if ($_BBS_BROKER_SOCK && defined &broker_send_direct_message) {
    eval {
      broker_send_direct_message($_BBS_BROKER_SOCK, "user-$target_handle", $dm);
    };
  } elsif ($_DOOR_BROKER_SOCK && defined &broker_send_direct_message) {
    eval {
      broker_send_direct_message($_DOOR_BROKER_SOCK, "user-$target_handle", $dm);
    };
  }
}

# Get unread messages for current player
sub door_get_messages {
  my ($doorname) = @_;
  my $dir = door_data_dir($doorname);
  my $msgfile = "$dir/messages.dat";
  return [] unless -e $msgfile;
  my $messages;
  eval { $messages = lock_retrieve($msgfile); };
  return [] if $@ || !$messages;
  my @mine = grep { lc($_->{to}) eq lc($info{'handle'}) && !$_->{read} } @$messages;
  return \@mine;
}

# Mark messages as read for current player
sub door_mark_messages_read {
  my ($doorname) = @_;
  my $dir = door_data_dir($doorname);
  my $msgfile = "$dir/messages.dat";
  return unless -e $msgfile;
  my $messages;
  eval { $messages = lock_retrieve($msgfile); };
  return if $@ || !$messages;
  for my $m (@$messages) {
    $m->{read} = 1 if lc($m->{to}) eq lc($info{'handle'});
  }
  eval { lock_store($messages, $msgfile); };
}

# Show unread messages to player
sub door_show_messages {
  my ($doorname) = @_;
  my $msgs = door_get_messages($doorname);
  return unless @$msgs;
  writeline("", 1);
  writeline($config{'themecolor'} . " You have " . scalar(@$msgs) . " message(s):" . $RST, 1);
  door_hrule(50);
  for my $m (@$msgs) {
    my $when = localtime($m->{timestamp});
    writeline($config{'usercolor'} . " From $m->{from}" . $config{'systemcolor'} . " ($when):" . $RST, 1);
    writeline($config{'datacolor'} . "   $m->{message}" . $RST, 1);
  }
  writeline("", 1);
  door_mark_messages_read($doorname);
}

# ============================================================================
# UI HELPERS
# ============================================================================

# Draw a horizontal rule using box-drawing chars
# door_hrule($width, $color)  -- defaults to 50 wide, linecolor
sub door_hrule {
  my ($width, $color) = @_;
  $width //= 50;
  $color //= $config{'linecolor'};
  writeline($color . " " . (boxchar('horizontal') x $width) . $RST, 1);
}

# ============================================================================
# CARD ART
# ============================================================================
#
# Draws playing cards as box-art, side by side. Each card is 9 chars wide x 5 tall.
#
#  ┌───────┐
#  │ A     │    row 1: rank top-left
#  │   ♥   │    row 2: suit center
#  │     A │    row 3: rank bottom-right
#  └───────┘
#
# Usage: door_draw_cards(\@cards, $base_color, $label)
#   @cards - card strings like "AH", "10D", "KS", or "?" for face-down

my %_SUIT_SYMBOL = (
  'H' => chr(3),   # CP437 heart
  'D' => chr(4),   # CP437 diamond
  'C' => chr(5),   # CP437 club
  'S' => chr(6),   # CP437 spade
  '?' => '?',
);

sub _door_parse_card {
  my ($card) = @_;
  return ('?', '?') if !defined($card) || $card eq '?';
  if ($card =~ /^(10)([HDCS])$/) { return ($1, $2); }
  if ($card =~ /^([2-9AJQK])([HDCS])$/) { return ($1, $2); }
  return ('?', '?');
}

sub door_draw_cards {
  my ($cards, $base_color, $label) = @_;
  $base_color //= $config{'linecolor'};
  my $n = scalar @$cards;
  return unless $n > 0;

  my $h  = boxchar('horizontal') x 7;
  my $tl = boxchar('topleft');
  my $tr = boxchar('topright');
  my $bl = boxchar('bottomleft');
  my $br = boxchar('bottomright');
  my $vl = boxchar('vertical');

  writeline($config{'systemcolor'} . " $label" . $RST, 1) if $label;

  my @parsed;
  for my $c (@$cards) {
    my ($rank, $suit) = _door_parse_card($c);
    my $sym  = $_SUIT_SYMBOL{$suit} // '?';
    my $scol = ($suit eq 'H' || $suit eq 'D') ? $config{'errorcolor'} : $config{'datacolor'};
    $scol    = $config{'linecolor'} if $suit eq '?';
    push @parsed, { rank => $rank, suit => $suit, sym => $sym, scol => $scol };
  }

  for my $row (0 .. 4) {
    my $line = " ";
    for my $i (0 .. $n - 1) {
      my $p = $parsed[$i];
      my ($r, $s, $sc) = ($p->{rank}, $p->{sym}, $p->{scol});
      my $hidden = ($p->{suit} eq '?');

      if    ($row == 0) { $line .= $base_color . $tl . $h . $tr . $RST; }
      elsif ($row == 1) { my $rl = $hidden ? "? " : sprintf("%-2s", $r);
                          $line .= $base_color . $vl . $RST . $sc . " $rl    " . $base_color . $vl . $RST; }
      elsif ($row == 2) { my $c2 = $hidden ? "  ?  " : "  $s  ";
                          $line .= $base_color . $vl . $RST . $sc . " $c2 " . $base_color . $vl . $RST; }
      elsif ($row == 3) { my $rr = $hidden ? " ? " : sprintf("%2s ", $r);
                          $line .= $base_color . $vl . $RST . $sc . "    $rr" . $base_color . $vl . $RST; }
      elsif ($row == 4) { $line .= $base_color . $bl . $h . $br . $RST; }

      $line .= " " if $i < $n - 1;
    }
    writeline($line, 1);
  }
}

# ============================================================================
# SLOT MACHINE DISPLAY
# ============================================================================
#
#  ┌─────────┬─────────┬─────────┐
#  │  Cherry  │  Bell   │   7    │
#  └─────────┴─────────┴─────────┘
#
# door_draw_slots(\@reels, $winning)  -- @reels = 3 symbol strings

sub door_draw_slots {
  my ($reels, $winning) = @_;
  $reels //= ['?', '?', '?'];

  my $h9  = boxchar('horizontal') x 9;
  my $vl  = boxchar('vertical');
  my $tl  = boxchar('topleft');   my $tr = boxchar('topright');
  my $bl  = boxchar('bottomleft');my $br = boxchar('bottomright');
  my $td  = boxchar('tdown');     my $tu = boxchar('tup');

  my $lc = $config{'linecolor'};
  my $dc = $winning ? $config{'usercolor'} : $config{'datacolor'};

  writeline(" " . $lc . $tl . $h9 . $td . $h9 . $td . $h9 . $tr . $RST, 1);
  my $mid = " " . $lc . $vl . $RST;
  for my $i (0 .. 2) {
    my $sym = $reels->[$i] // '?';
    $mid .= $dc . sprintf(" %-8s", substr($sym, 0, 8)) . $RST . $lc . $vl . $RST;
  }
  writeline($mid, 1);
  writeline(" " . $lc . $bl . $h9 . $tu . $h9 . $tu . $h9 . $br . $RST, 1);
}

