sub _atl_sell_artifacts {
  my ($p) = @_;

  door_header("Artifact Dealer");

  if (@{$p->{artifacts}} == 0) {
    writeline($config{'systemcolor'} . " You have no artifacts to sell." . $RST, 1);
    door_pause();
    return;
  }

  writeline($config{'systemcolor'} . " Your artifacts:" . $RST, 1);
  writeline("", 1);
  my $total = 0;
  my $idx = 1;
  for my $art (@{$p->{artifacts}}) {
    writeline(sprintf("  %s%-2d%s %s%-24s %s%s gold%s",
      $config{'promptcolor'}, $idx, $config{'themecolor'},
      $config{'datacolor'}, $art->{name},
      $config{'usercolor'}, _afmt($art->{value}),
      $RST), 1);
    $total += $art->{value};
    $idx++;
  }
  writeline("", 1);
  writeline($config{'systemcolor'} . " Total value: " . $config{'datacolor'} . _afmt($total) . " gold" . $RST, 1);
  writeline("", 1);
  writeline($config{'systemcolor'} . " Sell all? (Y/N) " . $RST);
  my $ch = uc(waitkey("")); writeline("", 1);

  if ($ch eq 'Y') {
    $p->{gold} += $total;
    $p->{artifacts} = [];
    writeline($config{'usercolor'} . " Sold! You received " . _afmt($total) . " gold." . $RST, 1);
    door_save($DOOR_NAME, $p);
  }
  door_pause();
}

