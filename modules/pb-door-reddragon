# ============================================================================
# FOREST - The main gameplay loop
# ============================================================================

sub _rd_forest {
  my ($p) = @_;

  unless ($p->{alive}) {
    writeline("", 1);
    writeline($config{'errorcolor'} . " You are dead! Visit the healer to resurrect." . $RST, 1);
    door_pause();
    return;
  }

  if ($p->{forest_fights} <= 0) {
    writeline("", 1);
    writeline($config{'systemcolor'} . " You have no more forest fights today." . $RST, 1);
    writeline($config{'systemcolor'} . " Return tomorrow for more adventure!" . $RST, 1);
    door_pause();
    return;
  }

  door_header("The Dark Forest");
  writeline($config{'systemcolor'} . " You venture into the dark forest..." . $RST, 1);
  writeline($config{'systemcolor'} . " Fights remaining: " . $config{'datacolor'} . "$p->{forest_fights}" . $RST, 1);
  writeline("", 1);

  # Random event vs combat (20% event, 80% combat)
  if (rand(100) < 20) {
    _rd_forest_event($p);
  } else {
    _rd_forest_combat($p);
  }

  $p->{forest_fights}--;
  door_save($DOOR_NAME, $p);
}

sub _rd_forest_event {
  my ($p) = @_;
  my $event = $FOREST_EVENTS[int(rand(@FOREST_EVENTS))];

  if ($event eq 'find_gold') {
    my $gold = int(rand($p->{level} * 100)) + 50;
    writeline($config{'datacolor'} . " You find a pouch of gold on the ground!" . $RST, 1);
    writeline($config{'systemcolor'} . " You found " . $config{'usercolor'} . _fmt($gold) . " gold" . $RST, 1);
    $p->{gold} += $gold;
  }
  elsif ($event eq 'find_gem') {
    writeline($config{'datacolor'} . " A glittering gem catches your eye!" . $RST, 1);
    writeline($config{'systemcolor'} . " You found a " . $config{'usercolor'} . "Gem!" . $RST, 1);
    $p->{gems}++;
  }
  elsif ($event eq 'old_man') {
    my $exp = int(rand($p->{level} * 30)) + 20;
    writeline($config{'datacolor'} . " An old man appears and shares wisdom..." . $RST, 1);
    writeline($config{'systemcolor'} . " You gain " . $config{'usercolor'} . _fmt($exp) . " experience" . $RST, 1);
    $p->{exp} += $exp;
  }
  elsif ($event eq 'fairy') {
    my $heal = int($p->{max_hp} * 0.3);
    writeline($config{'datacolor'} . " A forest fairy heals your wounds!" . $RST, 1);
    $p->{hp} = $p->{hp} + $heal;
    $p->{hp} = $p->{max_hp} if $p->{hp} > $p->{max_hp};
    writeline($config{'systemcolor'} . " You recover " . $config{'usercolor'} . "$heal HP" . $RST, 1);
  }
  elsif ($event eq 'trap') {
    my $dmg = int(rand($p->{level} * 5)) + 3;
    writeline($config{'errorcolor'} . " You stumble into a trap!" . $RST, 1);
    writeline($config{'errorcolor'} . " You take " . $config{'usercolor'} . "$dmg damage" . $RST, 1);
    $p->{hp} -= $dmg;
    if ($p->{hp} <= 0) {
      $p->{hp} = 0;
      $p->{alive} = 0;
      $p->{deaths}++;
      writeline("", 1);
      writeline($config{'errorcolor'} . " The trap has killed you!" . $RST, 1);
    }
  }
  else {
    writeline($config{'systemcolor'} . " The forest is quiet today. Nothing happens." . $RST, 1);
  }
  writeline("", 1);
  door_pause();
}

# ============================================================================
# COMBAT SYSTEM
# ============================================================================

sub _rd_forest_combat {
  my ($p) = @_;
  my $monster = _rd_pick_monster($p->{level});
  my $mhp = $monster->{hp} + int(rand($monster->{hp} * 0.3));
  my $mstr = $monster->{str};
  my $mdef = $monster->{def};
  my $mname = $monster->{name};

  writeline($config{'errorcolor'} . " A $mname appears!" . $RST, 1);
  writeline("", 1);

  my $fled = 0;
  my @combat_log = ();
  while ($mhp > 0 && $p->{hp} > 0) {
    door_clear();
    writeline($config{'themecolor'} . " Forest Combat" . $RST, 1);
    door_hrule(50);
    writeline($config{'errorcolor'} . " " . $mname .
      $config{'systemcolor'} . "   HP: " . $config{'errorcolor'} . $mhp . $RST, 1);
    writeline($config{'usercolor'} . " " . $info{'handle'} .
      $config{'systemcolor'} . "   HP: " . $config{'datacolor'} . "$p->{hp}/$p->{max_hp}" . $RST, 1);
    writeline("", 1);
    for my $log_line (@combat_log) { writeline($log_line, 1); }
    @combat_log = ();
    writeline("", 1);
    writeline("  " . $config{'promptcolor'} . "A" . $config{'themecolor'} . "ttack  " .
              $config{'promptcolor'} . "R" . $config{'themecolor'} . "un  " .
              $config{'promptcolor'} . "U" . $config{'themecolor'} . "se Gem  " .
              $config{'systemcolor'} . "? " . $RST);
    my $ch = uc(getline('text', 1, "", 1));

    if ($ch eq 'A') {
      # Player attacks
      my $total_str = $p->{str} + $WEAPONS[$p->{weapon}]{str};
      my $pdmg = int(rand($total_str) * 0.8) + int($total_str * 0.3);
      $pdmg -= int($mdef * 0.3);
      $pdmg = 1 if $pdmg < 1;
      $mhp -= $pdmg;
      push @combat_log, $config{'usercolor'} . " You hit the $mname for " . $config{'datacolor'} . "$pdmg" . $config{'usercolor'} . " damage!" . $RST;

      # Monster attacks back (if alive)
      if ($mhp > 0) {
        my $total_def = $p->{def} + $ARMORS[$p->{armor}]{def};
        my $mdmg = int(rand($mstr) * 0.8) + int($mstr * 0.3);
        $mdmg -= int($total_def * 0.3);
        $mdmg = 1 if $mdmg < 1;
        $p->{hp} -= $mdmg;
        push @combat_log, $config{'errorcolor'} . " The $mname hits you for " . $config{'datacolor'} . "$mdmg" . $config{'errorcolor'} . " damage!" . $RST;
      }
    }
    elsif ($ch eq 'R') {
      if (rand(100) < 60) {
        writeline("", 1);
        writeline($config{'systemcolor'} . " You flee from the $mname!" . $RST, 1);
        $fled = 1;
        last;
      } else {
        push @combat_log, $config{'errorcolor'} . " You couldn't escape!" . $RST;
        # Monster gets free hit
        my $total_def = $p->{def} + $ARMORS[$p->{armor}]{def};
        my $mdmg = int(rand($mstr) * 0.8) + int($mstr * 0.3);
        $mdmg -= int($total_def * 0.3);
        $mdmg = 1 if $mdmg < 1;
        $p->{hp} -= $mdmg;
        push @combat_log, $config{'errorcolor'} . " The $mname hits you for " . $config{'datacolor'} . "$mdmg" . $config{'errorcolor'} . " damage!" . $RST;
      }
    }
    elsif ($ch eq 'U') {
      if ($p->{gems} > 0) {
        $p->{gems}--;
        my $gdmg = int($p->{str} * 2) + int(rand(50));
        $mhp -= $gdmg;
        push @combat_log, $config{'datacolor'} . " The gem explodes with energy!" . $RST;
        push @combat_log, $config{'usercolor'} . " You blast the $mname for " . $config{'datacolor'} . "$gdmg" . $config{'usercolor'} . " damage!" . $RST;
      } else {
        push @combat_log, $config{'systemcolor'} . " No gems!" . $RST;
        writeline($config{'systemcolor'} . " You have no gems!" . $RST, 1);
        writeline("", 1);
      }
    }
  }

  unless ($fled) {
    if ($p->{hp} <= 0) {
      # Player died
      $p->{hp} = 0;
      $p->{alive} = 0;
      $p->{deaths}++;
      my $lost_gold = int($p->{gold} * 0.1);
      $p->{gold} -= $lost_gold;
      writeline($config{'errorcolor'} . " The $mname has killed you!" . $RST, 1);
      writeline($config{'errorcolor'} . " You lost " . $config{'datacolor'} . _fmt($lost_gold) . $config{'errorcolor'} . " gold." . $RST, 1);
    }
    elsif ($mhp <= 0) {
      # Monster died
      my $exp_gain = $monster->{exp} + int(rand($monster->{exp} * 0.3));
      my $gold_gain = $monster->{gold} + int(rand($monster->{gold} * 0.5));
      $p->{exp} += $exp_gain;
      $p->{gold} += $gold_gain;
      $p->{kills}++;
      writeline($config{'usercolor'} . " You have defeated the $mname!" . $RST, 1);
      writeline($config{'systemcolor'} . " Experience: " . $config{'datacolor'} . "+" . _fmt($exp_gain) .
        $config{'systemcolor'} . "  Gold: " . $config{'datacolor'} . "+" . _fmt($gold_gain) . $RST, 1);

      # Check for level up
      _rd_check_levelup($p);
    }
  }
  writeline("", 1);
  door_pause();
}

sub _rd_pick_monster {
  my ($level) = @_;
  my @eligible = grep { $_->{min} <= $level && $_->{max} >= $level } @MONSTERS;
  @eligible = ($MONSTERS[0]) unless @eligible;
  return $eligible[int(rand(@eligible))];
}

sub _rd_check_levelup {
  my ($p) = @_;
  return if $p->{level} >= $MAX_LEVEL;
  my $next = $LEVELS[$p->{level}]; # Next level (0-indexed, so current level = next index)
  if ($p->{exp} >= $next->{exp}) {
    writeline("", 1);
    writeline($config{'usercolor'} . " * LEVEL UP! *" . $RST, 1);
    writeline($config{'systemcolor'} . " You can train at the Training Grounds to advance!" . $RST, 1);
  }
}

