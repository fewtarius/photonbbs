sub _bc_display {
  my ($g) = @_;
  door_clear();
  my $lake = $LAKES[$g->{lake_idx}];
  my $lure = _bc_current_lure_name($g);
  my $boat_depth = $g->{lake}[$g->{boat_y}][$g->{boat_x}];

  writeline($config{'themecolor'} . " " . $lake->{name} .
    $config{'systemcolor'} . "  " . $g->{weather}{name} .
    "  Livewell: " . $config{'datacolor'} . scalar(@{$g->{livewell}}) . "/$LIVEWELL" .
    $config{'systemcolor'} . "  " . $config{'datacolor'} . _bc_money($g->{money}) . $RST, 1);

  for my $y (0 .. $LAKE_H - 1) {
    my $line = " ";
    for my $x (0 .. $LAKE_W - 1) {
      if ($y == $g->{boat_y} && $x == $g->{boat_x}) {
        $line .= $config{'usercolor'} . "@" . $RST; next;
      }
      if ($g->{fish_finder}) {
        my $dist = abs($y - $g->{boat_y}) + abs($x - $g->{boat_x});
        if ($dist <= 5) {
          my $fh = 0;
          for my $f (@{$g->{fish}}) {
            if ($f->{y} == $y && $f->{x} == $x && $f->{active}) {
              $line .= $config{'errorcolor'} . "o" . $RST; $fh = 1; last;
            }
          }
          next if $fh;
        }
      }
      my $depth = $g->{lake}[$y][$x];
      if ($depth < 0) {
        $line .= $config{'promptcolor'} . "#" . $RST;
      } else {
        my $surf = $g->{surface}[$y][$x];
        if ($surf > 0 && $surf <= $#SURFACE_TYPES) {
          $line .= $SURFACE_TYPES[$surf]{color} . $SURFACE_TYPES[$surf]{char} . $RST;
        } elsif ($depth <= 5) {  $line .= "\e[36m~" . $RST;
        } elsif ($depth <= 15) { $line .= "\e[34m~" . $RST;
        } elsif ($depth <= 30) { $line .= "\e[34;1m~" . $RST;
        } else {                 $line .= "\e[35m~" . $RST;
        }
      }
    }
    writeline($line, 1);
  }

  writeline("", 1);
  my $sn = $g->{surface}[$g->{boat_y}][$g->{boat_x}] >= 0
    ? $SURFACE_TYPES[$g->{surface}[$g->{boat_y}][$g->{boat_x}]]{name} : "Land";
  my $bn = $BOTTOM_TYPES[$g->{bottom}[$g->{boat_y}][$g->{boat_x}]]{name};
  writeline($config{'systemcolor'} . " Depth:" . $config{'datacolor'} . " ${boat_depth}ft" .
    $config{'systemcolor'} . " Surface:" . $config{'datacolor'} . " $sn" .
    $config{'systemcolor'} . " Bottom:" . $config{'datacolor'} . " $bn" .
    $config{'systemcolor'} . " Lure:" . $config{'datacolor'} . " $lure" . $RST, 1);
  writeline($config{'linecolor'} . " WASD=move C=cast T=tackle L=livewell F=finder S=shop H=scores Q=quit" . $RST, 1);
}

# ============================================================================
# DEPTH FINDER
# ============================================================================

sub _bc_depth_finder {
  my ($g) = @_;
  door_clear();
  writeline($config{'themecolor'} . " Depth Finder" . $RST, 1);
  writeline($config{'linecolor'} . " " . ("-" x 45) . $RST, 1);

  my $range = 5;
  my ($by, $bx) = ($g->{boat_y}, $g->{boat_x});

  my $hdr = "     ";
  for my $dx (-$range .. $range) {
    my $x = $bx + $dx;
    if ($dx == 0) { $hdr .= $config{'usercolor'} . " @@ " . $RST; }
    elsif ($x >= 0 && $x < $LAKE_W && $g->{lake}[$by][$x] >= 0) { $hdr .= "    "; }
    else { $hdr .= " ## "; }
  }
  writeline($hdr, 1);

  for my $row (0 .. 9) {
    my $depth_at = ($row + 1) * 5;
    my $line = sprintf(" %s%3dft%s", $config{'linecolor'}, $depth_at, $RST);
    for my $dx (-$range .. $range) {
      my $x = $bx + $dx;
      if ($x < 0 || $x >= $LAKE_W) { $line .= " ## "; next; }
      my $d = $g->{lake}[$by][$x];
      if ($d < 0) {
        $line .= $config{'promptcolor'} . " ## " . $RST;
      } elsif ($d < $depth_at) {
        my @ch = ('..', '**', 'OO', '~~');
        $line .= $config{'promptcolor'} . " " . $ch[$g->{bottom}[$by][$x]] . " " . $RST;
      } else {
        my $fish_here = 0;
        if ($g->{fish_finder}) {
          for my $f (@{$g->{fish}}) {
            if ($f->{x} == $x && $f->{y} == $by && abs($f->{depth} - $depth_at) < 5) {
              $fish_here = 1; last;
            }
          }
        }
        if ($fish_here) { $line .= $config{'errorcolor'} . " <> " . $RST; }
        elsif ($g->{surface}[$by][$x] > 0 && $depth_at <= 10) {
          my $s = $g->{surface}[$by][$x];
          $line .= $SURFACE_TYPES[$s]{color} . " " . $SURFACE_TYPES[$s]{char} x 2 . " " . $RST;
        } else { $line .= "\e[34m .. " . $RST; }
      }
    }
    writeline($line, 1);
  }

  writeline("", 1);
  my $bd = $g->{lake}[$by][$bx];
  my $sn = $g->{surface}[$by][$bx] >= 0 ? $SURFACE_TYPES[$g->{surface}[$by][$bx]]{name} : "Land";
  my $bn = $BOTTOM_TYPES[$g->{bottom}[$by][$bx]]{name};
  writeline($config{'systemcolor'} . " Under boat: ${bd}ft  Surface: $sn  Bottom: $bn" . $RST, 1);
  door_pause();
}

# ============================================================================
# COMMAND HANDLER
# ============================================================================

sub _bc_command {
  my ($g) = @_;
  writeline($config{'promptcolor'} . " > " . $RST);
  my $cmd = lc(waitkey(""));
  writeline("", 1);

  if    ($cmd eq 'w' || $cmd eq "\e[A") { _bc_move($g, -1, 0); }
  elsif ($cmd eq 'x' || $cmd eq "\e[B") { _bc_move($g, 1, 0); }
  elsif ($cmd eq 'a' || $cmd eq "\e[D") { _bc_move($g, 0, -1); }
  elsif ($cmd eq 'd' || $cmd eq "\e[C") { _bc_move($g, 0, 1); }
  elsif ($cmd eq 'c') { _bc_cast($g); }
  elsif ($cmd eq 't') { _bc_tackle_box($g); }
  elsif ($cmd eq 'l') { _bc_show_livewell($g); }
  elsif ($cmd eq 'f') { _bc_depth_finder($g); }
  elsif ($cmd eq 's') { _bc_shop($g); }
  elsif ($cmd eq 'h') { _bc_scores($g); }
  elsif ($cmd eq 'q') {
    writeline($config{'systemcolor'} . " Quit fishing? (Y/N) " . $RST);
    my $yn = uc(waitkey("")); writeline("", 1);
    $g->{quit} = 1 if $yn eq 'Y';
  }
  _bc_move_fish($g);
}

sub _bc_move {
  my ($g, $dy, $dx) = @_;
  my ($ny, $nx) = ($g->{boat_y} + $dy, $g->{boat_x} + $dx);
  return if $ny < 0 || $ny >= $LAKE_H || $nx < 0 || $nx >= $LAKE_W;
  return if $g->{lake}[$ny][$nx] < 0;
  $g->{boat_y} = $ny; $g->{boat_x} = $nx;
}

sub _bc_move_fish {
  my ($g) = @_;
  for my $f (@{$g->{fish}}) {
    next if rand(100) < 30;
    my $sp = $FISH[$f->{species}];
    my ($dy, $dx) = (int(rand(3)) - 1, int(rand(3)) - 1);
    my ($ny, $nx) = ($f->{y} + $dy, $f->{x} + $dx);
    next if $ny < 1 || $ny >= $LAKE_H-1 || $nx < 1 || $nx >= $LAKE_W-1;
    my $depth = $g->{lake}[$ny][$nx];
    next if $depth < 0;
    if ($depth >= $sp->{mind} && $depth <= $sp->{maxd}) {
      $f->{y} = $ny; $f->{x} = $nx; $f->{depth} = $depth;
    } elsif (rand(100) < 15) {
      $f->{y} = $ny; $f->{x} = $nx; $f->{depth} = $depth;
    }
    $f->{active} = (rand(100) < 50 * $g->{weather}{bite_mod}) ? 1 : 0;
  }
}

# ============================================================================
# TACKLE BOX
# ============================================================================

sub _bc_tackle_box {
  my ($g) = @_;
  door_clear();
  writeline($config{'themecolor'} . " Tackle Box" . $RST, 1);
  writeline($config{'linecolor'} . " " . ("-" x 55) . $RST, 1);
  writeline("", 1);

  my @owned;
  my $idx = 1;
  for my $ti (0 .. $#LURE_TYPES) {
    for my $si (0 .. $#LURE_SIZES) {
      my $name = "$LURE_SIZES[$si]{name} $LURE_TYPES[$ti]{type}";
      next unless $g->{lures_owned}{$name};
      my $lt = $LURE_TYPES[$ti];
      my $di;
      if ($lt->{behavior} eq 'top') { $di = "Surface"; }
      elsif ($lt->{behavior} eq 'dive') {
        $di = sprintf("S:%d M:%d F:%dft", $lt->{depths}[1], $lt->{depths}[2], $lt->{depths}[3]);
      } else {
        $di = sprintf("S:%d M:%d F:%dft", $lt->{depths}[0], $lt->{depths}[1], $lt->{depths}[2]);
      }
      my $cur = ($ti == $g->{lure_type} && $si == $g->{lure_size}) ? " <--" : "";
      writeline(sprintf("  %s%2d%s %s%-20s%s %s%s%s",
        $config{'promptcolor'}, $idx, $config{'themecolor'},
        $config{'usercolor'}, $name, $config{'systemcolor'}, $di,
        $config{'errorcolor'}, $cur . $RST), 1);
      push @owned, { ti => $ti, si => $si, name => $name };
      $idx++;
    }
  }

  writeline("", 1);
  writeline($config{'systemcolor'} . " Select lure (0 cancel): " . $RST);
  my $choice = int(getline('text', 2, "", 1));
  if ($choice >= 1 && $choice <= @owned) {
    my $sel = $owned[$choice - 1];
    $g->{lure_type} = $sel->{ti}; $g->{lure_size} = $sel->{si};
    writeline($config{'usercolor'} . " Equipped: $sel->{name}" . $RST, 1);
    door_pause();
  }
}

# ============================================================================
# CASTING
# ============================================================================

sub _bc_cast {
  my ($g) = @_;
  my $boat_depth = $g->{lake}[$g->{boat_y}][$g->{boat_x}];

  if ($boat_depth <= 0) {
    writeline($config{'errorcolor'} . " Can't cast from land!" . $RST, 1);
    door_pause(); return;
  }
  if (@{$g->{livewell}} >= $LIVEWELL) {
    writeline($config{'errorcolor'} . " Livewell full! Sell your catch." . $RST, 1);
    door_pause(); return;
  }

  writeline($config{'systemcolor'} . " Retrieve: [1]Stop [2]Slow [3]Medium [4]Fast " . $RST);
  my $sc = int(waitkey("") // "3");
  $sc = 3 if $sc < 1 || $sc > 4;
  $g->{speed} = $sc - 1;

  my $lt = $LURE_TYPES[$g->{lure_type}];
  my $lure_depth = $lt->{depths}[$g->{speed}];
  $lure_depth = $boat_depth if $lure_depth > $boat_depth;
  $g->{lure_depth} = $lure_depth;

  my $lname = _bc_current_lure_name($g);
  writeline("", 1);
  writeline($config{'themecolor'} . " Casting $lname... $SPEEDS[$g->{speed}]  Depth: ${lure_depth}ft" . $RST, 1);

  my @cands;
  for my $f (@{$g->{fish}}) {
    next unless $f->{active};
    my $sp = $FISH[$f->{species}];
    my $dist = abs($f->{y} - $g->{boat_y}) + abs($f->{x} - $g->{boat_x});
    next if $dist > 4;
    next if abs($f->{depth} - $lure_depth) > 10;

    my $ltype = lc($lt->{type});
    my $lmatch = 0;
    for my $p (@{$sp->{lure}}) { if ($ltype =~ /\Q$p\E/i) { $lmatch = 1; last; } }

    my $ls = $LURE_SIZES[$g->{lure_size}];
    next if $f->{weight} < $ls->{minfish} || $f->{weight} > $ls->{maxfish};

    my $surface = $g->{surface}[$f->{y}][$f->{x}];
    my $smatch = 0;
    if (exists $STRUCT_MAP{$sp->{struct}}) {
      for my $sid (@{$STRUCT_MAP{$sp->{struct}}}) {
        if ($surface == $sid) { $smatch = 1; last; }
      }
    }
    $smatch = 1 if $sp->{struct} eq 'open' && $surface == 0;

    my $chance = 25 + ($lmatch ? 20 : 0) + ($smatch ? 10 : 0);
    $chance -= abs($f->{depth} - $lure_depth) * 2;
    $chance -= $dist * 5;
    $chance = int($chance * $g->{weather}{bite_mod} * $ls->{strike_mod});
    $chance = 5 if $chance < 5; $chance = 85 if $chance > 85;
    push @cands, { fish => $f, chance => $chance };
  }

  if (!@cands) {
    my @m = ("No bites here.", "Nothing interested.", "Try different water.", "No takers.");
    writeline($config{'systemcolor'} . " " . $m[int(rand(@m))] . $RST, 1);
    door_pause(); return;
  }

  for my $c (sort { $b->{chance} <=> $a->{chance} } @cands) {
    if (rand(100) < $c->{chance}) { _bc_strike($g, $c->{fish}); return; }
  }

  my @m = ("A nibble... but no hookup.", "Something bumped the lure.", "A swirl, but no strike.");
  writeline($config{'systemcolor'} . " " . $m[int(rand(@m))] . $RST, 1);
  door_pause();
}

# ============================================================================
# STRIKE AND FIGHT
# ============================================================================

sub _bc_strike {
  my ($g, $fish) = @_;
  my $sp = $FISH[$fish->{species}];

  writeline("", 1);
  writeline($config{'usercolor'} . " Strike!" . $RST, 1);
  writeline($config{'systemcolor'} . " Hit H to hook!" . $RST, 1);
  writeline($config{'promptcolor'} . " > " . $RST);
  my $key = lc(waitkey(""));

  if ($key ne 'h') {
    writeline("", 1);
    writeline($config{'systemcolor'} . " Too slow! It spit the lure." . $RST, 1);
    door_pause(); return;
  }

  writeline("", 1);
  writeline($config{'usercolor'} . " Hooked!" . $RST, 1);

  my $line_test = $g->{rod_power} * 5 + 4;
  my $tension = int(rand(20));
  my $energy = int($sp->{fight} * 3 + $fish->{weight} * 0.5);
  my $distance = 4 + int($sp->{fight} / 2);
  my $max_t = $line_test * 3;

  while ($distance > 0 && $tension < $max_t && $energy > 0) {
    my $pull = int(rand($sp->{fight} * 2)) + int($fish->{weight} * 0.3);

    if ($pull > $line_test) {
      writeline($config{'errorcolor'} . " Be careful - pulling the drag!" . $RST, 1);
    }
    $tension += $pull;

    my $pct = $tension * 100 / $max_t;
    my $fl = int($pct / 100 * 25); $fl = 25 if $fl > 25;
    my $bar = "[" . ("=" x $fl) . (" " x (25 - $fl)) . "]";
    my $tc = $pct > 75 ? $config{'errorcolor'} : $pct > 40 ? $config{'promptcolor'} : $config{'usercolor'};

    writeline($config{'systemcolor'} . " Line: " . $tc . $bar .
      $config{'systemcolor'} . " Dist:" . $config{'datacolor'} . "$distance" .
      $config{'systemcolor'} . " Energy:" . $config{'datacolor'} . "$energy" . $RST, 1);
    writeline($config{'systemcolor'} . " [R]eel  [B]ear Down  [G]ive 'em Line " . $RST);
    my $action = lc(waitkey(""));
    writeline("", 1);

    if ($action eq 'r') {
      $distance--; $tension += int(rand(5)) + 2; $energy -= 1;
    } elsif ($action eq 'b') {
      $tension += int(rand($sp->{fight})) + 3; $energy -= 3;
      $distance-- if rand(100) < 40;
    } elsif ($action eq 'g') {
      $tension -= int(rand(15)) + 10; $tension = 0 if $tension < 0;
      $distance++ if rand(100) < 30; $energy -= 1;
    } else {
      $tension -= int(rand(8)); $tension = 0 if $tension < 0;
    }

    if ($energy > 0 && rand(100) < 15) {
      my @ev = ("The fish jumps!", "Making a run!", "Diving deep!");
      writeline($config{'datacolor'} . " " . $ev[int(rand(@ev))] . $RST, 1);
      $tension += int(rand(10));
    }
  }

  if ($tension >= $max_t) {
    writeline("", 1);
    writeline($config{'errorcolor'} . " He snapped the line!" . $RST, 1);
    door_pause(); return;
  }

  if ($distance <= 0 || $energy <= 0) {
    writeline("", 1);
    writeline($config{'usercolor'} . " You caught a $sp->{name}!" . $RST, 1);
    writeline($config{'datacolor'} . " Weight: " . sprintf("%.2f", $fish->{weight}) . " lbs" . $RST, 1);

    push @{$g->{livewell}}, {
      species => $sp->{name}, weight => $fish->{weight}, price => $sp->{price},
    };
    $g->{total_caught}++;
    $g->{biggest} = $fish->{weight} if $fish->{weight} > $g->{biggest};
    $g->{species_caught}{$sp->{name}} = ($g->{species_caught}{$sp->{name}} // 0) + 1;

    $g->{fish} = [grep { $_ != $fish } @{$g->{fish}}];
    _bc_spawn_one($g);

    if ($fish->{weight} >= $sp->{maxw} * 0.7) {
      door_submit_score($DOOR_NAME, int($fish->{weight} * 100),
        { species => $sp->{name}, weight => sprintf("%.2f lbs", $fish->{weight}) });
    }
    if ($fish->{weight} >= $sp->{maxw} * 0.8) {
      door_broadcast($DOOR_NAME,
        sprintf("%s caught a trophy %s (%.2f lbs)!", $info{'handle'}, $sp->{name}, $fish->{weight}));
    }
  }
  door_pause();
}

sub _bc_spawn_one {
  my ($g) = @_;
  my $lake = $LAKES[$g->{lake_idx}];
  my $si = $lake->{species}[int(rand(scalar @{$lake->{species}}))];
  my $sp = $FISH[$si];
  my ($fy, $fx, $att) = (0, 0, 0);
  do {
    $fy = 1 + int(rand($LAKE_H - 2)); $fx = 1 + int(rand($LAKE_W - 2)); $att++;
  } while (($g->{lake}[$fy][$fx] < $sp->{mind} || $g->{lake}[$fy][$fx] > $sp->{maxd} ||
            $g->{lake}[$fy][$fx] < 0) && $att < 80);
  return if $att >= 80;
  my $w = $sp->{minw} + ($sp->{maxw} - $sp->{minw}) * (rand(0.5) + rand(0.5));
  push @{$g->{fish}}, {
    species => $si, y => $fy, x => $fx,
    weight => sprintf("%.2f", $w) + 0, depth => $g->{lake}[$fy][$fx],
    active => rand(100) < 50 ? 1 : 0,
  };
}

# ============================================================================
# LIVEWELL
# ============================================================================

sub _bc_show_livewell {
  my ($g) = @_;
  door_clear();
  writeline($config{'themecolor'} . " Livewell (" . scalar(@{$g->{livewell}}) . "/$LIVEWELL)" . $RST, 1);
  writeline($config{'linecolor'} . " " . ("-" x 50) . $RST, 1);

  if (!@{$g->{livewell}}) {
    writeline($config{'systemcolor'} . " Empty!" . $RST, 1);
  } else {
    my ($tw, $tv) = (0, 0);
    writeline(sprintf("  %s%-3s %-20s %8s %8s%s", $config{'systemcolor'}, "#", "Species", "Weight", "Value", $RST), 1);
    for my $i (0 .. $#{$g->{livewell}}) {
      my $f = $g->{livewell}[$i];
      my $v = $f->{weight} * $f->{price};
      $tw += $f->{weight}; $tv += $v;
      writeline(sprintf("  %s%-3d %s%-20s %s%7.2f %s%8s%s",
        $config{'promptcolor'}, $i+1, $config{'usercolor'}, $f->{species},
        $config{'datacolor'}, $f->{weight}, $config{'datacolor'}, _bc_money($v), $RST), 1);
    }
    writeline($config{'linecolor'} . " " . ("-" x 50) . $RST, 1);
    writeline(sprintf("  %s%-24s %7.2f %s%s",
      $config{'systemcolor'}, "Total:", $tw, _bc_money($tv), $RST), 1);
  }
  writeline("", 1);

  if (@{$g->{livewell}}) {
    writeline($config{'systemcolor'} . " [S]ell  [R]elease  [any]back " . $RST);
    my $cmd = lc(waitkey(""));
    if ($cmd eq 's') { _bc_sell_catch($g); }
    elsif ($cmd eq 'r') {
      writeline("", 1);
      writeline($config{'systemcolor'} . " Release which? (0 cancel) " . $RST);
      my $ch = int(getline('text', 2, "", 1));
      if ($ch >= 1 && $ch <= @{$g->{livewell}}) {
        my $rel = splice(@{$g->{livewell}}, $ch - 1, 1);
        writeline($config{'usercolor'} . " Released $rel->{species}." . $RST, 1);
        door_pause();
      }
    }
  } else { door_pause(); }
}

sub _bc_sell_catch {
  my ($g) = @_;
  my $total = 0;
  for my $f (@{$g->{livewell}}) { $total += $f->{weight} * $f->{price}; }
  $total = sprintf("%.2f", $total) + 0;
  $g->{money} += $total; $g->{lifetime_money} += $total;
  writeline("", 1);
  writeline($config{'usercolor'} . " Sold " . scalar(@{$g->{livewell}}) . " fish for " . _bc_money($total) . "!" . $RST, 1);
  $g->{livewell} = [];
  door_pause();
}

# ============================================================================
# SHOP
# ============================================================================

sub _bc_shop {
  my ($g) = @_;
  my $shopping = 1;
  while ($shopping) {
    door_clear();
    writeline($config{'themecolor'} . " Fonzo's Tackle & Bait" . $RST, 1);
    writeline($config{'linecolor'} . " " . ("-" x 50) . $RST, 1);
    writeline($config{'systemcolor'} . " Balance: " . $config{'datacolor'} . _bc_money($g->{money}) . $RST, 1);
    writeline("", 1);

    my @items;
    my $idx = 1;
    my @rods = (
      { name => "6 lb Test Line",   power => 1, price => 0 },
      { name => "10 lb Test Line",  power => 2, price => 150 },
      { name => "15 lb Test Line",  power => 3, price => 400 },
      { name => "20 lb Test Line",  power => 4, price => 800 },
      { name => "30 lb Test Line",  power => 5, price => 1500 },
    );

    writeline($config{'systemcolor'} . " -- Line Upgrades --" . $RST, 1);
    for my $r (@rods) {
      next if $r->{power} <= $g->{rod_power};
      writeline(sprintf("  %s%2d%s %s%-22s%s %s",
        $config{'promptcolor'}, $idx, $config{'themecolor'},
        $config{'usercolor'}, $r->{name}, $config{'datacolor'}, _bc_money($r->{price}) . $RST), 1);
      push @items, { type => 'rod', data => $r }; $idx++;
    }

    unless ($g->{fish_finder}) {
      writeline("", 1);
      writeline($config{'systemcolor'} . " -- Electronics --" . $RST, 1);
      writeline(sprintf("  %s%2d%s %s%-22s%s %s",
        $config{'promptcolor'}, $idx, $config{'themecolor'},
        $config{'usercolor'}, "Fish Finder", $config{'datacolor'}, _bc_money(500) . $RST), 1);
      push @items, { type => 'finder', price => 500 }; $idx++;
    }

    writeline("", 1);
    writeline($config{'systemcolor'} . " -- Lures --" . $RST, 1);
    for my $ti (0 .. $#LURE_TYPES) {
      for my $si (0 .. $#LURE_SIZES) {
        my $name = "$LURE_SIZES[$si]{name} $LURE_TYPES[$ti]{type}";
        next if $g->{lures_owned}{$name};
        my $price = 20 + ($si * 15) + ($ti * 10);
        writeline(sprintf("  %s%2d%s %s%-22s%s %s",
          $config{'promptcolor'}, $idx, $config{'themecolor'},
          $config{'usercolor'}, $name, $config{'datacolor'}, _bc_money($price) . $RST), 1);
        push @items, { type => 'lure', name => $name, price => $price, ti => $ti, si => $si }; $idx++;
      }
    }

    writeline("", 1);
    writeline($config{'systemcolor'} . " Buy (0 exit): " . $RST);
    my $ch = int(getline('text', 2, "", 1));
    if ($ch < 1 || $ch > @items) { $shopping = 0; next; }

    my $item = $items[$ch - 1];
    if ($item->{type} eq 'rod') {
      if ($g->{money} >= $item->{data}{price}) {
        $g->{money} -= $item->{data}{price}; $g->{rod_power} = $item->{data}{power};
        writeline($config{'usercolor'} . " Upgraded to $item->{data}{name}!" . $RST, 1);
      } else { writeline($config{'errorcolor'} . " Not enough money." . $RST, 1); }
    } elsif ($item->{type} eq 'finder') {
      if ($g->{money} >= $item->{price}) {
        $g->{money} -= $item->{price}; $g->{fish_finder} = 1;
        writeline($config{'usercolor'} . " Fish Finder installed!" . $RST, 1);
      } else { writeline($config{'errorcolor'} . " Not enough money." . $RST, 1); }
    } elsif ($item->{type} eq 'lure') {
      if ($g->{money} >= $item->{price}) {
        $g->{money} -= $item->{price}; $g->{lures_owned}{$item->{name}} = 1;
        writeline($config{'usercolor'} . " Bought $item->{name}!" . $RST, 1);
      } else { writeline($config{'errorcolor'} . " Not enough money." . $RST, 1); }
    }
    door_pause();
  }
}

# ============================================================================
# SCORES AND DERBY
# ============================================================================

sub _bc_scores {
  my ($g) = @_;
  door_show_scores($DOOR_NAME, "Big Catch - Trophy Fish", "Weight");
  _bc_show_derby($g);
  door_pause();
}

sub _bc_show_derby {
  my ($g) = @_;
  my $derby = door_load_shared($DOOR_NAME, "derby.dat");
  return unless $derby && $derby->{entries} && keys %{$derby->{entries}};
  writeline("", 1);
  writeline($config{'themecolor'} . " Fishing Derby Standings" . $RST, 1);
  writeline($config{'linecolor'} . " " . ("-" x 58) . $RST, 1);
  writeline(sprintf("  %s%-18s %8s %8s %8s %8s%s",
    $config{'systemcolor'}, "Angler", "Biggest", "Caught", "Species", "Earned", $RST), 1);
  my @s = sort { $derby->{entries}{$b}{biggest} <=> $derby->{entries}{$a}{biggest} }
          keys %{$derby->{entries}};
  for my $n (@s[0 .. ($#s > 14 ? 14 : $#s)]) {
    my $e = $derby->{entries}{$n};
    my $c = (lc($n) eq lc($info{'handle'})) ? $config{'usercolor'} : $config{'datacolor'};
    writeline(sprintf("  %s%-18s %s%7.1flb %8d %8d %8s%s",
      $c, substr($n, 0, 18), $config{'datacolor'}, $e->{biggest},
      $e->{total}, $e->{species}, _bc_money($e->{earned} // 0), $RST), 1);
  }
  writeline("", 1);
}

sub _bc_update_derby {
  my ($g) = @_;
  my $derby = door_load_shared($DOOR_NAME, "derby.dat") // { entries => {} };
  my $e = $derby->{entries}{$info{'handle'}} // { biggest => 0, total => 0, species => 0, earned => 0 };
  $e->{biggest} = $g->{biggest} if $g->{biggest} > ($e->{biggest} // 0);
  $e->{total} = $g->{total_caught};
  $e->{species} = scalar(keys %{$g->{species_caught}});
  $e->{earned} = $g->{lifetime_money};
  $derby->{entries}{$info{'handle'}} = $e;
  door_save_shared($DOOR_NAME, "derby.dat", $derby);

  if ($g->{biggest} > 0) {
    my $max = 0;
    for my $v (values %{$derby->{entries}}) { $max = $v->{biggest} if $v->{biggest} > $max; }
    if ($g->{biggest} >= $max) {
      door_broadcast($DOOR_NAME, sprintf("%s holds the Big Catch record: %.1f lbs!", $info{'handle'}, $g->{biggest}));
    }
  }
}

