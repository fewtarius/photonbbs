sub _casino_roulette {
  my $balance = door_get_credits();

  door_clear();
  writeline($config{'themecolor'} . " Roulette" . $RST, 1);
  door_hrule(50);
  writeline($config{'systemcolor'} . " Balance: " . $config{'usercolor'} . door_money($balance) . $RST, 1);
  writeline("", 1);

  if ($balance <= 0) {
    writeline($config{'errorcolor'} . " You're broke!" . $RST, 1);
    door_pause();
    return;
  }

  writeline($config{'systemcolor'} . " Bet types:" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "N" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Number (0-36)  pays 35:1" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "R" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Red            pays 1:1" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "B" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Black          pays 1:1" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "O" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Odd            pays 1:1" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "E" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Even           pays 1:1" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "L" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "Low (1-18)     pays 1:1" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "H" . $config{'themecolor'} . " ... " . $config{'usercolor'} . "High (19-36)   pays 1:1" . $RST, 1);
  writeline("", 1);

  writeline($config{'promptcolor'} . " Bet type: " . $RST);
  my $type = uc(waitkey(""));
  writeline("", 1);

  my $number = -1;
  if ($type eq 'N') {
    $number = door_getnum("Pick a number (0-36):", 37) - 1;
    return if $number < -1;
    $number = 0 if $number < 0;
  } elsif ($type !~ /^[RBOELH]$/) {
    writeline($config{'errorcolor'} . " Invalid bet type." . $RST, 1);
    door_pause();
    return;
  }

  my $max_bet = $balance > 5000 ? 5000 : $balance;
  my $bet = door_getamount("Place your bet (max " . door_money($max_bet) . "):", $max_bet);
  return if $bet <= 0;

  door_sub_credits($bet);

  # Spin the wheel
  writeline("", 1);
  writeline($config{'themecolor'} . " Spinning the wheel..." . $RST, 1);

  my $result = int(rand(37));  # 0-36
  my $is_red = exists $ROULETTE_RED_MAP{$result};
  my $result_color = $result == 0 ? $config{'usercolor'} : ($is_red ? $config{'errorcolor'} : $config{'datacolor'});
  my $color_name = $result == 0 ? "Green" : ($is_red ? "Red" : "Black");

  writeline($config{'systemcolor'} . " The ball lands on: " .
    $result_color . "$result $color_name" . $RST, 1);
  writeline("", 1);

  # Evaluate bet
  my $winnings = 0;
  my $won = 0;

  if ($type eq 'N' && $result == $number) {
    $winnings = $bet * 36;  # 35:1 + original bet
    $won = 1;
  } elsif ($type eq 'R' && $is_red && $result != 0) {
    $winnings = $bet * 2;
    $won = 1;
  } elsif ($type eq 'B' && !$is_red && $result != 0) {
    $winnings = $bet * 2;
    $won = 1;
  } elsif ($type eq 'O' && $result != 0 && $result % 2 == 1) {
    $winnings = $bet * 2;
    $won = 1;
  } elsif ($type eq 'E' && $result != 0 && $result % 2 == 0) {
    $winnings = $bet * 2;
    $won = 1;
  } elsif ($type eq 'L' && $result >= 1 && $result <= 18) {
    $winnings = $bet * 2;
    $won = 1;
  } elsif ($type eq 'H' && $result >= 19 && $result <= 36) {
    $winnings = $bet * 2;
    $won = 1;
  }

  if ($won) {
    door_add_credits($winnings);
    writeline($config{'usercolor'} . " You win " . door_money($winnings) . "!" . $RST, 1);
    my $profit = $winnings - $bet;
    door_submit_score($DOOR_NAME, $profit, { game => "Roulette" });
    if ($profit >= 500) {
      my $msg = "$info{'handle'} won " . door_money($profit) . " at Roulette!";
      _casino_post_news($msg);
      door_broadcast($DOOR_NAME, $msg) if $profit >= 2000;
    }
  } else {
    writeline($config{'errorcolor'} . " You lose." . $RST, 1);
  }

  door_pause();
}

# ============================================================================
# SLOT MACHINE
# ============================================================================

sub _casino_slots {
  my $balance = door_get_credits();

  door_clear();
  writeline($config{'themecolor'} . " Slot Machine" . $RST, 1);
  door_hrule(50);
  writeline("", 1);

  my $spinning = 1;
  while ($spinning) {

    door_clear();
    writeline($config{'themecolor'} . " Slot Machine" . $RST, 1);
    door_hrule(50);
    writeline("", 1);
    writeline($config{'systemcolor'} . " Payouts:" . $RST, 1);
    for my $sym (@SLOT_SYMBOLS) {
      my $p = $SLOT_PAYOUTS{$sym->{sym}};
      writeline(sprintf("  %s%-10s%s  2x: %s%-4s%s  3x: %s%-4s%s",
        $config{'usercolor'}, $sym->{sym}, $RST,
        $config{'datacolor'}, $p->{two} . "x", $RST,
        $config{'datacolor'}, $p->{three} . "x", $RST), 1);
    }
    writeline("", 1);
    $balance = door_get_credits();
    writeline($config{'systemcolor'} . " Balance: " . $config{'usercolor'} . door_money($balance) . $RST, 1);
    if ($balance <= 0) {
      writeline($config{'errorcolor'} . " You're broke!" . $RST, 1);
      door_pause();
      return;
    }

    my $max_bet = $balance > 1000 ? 1000 : $balance;
    my $bet = door_getamount("Bet (max " . door_money($max_bet) . ", 0 to quit):", $max_bet);
    if ($bet <= 0) {
      $spinning = 0;
      next;
    }

    door_sub_credits($bet);

    # Spin reels (weighted random)
    my @reels;
    for (1 .. 3) {
      push @reels, _slot_spin();
    }

    writeline("", 1);
    # Check for matches first
    my $winnings = 0;
    my $win_msg = "";
    if ($reels[0] eq $reels[1] && $reels[1] eq $reels[2]) {
      $winnings = $bet * $SLOT_PAYOUTS{$reels[0]}{three};
      $win_msg = $config{'usercolor'} . " JACKPOT! Three $reels[0]s! Win " . door_money($winnings) . "!" . $RST;
    } elsif ($reels[0] eq $reels[1] || $reels[1] eq $reels[2] || $reels[0] eq $reels[2]) {
      my $matched = ($reels[0] eq $reels[1]) ? $reels[0] : ($reels[1] eq $reels[2]) ? $reels[1] : $reels[0];
      $winnings = $bet * $SLOT_PAYOUTS{$matched}{two};
      $win_msg = $config{'usercolor'} . " Two ${matched}s! Win " . door_money($winnings) . "!" . $RST;
    } else {
      $win_msg = $config{'errorcolor'} . " No match." . $RST;
    }
    door_draw_slots(\@reels, $winnings);
    writeline($win_msg, 1);

    if ($winnings > 0) {
      door_add_credits($winnings);
      if ($winnings > $bet * 10) {
        door_submit_score($DOOR_NAME, $winnings, { game => "Slots" });
        door_log_activity($DOOR_NAME, $info{'handle'} . " hit " . door_money($winnings) . " on the slots!");
        my $msg = "$info{'handle'} hit " . door_money($winnings) . " on the Slot Machine!";
        _casino_post_news($msg);
        door_broadcast($DOOR_NAME, $msg) if $winnings >= $bet * 50;
      }
    }
    door_pause();
  }
}

sub _slot_spin {
  my $total_weight = 0;
  $total_weight += $_->{weight} for @SLOT_SYMBOLS;
  my $r = int(rand($total_weight));
  my $cumulative = 0;
  for my $sym (@SLOT_SYMBOLS) {
    $cumulative += $sym->{weight};
    return $sym->{sym} if $r < $cumulative;
  }
  return $SLOT_SYMBOLS[-1]{sym};
}

