# ============================================================================
# MAIN ENTRY POINT
# ============================================================================

sub reddragon_main {
  my $p = _rd_load_player();

  # Check for daily reset
  _rd_daily_reset($p);

  iamat($info{'handle'}, "Playing Red Dragon");

  # Connect to broker for in-town chat
  door_broker_connect($DOOR_NAME, "door-$DOOR_NAME-town");

  _rd_title_screen();
  door_show_messages($DOOR_NAME);
  door_pause();

  my $quit = 0;
  while (!$quit) {
    _rd_town_menu($p);
    my $ch = uc(getline('text', 1, "", 1));

    if    ($ch eq 'F') { _rd_forest($p); }
    elsif ($ch eq 'W') { _rd_weapon_shop($p); }
    elsif ($ch eq 'A') { _rd_armor_shop($p); }
    elsif ($ch eq 'H') { _rd_healer($p); }
    elsif ($ch eq 'I') { _rd_inn($p); }
    elsif ($ch eq 'T') { _rd_training($p); }
    elsif ($ch eq 'V') { _rd_view_stats($p); }
    elsif ($ch eq 'L') { _rd_player_list(); }
    elsif ($ch eq 'P') { _rd_pvp_attack($p); }
    elsif ($ch eq 'C') { door_chat_input($DOOR_NAME); }
    elsif ($ch eq 'D') { _rd_dragon($p); }
    elsif ($ch eq 'S') { door_show_scores($DOOR_NAME, "Red Dragon Hall of Fame", "Kills", 10); door_pause(); }
    elsif ($ch eq '/') {
      my $result = door_check_command($DOOR_NAME);
      if ($result && $result eq 'quit') { $quit = 1; }
      else { door_pause() unless $result; }
    }
    elsif ($ch eq 'Q') { $quit = 1; }
  }

  door_save($DOOR_NAME, $p);
  door_broker_disconnect();
  writeline("", 1);
  writeline($config{'themecolor'} . " The town gates close behind you..." . $RST, 1);
  writeline("", 1);
  door_pause();
  iamat($info{'handle'}, "Finished Red Dragon");
}

