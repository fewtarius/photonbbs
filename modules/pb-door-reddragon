sub _rd_training {
  my ($p) = @_;

  door_header("Training Grounds");

  if ($p->{level} >= $MAX_LEVEL) {
    writeline($config{'usercolor'} . " You have reached the maximum level!" . $RST, 1);
    writeline($config{'systemcolor'} . " There is nothing more the masters can teach you." . $RST, 1);
    door_pause();
    return;
  }

  my $next = $LEVELS[$p->{level}];
  my $title = $next->{title};

  writeline($config{'systemcolor'} . " Current Level: " . $config{'datacolor'} . "$p->{level}" .
    $config{'systemcolor'} . " (" . $LEVELS[$p->{level} - 1]{title} . ")" . $RST, 1);
  writeline($config{'systemcolor'} . " Next Level: " . $config{'datacolor'} . ($p->{level} + 1) .
    $config{'systemcolor'} . " ($title)" . $RST, 1);
  writeline("", 1);
  writeline($config{'systemcolor'} . " Requirements:" . $RST, 1);

  my $exp_ok  = $p->{exp} >= $next->{exp};
  my $gold_ok = $p->{gold} >= $next->{gold};
  my $exp_col  = $exp_ok  ? $config{'usercolor'} : $config{'errorcolor'};
  my $gold_col = $gold_ok ? $config{'usercolor'} : $config{'errorcolor'};

  writeline("  " . $config{'systemcolor'} . "Experience: " . $exp_col . _fmt($p->{exp}) . "/" . _fmt($next->{exp}) .
    ($exp_ok ? " OK" : " NEED MORE") . $RST, 1);
  writeline("  " . $config{'systemcolor'} . "Gold:       " . $gold_col . _fmt($p->{gold}) . "/" . _fmt($next->{gold}) .
    ($gold_ok ? " OK" : " NEED MORE") . $RST, 1);
  writeline("", 1);

  if ($exp_ok && $gold_ok) {
    writeline($config{'datacolor'} . " You are ready to advance!" . $RST, 1);
    writeline($config{'systemcolor'} . " Train to level " . ($p->{level} + 1) . "? (Y/N) " . $RST);
    my $ch = uc(waitkey("")); writeline("", 1);
    if ($ch eq 'Y') {
      $p->{gold} -= $next->{gold};
      $p->{level}++;
      my $lvl = $LEVELS[$p->{level} - 1];
      $p->{max_hp} = $lvl->{hp};
      $p->{hp}     = $lvl->{hp};
      $p->{str}    = $lvl->{str};
      $p->{def}    = $lvl->{def};
      writeline("", 1);
      writeline($config{'usercolor'} . " Congratulations! You are now a $lvl->{title}!" . $RST, 1);
      writeline($config{'systemcolor'} . " Level " . $config{'datacolor'} . $p->{level} .
        $config{'systemcolor'} . "  HP " . $config{'datacolor'} . $p->{max_hp} .
        $config{'systemcolor'} . "  STR " . $config{'datacolor'} . $p->{str} .
        $config{'systemcolor'} . "  DEF " . $config{'datacolor'} . $p->{def} . $RST, 1);
      door_save($DOOR_NAME, $p);
    }
  } else {
    writeline($config{'systemcolor'} . " You are not ready yet. Keep fighting!" . $RST, 1);
  }
  door_pause();
}

