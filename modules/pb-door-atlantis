sub _atl_encounter {
  my ($p) = @_;
  my @eligible = grep { $_->{depth} <= $p->{depth} } @CREATURES;
  return unless @eligible;

  # Prefer creatures at current depth
  my @preferred = grep { $_->{depth} == $p->{depth} } @eligible;
  @preferred = @eligible unless @preferred;
  my $c = $preferred[int(rand(@preferred))];

  my $chp = $c->{hp} + int(rand($c->{hp} * 0.3));
  my $catk = $c->{atk};

  writeline("", 1);
  writeline($config{'errorcolor'} . " A $c->{name} attacks!" . $RST, 1);
  writeline("", 1);

  while ($chp > 0 && $p->{hp} > 0) {
    writeline($config{'systemcolor'} . " HP: " . $config{'datacolor'} . "$p->{hp}" .
      $config{'systemcolor'} . "  $c->{name}: " . $config{'errorcolor'} . "$chp" . $RST, 1);
    writeline("  " . $config{'promptcolor'} . "A" . $config{'themecolor'} . "ttack  " .
              $config{'promptcolor'} . "R" . $config{'themecolor'} . "un  ? " . $RST);
    my $ch = uc(getline('text', 1, "", 1));

    if ($ch eq 'A') {
      my $patk = $WEAPONS[$p->{weapon}]{atk} + int(rand(8));
      my $pdmg = $patk + int(rand($patk * 0.5));
      $pdmg = 1 if $pdmg < 1;
      $chp -= $pdmg;
      writeline($config{'usercolor'} . " You hit for $pdmg damage!" . $RST, 1);
    }
    elsif ($ch eq 'R') {
      if (rand(100) < 55) {
        writeline($config{'systemcolor'} . " You swim away!" . $RST, 1);
        door_pause();
        return;
      }
      writeline($config{'errorcolor'} . " Can't escape!" . $RST, 1);
    }

    # Creature attacks
    if ($chp > 0) {
      my $mdmg = int(rand($catk) * 0.6) + int($catk * 0.3);
      $mdmg -= int($DIVING_GEAR[$p->{gear}]{depth} * 2);
      $mdmg = 1 if $mdmg < 1;
      $p->{hp} -= $mdmg;
      writeline($config{'errorcolor'} . " The $c->{name} hits you for $mdmg!" . $RST, 1);
    }
    writeline("", 1);
  }

  if ($chp <= 0) {
    my $exp = $c->{exp} + int(rand($c->{exp} * 0.3));
    my $gold = $c->{gold} + int(rand($c->{gold} * 0.5));
    $p->{exp} += $exp;
    $p->{gold} += $gold;
    $p->{creatures_killed}++;
    writeline($config{'usercolor'} . " You defeated the $c->{name}!" . $RST, 1);
    writeline($config{'systemcolor'} . " Exp: +" . $exp . "  Gold: +" . $gold . $RST, 1);

    # Level up HP based on experience thresholds
    _atl_check_levelup($p);
  }
  elsif ($p->{hp} <= 0) {
    writeline($config{'errorcolor'} . " The $c->{name} has overpowered you!" . $RST, 1);
  }
  door_pause();
}

sub _atl_check_levelup {
  my ($p) = @_;
  # Every 500 exp, gain 10 max HP
  my $expected_hp = 30 + int($p->{exp} / 500) * 10;
  if ($expected_hp > $p->{max_hp}) {
    my $gain = $expected_hp - $p->{max_hp};
    $p->{max_hp} = $expected_hp;
    $p->{hp} += $gain;
    writeline($config{'usercolor'} . " Your endurance improves! +$gain max HP" . $RST, 1);
  }
}

