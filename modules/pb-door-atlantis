sub _atl_load_player {
  my $p = door_load($DOOR_NAME);
  return $p if $p;
  return _atl_new_player();
}

sub _atl_new_player {
  my $map = _atl_generate_map();
  return {
    gold         => $START_GOLD,
    oxygen       => $START_OXYGEN,
    max_oxygen   => $START_OXYGEN,
    hp           => 30,
    max_hp       => 30,
    exp          => 0,
    depth        => 1,
    max_depth    => 1,
    x            => int($MAP_SIZE / 2),
    y            => int($MAP_SIZE / 2),
    gear         => 0,
    weapon       => 0,
    tool         => 0,
    turns        => $TURNS_PER_DAY,
    artifacts    => [],
    explored     => {},
    map          => $map,
    dives        => 0,
    creatures_killed => 0,
    artifacts_found  => 0,
    atlantis_found   => 0,
    last_reset   => time(),
    created      => time(),
  };
}

sub _atl_daily_reset {
  my ($p) = @_;
  my $now = time();
  if (($now - ($p->{last_reset} // 0)) >= 86400) {
    $p->{turns}      = $TURNS_PER_DAY;
    $p->{hp}         = $p->{max_hp};
    $p->{oxygen}     = $p->{max_oxygen};
    $p->{last_reset} = $now;
    door_save($DOOR_NAME, $p);
  }
}

# ============================================================================
# MAP GENERATION
# ============================================================================

sub _atl_generate_map {
  my @map;
  for my $d (1 .. $MAX_DEPTH) {
    my @level;
    for my $y (0 .. $MAP_SIZE - 1) {
      my @row;
      for my $x (0 .. $MAP_SIZE - 1) {
        my $r = rand(100);
        my $tile;
        if ($d == 1) {
          # Shallow: mostly open water, some coral and kelp
          if    ($r < 50) { $tile = '~'; }
          elsif ($r < 70) { $tile = 'K'; }
          elsif ($r < 85) { $tile = '#'; }
          elsif ($r < 95) { $tile = 'R'; }
          else            { $tile = 'T'; }
        }
        elsif ($d <= 3) {
          # Mid depth: ruins, caves, treasure
          if    ($r < 35) { $tile = '~'; }
          elsif ($r < 50) { $tile = '#'; }
          elsif ($r < 65) { $tile = 'R'; }
          elsif ($r < 75) { $tile = 'C'; }
          elsif ($r < 88) { $tile = 'T'; }
          else            { $tile = 'V'; }
        }
        else {
          # Deep: more caves and vents, Atlantis gate at depth 5
          if    ($r < 25) { $tile = '~'; }
          elsif ($r < 40) { $tile = 'C'; }
          elsif ($r < 55) { $tile = 'V'; }
          elsif ($r < 70) { $tile = 'R'; }
          elsif ($r < 85) { $tile = 'T'; }
          else            { $tile = '#'; }
        }
        push @row, $tile;
      }
      push @level, \@row;
    }
    # Place Atlantis gate at max depth
    if ($d == $MAX_DEPTH) {
      my $ax = int(rand($MAP_SIZE));
      my $ay = int(rand($MAP_SIZE));
      $level[$ay][$ax] = 'A';
    }
    push @map, \@level;
  }
  return \@map;
}

