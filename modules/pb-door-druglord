  my $news = door_load_shared($DOOR_NAME, "news.dat") // { items => [] };
  push @{$news->{items}}, $msg;
  if (scalar @{$news->{items}} > 20) {
    splice @{$news->{items}}, 0, scalar(@{$news->{items}}) - 20;
  }
  door_save_shared($DOOR_NAME, "news.dat", $news);
}

