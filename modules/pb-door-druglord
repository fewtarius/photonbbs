sub _dl_jet {
  my ($g) = @_;

  # Show compact status header
  door_clear();
  my $loc_name = $LOCATIONS[$g->{location}]{name};
  my $net      = $g->{cash} + $g->{bank} - $g->{debt};
  my $space    = _dl_free_space($g);
  writeline($config{'themecolor'} . " DrugLord" .
    $config{'systemcolor'} . "  Day " . $config{'datacolor'} . "$g->{turn}" .
    $config{'systemcolor'} . " of " . $config{'datacolor'} . "$MAX_TURNS" .
    $config{'systemcolor'} . "  |  " . $config{'usercolor'} . $loc_name . $RST, 1);
  writeline($config{'systemcolor'} . " Cash: " . $config{'datacolor'} . door_money($g->{cash}) .
    $config{'systemcolor'} . "  Net: " . ($net >= 0 ? $config{'usercolor'} : $config{'errorcolor'}) . door_money($net) .
    $config{'systemcolor'} . "  Space: " . $config{'datacolor'} . "$space" .
    $config{'systemcolor'} . "  Health: " . _dl_health_color($g->{health}) . "$g->{health}%" . $RST, 1);
  door_hrule(60);
  writeline("", 1);
  writeline($config{'themecolor'} . "  Where to, man?" . $RST, 1);
  writeline("", 1);
  for my $i (0 .. $#LOCATIONS) {
    my $marker = ($i == $g->{location}) ? "*" : " ";
    my $extras = "";
    $extras .= " [Loan Shark]" if $i == $LOC_LOANSHARK;
    $extras .= " [Bank]"       if $i == $LOC_BANK && $i != $LOC_LOANSHARK;
    $extras .= " [Gun Shop]"   if $i == $LOC_GUNSHOP;
    $extras .= " [Pub]"        if $i == $LOC_PUB && $i != $LOC_GUNSHOP;
    # Combine if same location
    if ($i == $LOC_LOANSHARK && $i == $LOC_BANK) {
      $extras = " [Loan Shark] [Bank]";
    }
    if ($i == $LOC_GUNSHOP && $i == $LOC_PUB) {
      $extras = " [Gun Shop] [Pub]";
    }
    writeline(sprintf("  %s%d%s%s %-18s%s%s%s",
      $config{'promptcolor'}, $i + 1, $config{'themecolor'},
      $marker, $LOCATIONS[$i]{name},
      $config{'systemcolor'}, $extras,
      $RST), 1);
  }

  my $dest = door_getnum("Destination? (0 to stay)", scalar @LOCATIONS);
  if ($dest > 0) {
    $g->{location} = $dest - 1;
  }

  # Advance turn
  $g->{turn}++;

  # Interest on debt
  if ($g->{debt} > 0) {
    $g->{debt} = int($g->{debt} * (100 + $DEBT_INTEREST) / 100);
  }

  # Interest on bank
  if ($g->{bank} > 0) {
    $g->{bank} = int($g->{bank} * (100 + $BANK_INTEREST) / 100);
  }

  # Random: health recovery
  if ($g->{health} < 100 && rand(100) < 30) {
    my $heal = 5 + int(rand(15));
    $g->{health} += $heal;
    $g->{health} = 100 if $g->{health} > 100;
  }
}

