# ============================================================================
# MAIN ENTRY POINT
# ============================================================================

sub bigcatch_main {
  iamat($info{'handle'}, "Playing Big Catch");

  eval { require "$config{'home'}/modules/pb-doorlib"; } unless defined &door_load;

  my $save = door_load($DOOR_NAME) // {};
  my %game = (
    money          => $save->{money} // 200,
    rod_power      => $save->{rod_power} // 1,
    fish_finder    => $save->{fish_finder} // 0,
    total_caught   => $save->{total_caught} // 0,
    biggest        => $save->{biggest} // 0,
    species_caught => $save->{species_caught} // {},
    lifetime_money => $save->{lifetime_money} // 0,
    lures_owned    => $save->{lures_owned} // _bc_default_lures(),
    lake_idx   => -1,
    weather    => $WEATHER[int(rand(@WEATHER))],
    boat_y     => 0,
    boat_x     => 0,
    lake       => [],
    surface    => [],
    bottom     => [],
    fish       => [],
    livewell   => [],
    lure_type  => 0,
    lure_size  => 1,
    speed      => 2,
    lure_depth => 0,
    casting    => 0,
    quit       => 0,
  );

  door_show_messages($DOOR_NAME);
  _bc_title_screen(\%game);
  _bc_choose_lake(\%game);
  return if $game{quit};

  _bc_generate_lake(\%game);
  _bc_stock_lake(\%game);

  while (!$game{quit}) {
    _bc_display(\%game);
    _bc_command(\%game);
  }

  _bc_sell_catch(\%game) if @{$game{livewell}};

  door_save($DOOR_NAME, {
    money          => $game{money},
    rod_power      => $game{rod_power},
    fish_finder    => $game{fish_finder},
    total_caught   => $game{total_caught},
    biggest        => $game{biggest},
    species_caught => $game{species_caught},
    lifetime_money => $game{lifetime_money},
    lures_owned    => $game{lures_owned},
  });

  _bc_update_derby(\%game);
  iamat($info{'handle'}, "Finished Big Catch");
}

