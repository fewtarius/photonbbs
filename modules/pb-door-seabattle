#!/usr/bin/perl
#
# PhotonBBS Door: Sea Battle (Battleship)
# Based on the classic Battleship board game (Milton Bradley, 1967)
# Reference: SBBS Sea Battle (Synchronet BBS)
#
# Classic battleship game vs AI opponent
#

# ============================================================================
# GAME CONSTANTS
# ============================================================================

my $GRID_SIZE = 10;

my @SHIPS = (
  { name => "Carrier",    size => 5 },
  { name => "Battleship", size => 4 },
  { name => "Cruiser",    size => 3 },
  { name => "Submarine",  size => 3 },
  { name => "Destroyer",  size => 2 },
);

# Cell states
my $CELL_EMPTY  = ' ';
my $CELL_SHIP   = 'O';
my $CELL_HIT    = 'X';
my $CELL_MISS   = '-';
my $CELL_SUNK   = '#';

my $DOOR_NAME = "seabattle";

# ============================================================================
# MAIN ENTRY POINT
# ============================================================================

sub seabattle_main {
  iamat($info{'handle'}, "Playing Sea Battle");

  door_broker_connect($DOOR_NAME, "door-$DOOR_NAME-harbor");
  door_show_messages($DOOR_NAME);

  door_clear();
  writeline("", 1);
  writeline($config{'themecolor'} . "            S E A   B A T T L E" . $RST, 1);
  writeline($config{'linecolor'}  . "          -------------------------" . $RST, 1);
  writeline($config{'systemcolor'} . "    Classic Battleship - sink the enemy fleet!" . $RST, 1);
  writeline("", 1);

  # Check for incoming challenges
  _sb_check_challenges();

  # Show who else is in the harbor
  my @online = door_get_online_players($DOOR_NAME);
  if (@online) {
    my $others = join(", ", map { $config{'usercolor'} . $_ . $RST } @online);
    writeline($config{'datacolor'} . "  Also here: " . $others, 1);
    writeline("", 1);
  }

  # Show any incoming chat
  my @chat = door_chat_poll($DOOR_NAME);
  for my $m (@chat) {
    writeline($config{'linecolor'} . $m . $RST, 1);
  }

  # Check for waiting sessions (other players looking for opponents)
  my $sessions = door_session_list($DOOR_NAME);
  my @joinable = grep { lc($_->{host}) ne lc($info{'handle'}) } @$sessions;
  if (@joinable) {
    writeline($config{'usercolor'} . "  ** " . $joinable[0]{host} . " is waiting for a live battle! **" . $RST, 1);
    writeline("", 1);
  }

  my $mode = door_menu([
    ['A', 'Battle the AI'],
    ['C', 'Live Battle (vs human)'],
    ['W', 'Win/Loss Record'],
    ['H', 'High Scores'],
    ['T', 'Harbor Chat'],
    ['Q', 'Quit'],
  ], "Choose mode");

  if ($mode eq 'A') {
    _sb_play_ai();
  } elsif ($mode eq 'C') {
    _sb_challenge();
  } elsif ($mode eq 'W') {
    _sb_records();
    door_pause();
  } elsif ($mode eq 'H') {
    door_show_scores($DOOR_NAME, "Sea Battle High Scores", "Score");
    door_pause();
  } elsif ($mode eq 'T') {
    door_chat_input($DOOR_NAME);
  }

  door_broker_disconnect();
  iamat($info{'handle'}, "Finished Sea Battle");
}

sub _sb_check_challenges {
  my $msgs = door_get_messages($DOOR_NAME);
  return unless @$msgs;
  writeline("", 1);
  for my $m (@$msgs) {
    writeline($config{'usercolor'} . " Message from $m->{from}: " .
      $config{'datacolor'} . $m->{message} . $RST, 1);
  }
  door_mark_messages_read($DOOR_NAME);
  writeline("", 1);
}

sub _sb_records {
  door_header("Win/Loss Record");
  my @all = door_get_all_players($DOOR_NAME);
  writeline(sprintf("  %s%-20s %s%-6s %-6s%s",
    $config{'systemcolor'}, "Player", $config{'datacolor'}, "Wins", "Losses", $RST), 1);
  door_hrule(36);
  for my $name (@all) {
    my $pd = door_load_player($DOOR_NAME, $name);
    next unless $pd;
    my $color = ($name eq $info{'handle'}) ? $config{'usercolor'} : $config{'datacolor'};
    writeline(sprintf("  %s%-20s %s%-6d %-6d%s",
      $color, substr($name, 0, 20),
      $config{'datacolor'}, $pd->{wins} // 0, $pd->{losses} // 0, $RST), 1);
  }
  writeline("", 1);
}

sub _sb_challenge {
  # Check if there's a session waiting for us
  my $sessions = door_session_list($DOOR_NAME);
  my $join_session = undef;
  for my $s (@$sessions) {
    # Don't join our own sessions
    next if lc($s->{host}) eq lc($info{'handle'});
    $join_session = $s;
    last;
  }

  if ($join_session) {
    writeline("", 1);
    writeline($config{'usercolor'} . " $join_session->{host}" . $config{'systemcolor'} .
      " is waiting for an opponent!" . $RST, 1);
    if (door_yesno("Join their game?")) {
      my $session = door_session_join($DOOR_NAME, $join_session->{id});
      if ($session) {
        _sb_play_pvp($session, 1);  # player index 1 (joiner)
        return;
      }
      writeline($config{'errorcolor'} . " Couldn't join - game may have started." . $RST, 1);
    }
  }

  # Create a new session and wait
  writeline("", 1);
  writeline($config{'systemcolor'} . " Creating a live battle session..." . $RST, 1);
  writeline($config{'systemcolor'} . " Another player must join from the Sea Battle menu." . $RST, 1);
  writeline($config{'datacolor'} . " Press A to fill with AI, Q to cancel." . $RST, 1);
  writeline("", 1);

  my $session = door_session_create($DOOR_NAME, { max_players => 2 });
  unless ($session) {
    writeline($config{'errorcolor'} . " Couldn't create session." . $RST, 1);
    door_pause();
    return;
  }

  my $result = door_session_wait($DOOR_NAME, $session->{id}, {
    timeout => 60, max_cycles => 3,
  });

  unless ($result) {
    writeline($config{'systemcolor'} . " Game cancelled." . $RST, 1);
    door_pause();
    return;
  }

  if (scalar @{$result->{players}} < 2) {
    # Fill with AI
    writeline($config{'systemcolor'} . " No opponent found. Filling with AI." . $RST, 1);
    door_session_destroy($DOOR_NAME, $session->{id});
    _sb_play_ai();
    return;
  }

  _sb_play_pvp($result, 0);  # player index 0 (host)
}

# Real-time PvP battle using broker + session file fallback
sub _sb_play_pvp {
  my ($session, $my_idx) = @_;
  my $opp_idx = $my_idx == 0 ? 1 : 0;
  my $opp_name = $session->{players}[$opp_idx]{name};
  my $session_id = $session->{id};

  iamat($info{'handle'}, "Sea Battle vs $opp_name");

  # Join game-specific broker room for fast sync
  door_game_room_join($DOOR_NAME, $session_id);

  door_clear();
  writeline("", 1);
  writeline($config{'themecolor'} . " Live Sea Battle!" . $RST, 1);
  writeline($config{'systemcolor'} . " You vs " . $config{'usercolor'} . $opp_name . $RST, 1);
  writeline("", 1);

  # Initialize local game state
  my %game;
  $game{player_grid}  = _sb_empty_grid();
  $game{player_shots} = _sb_empty_grid();
  $game{enemy_shots}  = _sb_empty_grid();
  $game{player_ships} = [];
  $game{turn}         = 0;

  # Place ships
  _sb_place_ships_player(\%game);

  # Serialize our ship positions into the session (as ship cell lists only)
  my @ship_cells;
  for my $ship (@{$game{player_ships}}) {
    push @ship_cells, { name => $ship->{name}, size => $ship->{size}, cells => $ship->{cells}, hits => 0 };
  }

  # Store our grid in session under our player index
  my $grid_key = "p${my_idx}_grid";
  my $ships_key = "p${my_idx}_ships";
  my $init_state = {
    %{$session->{game_state} // {}},
    $grid_key  => $game{player_grid},
    $ships_key => \@ship_cells,
    "p${my_idx}_ready" => 1,
    current_turn => 0,
    "p0_shots" => _sb_empty_grid(),
    "p1_shots" => _sb_empty_grid(),
  };
  door_session_update($DOOR_NAME, $session_id, { game_state => $init_state });
  # Broadcast ready state via broker
  door_game_state_send($DOOR_NAME, { ready => $my_idx });

  # Wait for opponent to be ready (broker + file polling)
  writeline($config{'systemcolor'} . " Waiting for $opp_name to place ships..." . $RST, 1);
  my $ready = 0;
  my $wait_start = time();
  while (!$ready && (time() - $wait_start) < 180) {
    # Check broker first (fast)
    my ($states, $chats) = door_game_state_recv($DOOR_NAME);
    for my $s (@$states) {
      if (defined $s->{ready} && $s->{ready} == $opp_idx) {
        $ready = 1;
        last;
      }
    }
    last if $ready;

    # Fall back to session file (slower but reliable)
    my $s = door_session_poll($DOOR_NAME, $session_id);
    unless ($s) {
      writeline($config{'errorcolor'} . " Session lost!" . $RST, 1);
      door_pause();
      return;
    }
    $ready = $s->{game_state}{"p${opp_idx}_ready"} // 0;
    writeline("\r" . $config{'systemcolor'} . " Waiting... " . (time() - $wait_start) . "s " . $RST, 0) unless $ready;
    select(undef, undef, undef, 1) unless $ready;
  }

  unless ($ready) {
    writeline("", 1);
    writeline($config{'errorcolor'} . " Opponent timed out." . $RST, 1);
    door_session_destroy($DOOR_NAME, $session_id);
    door_pause();
    return;
  }

  writeline("", 1);
  writeline($config{'usercolor'} . " Both fleets deployed! Battle stations!" . $RST, 1);
  door_pause("Press any key to begin...");

  # Main PvP loop
  my $game_over = 0;
  while (!$game_over) {
    my $s = door_session_poll($DOOR_NAME, $session_id);
    unless ($s) {
      writeline($config{'errorcolor'} . " Session lost!" . $RST, 1);
      last;
    }
    my $gs = $s->{game_state};
    my $current_turn = $gs->{current_turn} // 0;

    # Update our view: opponent's shots at us
    $game{enemy_shots} = $gs->{"p${opp_idx}_shots"} // _sb_empty_grid();
    # Update our view: our shots at opponent
    $game{player_shots} = $gs->{"p${my_idx}_shots"} // _sb_empty_grid();

    # Build enemy ships for display (tracking hits from our shots)
    my $opp_ships = $gs->{"p${opp_idx}_ships"} // [];
    my @display_enemy_ships;
    for my $ship (@$opp_ships) {
      my $hits = 0;
      for my $cell (@{$ship->{cells}}) {
        my $shot = $game{player_shots}[$cell->[0]][$cell->[1]];
        $hits++ if $shot eq $CELL_HIT || $shot eq $CELL_SUNK;
      }
      push @display_enemy_ships, { name => $ship->{name}, size => $ship->{size}, cells => $ship->{cells}, hits => $hits };
    }

    # Display board
    _sb_pvp_display(\%game, $opp_name, $current_turn == $my_idx);

    if ($current_turn == $my_idx) {
      # Our turn - fire
      my $result = _sb_pvp_fire(\%game, $gs, $my_idx, $opp_idx);
      last if $result eq 'quit';

      # Update session and broadcast via broker
      my $new_gs = {
        %$gs,
        "p${my_idx}_shots" => $game{player_shots},
        current_turn => $opp_idx,
      };
      door_session_update($DOOR_NAME, $session_id, { game_state => $new_gs });
      door_game_state_send($DOOR_NAME, {
        type => 'shot',
        shooter => $my_idx,
        shots => $game{player_shots},
        current_turn => $opp_idx,
      });

      $game{turn}++;

      # Check if we won (all opponent ships sunk)
      if (_sb_pvp_all_sunk($opp_ships, $game{player_shots})) {
        _sb_pvp_display(\%game, $opp_name, 0);
        writeline($config{'usercolor'} . " You sank $opp_name's entire fleet! VICTORY!" . $RST, 1);
        my $score = 1000 - ($game{turn} * 10);
        $score = 100 if $score < 100;
        door_submit_score($DOOR_NAME, $score, { shots => $game{turn}, vs => $opp_name });
        door_log_activity($DOOR_NAME, "$info{'handle'} defeated $opp_name in Sea Battle!");
        door_broadcast($DOOR_NAME, "$info{'handle'} defeated $opp_name in live Sea Battle!");
        my $record = door_load($DOOR_NAME) // { wins => 0, losses => 0 };
        $record->{wins}++;
        door_save($DOOR_NAME, $record);
        door_session_update($DOOR_NAME, $session_id, {
          game_state => { %$gs, winner => $my_idx, game_over => 1 },
        });
        door_game_state_send($DOOR_NAME, { type => 'game_over', winner => $my_idx });
        $game_over = 1;
      }
    } else {
      # Opponent's turn - wait using broker + file polling
      writeline($config{'systemcolor'} . " Waiting for $opp_name to fire..." . $RST, 0);
      my $wait_start = time();
      my $turn_changed = 0;
      while (!$turn_changed && (time() - $wait_start) < 120) {
        # Check broker first (fast - sub-second)
        my ($states, $chats) = door_game_state_recv($DOOR_NAME);
        for my $bs (@$states) {
          if ($bs->{type} && $bs->{type} eq 'game_over') {
            writeline("", 1);
            if (($bs->{winner} // -1) == $opp_idx) {
              writeline($config{'errorcolor'} . " $opp_name has sunk your fleet! DEFEAT!" . $RST, 1);
              my $record = door_load($DOOR_NAME) // { wins => 0, losses => 0 };
              $record->{losses}++;
              door_save($DOOR_NAME, $record);
            }
            $game_over = 1;
            $turn_changed = 1;
            last;
          }
          if ($bs->{type} && $bs->{type} eq 'shot' && $bs->{current_turn} == $my_idx) {
            $game{enemy_shots} = $bs->{shots} if $bs->{shots};
            $turn_changed = 1;
            writeline("", 1);
            # Check if we lost
            if (_sb_pvp_all_sunk($game{player_ships}, $game{enemy_shots})) {
              _sb_pvp_display(\%game, $opp_name, 0);
              writeline($config{'errorcolor'} . " $opp_name has sunk your fleet! DEFEAT!" . $RST, 1);
              my $record = door_load($DOOR_NAME) // { wins => 0, losses => 0 };
              $record->{losses}++;
              door_save($DOOR_NAME, $record);
              $game_over = 1;
            }
            last;
          }
        }
        last if $turn_changed;

        # Show chat
        for my $c (@$chats) {
          writeline($config{'linecolor'} . " $c" . $RST, 1);
        }

        # Fall back to session file every 2 seconds
        select(undef, undef, undef, 1);
        my $s2 = door_session_poll($DOOR_NAME, $session_id);
        unless ($s2) {
          writeline("", 1);
          writeline($config{'errorcolor'} . " Session lost!" . $RST, 1);
          $game_over = 1;
          last;
        }
        my $gs2 = $s2->{game_state};

        if ($gs2->{game_over}) {
          writeline("", 1);
          if (($gs2->{winner} // -1) == $opp_idx) {
            writeline($config{'errorcolor'} . " $opp_name has sunk your fleet! DEFEAT!" . $RST, 1);
            my $record = door_load($DOOR_NAME) // { wins => 0, losses => 0 };
            $record->{losses}++;
            door_save($DOOR_NAME, $record);
          }
          $game_over = 1;
          last;
        }

        if (($gs2->{current_turn} // 0) == $my_idx) {
          $turn_changed = 1;
          $game{enemy_shots} = $gs2->{"p${opp_idx}_shots"} // _sb_empty_grid();
          writeline("", 1);
          if (_sb_pvp_all_sunk($game{player_ships}, $game{enemy_shots})) {
            _sb_pvp_display(\%game, $opp_name, 0);
            writeline($config{'errorcolor'} . " $opp_name has sunk your fleet! DEFEAT!" . $RST, 1);
            my $record = door_load($DOOR_NAME) // { wins => 0, losses => 0 };
            $record->{losses}++;
            door_save($DOOR_NAME, $record);
            $game_over = 1;
          }
        }
      }

      unless ($turn_changed || $game_over) {
        writeline("", 1);
        writeline($config{'errorcolor'} . " Opponent timed out. Game cancelled." . $RST, 1);
        $game_over = 1;
      }
    }
  }

  door_session_destroy($DOOR_NAME, $session_id);
  writeline("", 1);
  door_pause("Press any key to continue...");
}

# PvP display - same as AI display but with opponent name
sub _sb_pvp_display {
  my ($g, $opp_name, $my_turn) = @_;
  door_clear();
  my $turn_indicator = $my_turn ? $config{'usercolor'} . "YOUR TURN" : $config{'systemcolor'} . "Waiting...";
  writeline($config{'themecolor'} . " Sea Battle vs " . $config{'usercolor'} . $opp_name .
    "  " . $turn_indicator . $RST, 1);
  writeline("", 1);

  # Show both grids side by side (reuse existing display logic)
  my $_sb_h12 = boxchar('horizontal') x 12;
  writeline($config{'themecolor'} .
    "  " . boxchar('topleft') . $_sb_h12 . boxchar('topright') .
    "    " .
    boxchar('topleft') . $_sb_h12 . boxchar('topright') . $RST, 1);
  writeline($config{'themecolor'} .
    "  " . boxchar('vertical') . " Your Fleet " . boxchar('vertical') .
    "    " .
    boxchar('vertical') . " $opp_name    " . boxchar('vertical') . $RST, 1);
  writeline($config{'linecolor'} .
    "  " . boxchar('tright') . $_sb_h12 . boxchar('tleft') .
    "    " .
    boxchar('tright') . $_sb_h12 . boxchar('tleft') . $RST, 1);
  writeline($config{'systemcolor'} . "   " . "1234567890" . "             " . "1234567890" . $RST, 1);

  for my $y (0 .. $GRID_SIZE - 1) {
    my $row_label = chr(ord('A') + $y);
    my $left = $config{'systemcolor'} . " $row_label " . $RST;
    for my $x (0 .. $GRID_SIZE - 1) {
      my $cell = $g->{player_grid}[$y][$x];
      if ($g->{enemy_shots}[$y][$x] eq $CELL_HIT) {
        $left .= $config{'errorcolor'} . "X" . $RST;
      } elsif ($g->{enemy_shots}[$y][$x] eq $CELL_MISS) {
        $left .= $config{'linecolor'} . "-" . $RST;
      } elsif ($cell eq $CELL_SHIP) {
        $left .= $config{'usercolor'} . "O" . $RST;
      } else {
        $left .= $config{'linecolor'} . "." . $RST;
      }
    }
    $left .= "       ";
    $left .= $config{'systemcolor'} . " $row_label " . $RST;
    for my $x (0 .. $GRID_SIZE - 1) {
      my $shot = $g->{player_shots}[$y][$x];
      if ($shot eq $CELL_HIT) {
        $left .= $config{'errorcolor'} . "X" . $RST;
      } elsif ($shot eq $CELL_SUNK) {
        $left .= $config{'usercolor'} . "#" . $RST;
      } elsif ($shot eq $CELL_MISS) {
        $left .= $config{'linecolor'} . "-" . $RST;
      } else {
        $left .= $config{'linecolor'} . "." . $RST;
      }
    }
    writeline($left, 1);
  }
  writeline("", 1);
  _sb_show_ship_status($g->{player_ships}, "Your ships");
}

# Fire at opponent in PvP mode
sub _sb_pvp_fire {
  my ($g, $gs, $my_idx, $opp_idx) = @_;

  writeline($config{'promptcolor'} . " Fire at (e.g. A5, Q to quit): " . $RST);
  my $input = getline(text, 4, "", 1);
  chomp $input;
  return 'quit' if uc($input) eq 'Q';

  my ($ty, $tx) = _sb_parse_coord(uc($input));
  if ($ty < 0) {
    writeline($config{'errorcolor'} . " Invalid coordinate." . $RST, 1);
    door_pause();
    return 'invalid';
  }

  if ($g->{player_shots}[$ty][$tx] ne $CELL_EMPTY) {
    writeline($config{'systemcolor'} . " Already fired there." . $RST, 1);
    door_pause();
    return 'repeat';
  }

  # Check opponent's grid
  my $opp_grid = $gs->{"p${opp_idx}_grid"} // _sb_empty_grid();
  my $opp_ships = $gs->{"p${opp_idx}_ships"} // [];

  if ($opp_grid->[$ty][$tx] eq $CELL_SHIP) {
    $g->{player_shots}[$ty][$tx] = $CELL_HIT;
    my $sunk_name = "";
    for my $ship (@$opp_ships) {
      for my $cell (@{$ship->{cells}}) {
        if ($cell->[0] == $ty && $cell->[1] == $tx) {
          $ship->{hits}++;
          if ($ship->{hits} >= $ship->{size}) {
            $sunk_name = $ship->{name};
            for my $c (@{$ship->{cells}}) {
              $g->{player_shots}[$c->[0]][$c->[1]] = $CELL_SUNK;
            }
          }
          last;
        }
      }
    }
    if ($sunk_name) {
      writeline($config{'usercolor'} . " HIT! You sank their $sunk_name!" . $RST, 1);
    } else {
      writeline($config{'usercolor'} . " HIT!" . $RST, 1);
    }
  } else {
    $g->{player_shots}[$ty][$tx] = $CELL_MISS;
    writeline($config{'systemcolor'} . " Miss." . $RST, 1);
  }

  return 'ok';
}

# Check if all ships are sunk (PvP version - checks shot grid against ship cells)
sub _sb_pvp_all_sunk {
  my ($ships, $shots) = @_;
  for my $ship (@$ships) {
    my $hits = 0;
    for my $cell (@{$ship->{cells}}) {
      my $shot = $shots->[$cell->[0]][$cell->[1]];
      $hits++ if $shot eq $CELL_HIT || $shot eq $CELL_SUNK;
    }
    return 0 if $hits < $ship->{size};
  }
  return 1;
}

sub _sb_play_ai {

  # Initialize grids
  my %game;
  $game{player_grid}  = _sb_empty_grid();   # Player's ships
  $game{player_shots} = _sb_empty_grid();   # Player's shots at enemy
  $game{enemy_grid}   = _sb_empty_grid();   # Enemy's ships
  $game{enemy_shots}  = _sb_empty_grid();   # Enemy's shots at player
  $game{player_ships} = [];
  $game{enemy_ships}  = [];
  $game{ai_mode}      = 'hunt';  # hunt or destroy
  $game{ai_hits}      = [];      # Recent hits in destroy mode
  $game{ai_dir}       = undef;   # Direction AI is exploring
  $game{turn}         = 0;

  # Place ships
  _sb_place_ships_player(\%game);
  _sb_place_ships_ai(\%game);

  # Main game loop
  my $game_over = 0;
  while (!$game_over) {
    _sb_display(\%game);

    # Player's turn
    my $result = _sb_player_fire(\%game);
    last if $result eq 'quit';
    $game{turn}++;

    # Check win
    if (_sb_all_sunk($game{enemy_ships})) {
      _sb_display(\%game);
      writeline($config{'usercolor'} . " You sank the entire enemy fleet! VICTORY!" . $RST, 1);
      writeline($config{'systemcolor'} . " Completed in $game{turn} shots." . $RST, 1);

      my $score = 1000 - ($game{turn} * 10);
      $score = 100 if $score < 100;
      door_submit_score($DOOR_NAME, $score, { shots => $game{turn} });
      door_log_activity($DOOR_NAME, $info{'handle'} . " won Sea Battle in $game{turn} shots!");
      # Track wins
      my $record = door_load($DOOR_NAME) // { wins => 0, losses => 0 };
      $record->{wins}++;
      door_save($DOOR_NAME, $record);
      $game_over = 1;
      last;
    }

    # AI's turn
    _sb_ai_fire(\%game);

    # Check loss
    if (_sb_all_sunk($game{player_ships})) {
      _sb_display(\%game);
      writeline($config{'errorcolor'} . " The enemy has sunk your fleet! DEFEAT!" . $RST, 1);
      my $record = door_load($DOOR_NAME) // { wins => 0, losses => 0 };
      $record->{losses}++;
      door_save($DOOR_NAME, $record);
      $game_over = 1;
      last;
    }
  }

  writeline("", 1);
  if (door_yesno("View high scores?")) {
    door_show_scores($DOOR_NAME, "Sea Battle High Scores", "Score");
  }
  door_pause("Press any key to return to the BBS...");
  iamat($info{'handle'}, "Finished Sea Battle");
}

# ============================================================================
# GRID MANAGEMENT
# ============================================================================

sub _sb_empty_grid {
  my @grid;
  for my $y (0 .. $GRID_SIZE - 1) {
    for my $x (0 .. $GRID_SIZE - 1) {
      $grid[$y][$x] = $CELL_EMPTY;
    }
  }
  return \@grid;
}

# ============================================================================
# SHIP PLACEMENT - PLAYER
# ============================================================================

sub _sb_place_ships_player {
  my ($g) = @_;

  writeline("", 1);
  writeline($config{'themecolor'} . " Place your fleet!" . $RST, 1);
  writeline($config{'systemcolor'} . " Use coordinates like A5 and direction H(orizontal)/V(ertical)" . $RST, 1);
  writeline("", 1);

  for my $ship (@SHIPS) {
    my $placed = 0;
    while (!$placed) {
      _sb_show_grid($g->{player_grid}, "Your Fleet", 1);
      writeline($config{'promptcolor'} . " Place $ship->{name} ($ship->{size} spaces)" . $RST, 1);
      writeline($config{'promptcolor'} . " Position (e.g. A5): " . $RST);
      my $pos = getline(text, 4, "", 1);
      chomp $pos;
      $pos = uc($pos);

      my ($py, $px) = _sb_parse_coord($pos);
      if ($py < 0) {
        writeline($config{'errorcolor'} . " Invalid coordinate." . $RST, 1);
        next;
      }

      writeline($config{'promptcolor'} . " Direction [H]orizontal/[V]ertical: " . $RST);
      my $dir = uc(waitkey("H"));
      writeline("", 1);
      my $horiz = ($dir eq 'H') ? 1 : 0;

      if (_sb_can_place($g->{player_grid}, $py, $px, $ship->{size}, $horiz)) {
        my @cells;
        for my $i (0 .. $ship->{size} - 1) {
          my $cy = $horiz ? $py : $py + $i;
          my $cx = $horiz ? $px + $i : $px;
          $g->{player_grid}[$cy][$cx] = $CELL_SHIP;
          push @cells, [$cy, $cx];
        }
        push @{$g->{player_ships}}, { name => $ship->{name}, size => $ship->{size}, cells => \@cells, hits => 0 };
        $placed = 1;
      } else {
        writeline($config{'errorcolor'} . " Can't place there - out of bounds or overlapping." . $RST, 1);
      }
    }
  }
}

sub _sb_parse_coord {
  my ($str) = @_;
  return (-1, -1) unless $str =~ /^([A-J])(\d{1,2})$/i;
  my $y = ord(uc($1)) - ord('A');
  my $x = $2 - 1;
  return (-1, -1) if $y < 0 || $y >= $GRID_SIZE || $x < 0 || $x >= $GRID_SIZE;
  return ($y, $x);
}

sub _sb_can_place {
  my ($grid, $y, $x, $size, $horiz) = @_;
  for my $i (0 .. $size - 1) {
    my $cy = $horiz ? $y : $y + $i;
    my $cx = $horiz ? $x + $i : $x;
    return 0 if $cy >= $GRID_SIZE || $cx >= $GRID_SIZE;
    return 0 if $grid->[$cy][$cx] ne $CELL_EMPTY;
  }
  return 1;
}

# ============================================================================
# SHIP PLACEMENT - AI
# ============================================================================

sub _sb_place_ships_ai {
  my ($g) = @_;
  for my $ship (@SHIPS) {
    my $placed = 0;
    while (!$placed) {
      my $y = int(rand($GRID_SIZE));
      my $x = int(rand($GRID_SIZE));
      my $horiz = int(rand(2));
      if (_sb_can_place($g->{enemy_grid}, $y, $x, $ship->{size}, $horiz)) {
        my @cells;
        for my $i (0 .. $ship->{size} - 1) {
          my $cy = $horiz ? $y : $y + $i;
          my $cx = $horiz ? $x + $i : $x;
          $g->{enemy_grid}[$cy][$cx] = $CELL_SHIP;
          push @cells, [$cy, $cx];
        }
        push @{$g->{enemy_ships}}, { name => $ship->{name}, size => $ship->{size}, cells => \@cells, hits => 0 };
        $placed = 1;
      }
    }
  }
}

# ============================================================================
# DISPLAY
# ============================================================================

sub _sb_display {
  my ($g) = @_;
  door_clear();
  writeline($config{'themecolor'} . " Sea Battle" . $config{'systemcolor'} . "  Turn: " .
    $config{'datacolor'} . $g->{turn} . $RST, 1);
  writeline("", 1);

  # Show both grids side by side
  my $_sb_h10 = boxchar('horizontal') x 10;
  my $_sb_h12 = boxchar('horizontal') x 12;
  writeline($config{'themecolor'} .
    "  " . boxchar('topleft') . $_sb_h12 . boxchar('topright') .
    "    " .
    boxchar('topleft') . $_sb_h12 . boxchar('topright') . $RST, 1);
  writeline($config{'themecolor'} .
    "  " . boxchar('vertical') . " Your Fleet " . boxchar('vertical') .
    "    " .
    boxchar('vertical') . " Enemy Waters" . boxchar('vertical') . $RST, 1);
  writeline($config{'linecolor'} .
    "  " . boxchar('tright') . $_sb_h12 . boxchar('tleft') .
    "    " .
    boxchar('tright') . $_sb_h12 . boxchar('tleft') . $RST, 1);
  writeline($config{'systemcolor'} . "   " . "1234567890" . "             " . "1234567890" . $RST, 1);

  for my $y (0 .. $GRID_SIZE - 1) {
    my $row_label = chr(ord('A') + $y);
    my $left = $config{'systemcolor'} . " $row_label " . $RST;
    for my $x (0 .. $GRID_SIZE - 1) {
      my $cell = $g->{player_grid}[$y][$x];
      # Show enemy shots on our grid
      if ($g->{enemy_shots}[$y][$x] eq $CELL_HIT) {
        $left .= $config{'errorcolor'} . "X" . $RST;
      } elsif ($g->{enemy_shots}[$y][$x] eq $CELL_MISS) {
        $left .= $config{'linecolor'} . "-" . $RST;
      } elsif ($cell eq $CELL_SHIP) {
        $left .= $config{'usercolor'} . "O" . $RST;
      } else {
        $left .= $config{'linecolor'} . "." . $RST;
      }
    }

    $left .= "       ";
    $left .= $config{'systemcolor'} . " $row_label " . $RST;

    for my $x (0 .. $GRID_SIZE - 1) {
      my $shot = $g->{player_shots}[$y][$x];
      if ($shot eq $CELL_HIT) {
        $left .= $config{'errorcolor'} . "X" . $RST;
      } elsif ($shot eq $CELL_SUNK) {
        $left .= $config{'usercolor'} . "#" . $RST;
      } elsif ($shot eq $CELL_MISS) {
        $left .= $config{'linecolor'} . "-" . $RST;
      } else {
        $left .= $config{'linecolor'} . "." . $RST;
      }
    }
    writeline($left, 1);
  }
  writeline("", 1);

  # Ship status
  _sb_show_ship_status($g->{player_ships}, "Your ships");
}

sub _sb_show_grid {
  my ($grid, $title, $show_ships) = @_;
  writeline("", 1);
  writeline($config{'themecolor'} . " $title" . $RST, 1);
  writeline($config{'systemcolor'} . "   1234567890" . $RST, 1);
  for my $y (0 .. $GRID_SIZE - 1) {
    my $row = $config{'systemcolor'} . " " . chr(ord('A') + $y) . " " . $RST;
    for my $x (0 .. $GRID_SIZE - 1) {
      my $cell = $grid->[$y][$x];
      if ($cell eq $CELL_SHIP && $show_ships) {
        $row .= $config{'usercolor'} . "O" . $RST;
      } else {
        $row .= $config{'linecolor'} . "." . $RST;
      }
    }
    writeline($row, 1);
  }
}

sub _sb_show_ship_status {
  my ($ships, $label) = @_;
  writeline($config{'systemcolor'} . " $label:" . $RST, 1);
  for my $ship (@$ships) {
    my $sunk = ($ship->{hits} >= $ship->{size});
    my $color = $sunk ? $config{'errorcolor'} : $config{'usercolor'};
    my $status = $sunk ? "SUNK" : "$ship->{hits}/$ship->{size} hit";
    writeline("  " . $color . sprintf("%-12s %s", $ship->{name}, $status) . $RST, 1);
  }
}

# ============================================================================
# PLAYER FIRE
# ============================================================================

sub _sb_player_fire {
  my ($g) = @_;

  writeline($config{'promptcolor'} . " Fire at (e.g. A5, Q to quit): " . $RST);
  my $input = getline(text, 4, "", 1);
  chomp $input;
  return 'quit' if uc($input) eq 'Q';

  my ($ty, $tx) = _sb_parse_coord(uc($input));
  if ($ty < 0) {
    writeline($config{'errorcolor'} . " Invalid coordinate." . $RST, 1);
    door_pause();
    return 'invalid';
  }

  if ($g->{player_shots}[$ty][$tx] ne $CELL_EMPTY) {
    writeline($config{'systemcolor'} . " Already fired there." . $RST, 1);
    door_pause();
    return 'repeat';
  }

  if ($g->{enemy_grid}[$ty][$tx] eq $CELL_SHIP) {
    $g->{player_shots}[$ty][$tx] = $CELL_HIT;
    # Check which ship was hit
    my $sunk_name = "";
    for my $ship (@{$g->{enemy_ships}}) {
      for my $cell (@{$ship->{cells}}) {
        if ($cell->[0] == $ty && $cell->[1] == $tx) {
          $ship->{hits}++;
          if ($ship->{hits} >= $ship->{size}) {
            $sunk_name = $ship->{name};
            # Mark all cells as sunk
            for my $c (@{$ship->{cells}}) {
              $g->{player_shots}[$c->[0]][$c->[1]] = $CELL_SUNK;
            }
          }
          last;
        }
      }
    }
    if ($sunk_name) {
      writeline($config{'usercolor'} . " HIT! You sank the $sunk_name!" . $RST, 1);
    } else {
      writeline($config{'usercolor'} . " HIT!" . $RST, 1);
    }
  } else {
    $g->{player_shots}[$ty][$tx] = $CELL_MISS;
    writeline($config{'systemcolor'} . " Miss." . $RST, 1);
  }

  return 'ok';
}

# ============================================================================
# AI FIRE (Hunt and Destroy)
# ============================================================================

sub _sb_ai_fire {
  my ($g) = @_;

  my ($ty, $tx);

  if ($g->{ai_mode} eq 'destroy' && @{$g->{ai_hits}}) {
    # Destroy mode: fire adjacent to known hits
    ($ty, $tx) = _sb_ai_destroy_target($g);
    if ($ty < 0) {
      # Couldn't find a target, switch to hunt
      $g->{ai_mode} = 'hunt';
      $g->{ai_hits} = [];
    }
  }

  if ($g->{ai_mode} eq 'hunt' || $ty < 0) {
    # Hunt mode: random checkerboard pattern
    my $attempts = 0;
    do {
      $ty = int(rand($GRID_SIZE));
      $tx = int(rand($GRID_SIZE));
      $attempts++;
      # Checkerboard pattern for efficiency
      if (($ty + $tx) % 2 != 0 && $attempts < 50) {
        $ty = -1;
        next;
      }
    } while ($ty < 0 || $g->{enemy_shots}[$ty][$tx] ne $CELL_EMPTY);
  }

  # Fire
  if ($g->{player_grid}[$ty][$tx] eq $CELL_SHIP) {
    $g->{enemy_shots}[$ty][$tx] = $CELL_HIT;
    my $sunk_name = "";
    for my $ship (@{$g->{player_ships}}) {
      for my $cell (@{$ship->{cells}}) {
        if ($cell->[0] == $ty && $cell->[1] == $tx) {
          $ship->{hits}++;
          if ($ship->{hits} >= $ship->{size}) {
            $sunk_name = $ship->{name};
            # Clear AI tracking for this ship
            $g->{ai_hits} = [grep { !_sb_cell_in_ship($_, $ship) } @{$g->{ai_hits}}];
            $g->{ai_mode} = 'hunt' if @{$g->{ai_hits}} == 0;
          }
          last;
        }
      }
    }
    push @{$g->{ai_hits}}, [$ty, $tx];
    $g->{ai_mode} = 'destroy';

    my $coord = chr(ord('A') + $ty) . ($tx + 1);
    if ($sunk_name) {
      writeline($config{'errorcolor'} . " Enemy fires at $coord - HIT! Your $sunk_name is sunk!" . $RST, 1);
    } else {
      writeline($config{'errorcolor'} . " Enemy fires at $coord - HIT!" . $RST, 1);
    }
  } else {
    $g->{enemy_shots}[$ty][$tx] = $CELL_MISS;
    my $coord = chr(ord('A') + $ty) . ($tx + 1);
    writeline($config{'systemcolor'} . " Enemy fires at $coord - miss." . $RST, 1);
  }
  door_pause();
}

sub _sb_ai_destroy_target {
  my ($g) = @_;
  # Try adjacent cells to known hits
  my @dirs = ([0,1],[0,-1],[1,0],[-1,0]);
  for my $hit (@{$g->{ai_hits}}) {
    for my $dir (@dirs) {
      my $ny = $hit->[0] + $dir->[0];
      my $nx = $hit->[1] + $dir->[1];
      next if $ny < 0 || $ny >= $GRID_SIZE || $nx < 0 || $nx >= $GRID_SIZE;
      next if $g->{enemy_shots}[$ny][$nx] ne $CELL_EMPTY;
      return ($ny, $nx);
    }
  }
  return (-1, -1);
}

sub _sb_cell_in_ship {
  my ($cell, $ship) = @_;
  for my $c (@{$ship->{cells}}) {
    return 1 if $c->[0] == $cell->[0] && $c->[1] == $cell->[1];
  }
  return 0;
}

sub _sb_all_sunk {
  my ($ships) = @_;
  for my $ship (@$ships) {
    return 0 if $ship->{hits} < $ship->{size};
  }
  return 1;
}

