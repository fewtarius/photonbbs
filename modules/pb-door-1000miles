sub _mb_setup {
  door_clear();
  writeline("", 1);
  writeline($config{'themecolor'} . "            1 0 0 0   M I L E S" . $RST, 1);
  writeline($config{'linecolor'}  . "       =============================" . $RST, 1);
  writeline("", 1);
  writeline($config{'systemcolor'} . "  The classic road racing card game." . $RST, 1);
  writeline($config{'systemcolor'} . "  First to reach 1000 km wins!" . $RST, 1);
  writeline("", 1);

  # Show saved stats
  my $save = door_load($DOOR_NAME);
  if ($save && $save->{hands_played}) {
    writeline($config{'systemcolor'} . "  Record: " .
      $config{'datacolor'} . "$save->{hands_won} wins" .
      $config{'systemcolor'} . " in " .
      $config{'datacolor'} . "$save->{hands_played} hands" .
      $config{'systemcolor'} . " (" .
      $config{'datacolor'} . "$save->{total} pts)" . $RST, 1);
    writeline("", 1);
  }

  writeline($config{'themecolor'} . " How many players? (2-4)" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "2" . $config{'themecolor'} .
    " ... " . $config{'usercolor'} . "You vs 1 opponent" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "3" . $config{'themecolor'} .
    " ... " . $config{'usercolor'} . "You vs 2 opponents" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "4" . $config{'themecolor'} .
    " ... " . $config{'usercolor'} . "You vs 3 opponents" . $RST, 1);
  writeline("  " . $config{'promptcolor'} . "Q" . $config{'themecolor'} .
    " ... " . $config{'usercolor'} . "Quit" . $RST, 1);
  writeline("", 1);
  writeline($config{'promptcolor'} . " > " . $RST);
  my $ch = uc(waitkey("")); writeline("", 1);

  return 0 if $ch eq 'Q';
  my $np = int($ch || 2);
  $np = 2 if $np < 2;
  $np = 4 if $np > 4;
  return $np;
}

# ============================================================================
# MAIN GAME LOOP
# ============================================================================

sub onek_miles_main {
  iamat($info{'handle'}, "Playing 1000 Miles");

  my $num_players = _mb_setup();
  unless ($num_players) {
    iamat($info{'handle'}, "Finished 1000 Miles");
    return;
  }

  my %game = _mb_init_game($num_players, 1);
  my $playing = 1;

  while ($playing && !$game{quit}) {
    $game{finished} = 0;
    $game{last_action} = "";

    while (!$game{finished} && !$game{quit}) {
      my $pi = $game{turn};
      my $p = $game{players}[$pi];

      # Clear new_battle/new_speed flags
      $p->{new_battle} = 0;
      $p->{new_speed} = 0;

      if ($p->{type} eq 'human') {
        _mb_do_human_turn(\%game, $pi);
      } else {
        # Show board before AI move so player sees state
        if ($pi == ($game{human_idx} + 1) % scalar @{$game{players}}) {
          # Only pause on first AI after human
          _mb_show_board(\%game, $game{human_idx});
          if ($game{last_action}) {
            writeline("", 1);
            writeline($config{'systemcolor'} . " " . $game{last_action} . $RST, 1);
          }
          door_pause();
        }
        _mb_do_ai_turn(\%game, $pi);
      }

      last if $game{quit};

      # Check goal reached
      if ($p->{mileage} >= $game{goal}) {
        _mb_check_extension(\%game, $pi);
      }
      last if $game{finished};

      # Check stuck
      if (_mb_check_stuck(\%game)) {
        $game{finished} = 1; last;
      }

      # Next turn
      $game{turn} = ($game{turn} + 1) % scalar @{$game{players}};
    }

    last if $game{quit};

    # Score and show results
    _mb_score_hand(\%game);
    $game{hands_played}++;
    _mb_show_hand_result(\%game);
    writeline("", 1);
    _mb_show_scores(\%game);
    writeline("", 1);

    # Save
    my $hp = $game{players}[$game{human_idx}];
    door_save($DOOR_NAME, {
      total        => $hp->{total},
      hands_won    => $hp->{games},
      hands_played => $game{hands_played},
    });

    if ($hp->{mileage} >= $game{goal}) {
      door_submit_score($DOOR_NAME, $hp->{total},
        { hands => $game{hands_played} });
    }

    writeline($config{'systemcolor'} . " Play another hand? (Y/N) " . $RST);
    my $ch = uc(waitkey("")); writeline("", 1);
    if ($ch ne 'Y') {
      $playing = 0;
    } else {
      _mb_new_hand(\%game);
    }
  }

  # Final summary
  door_clear();
  writeline("", 1);
  _mb_show_scores(\%game);
  writeline("", 1);

  my $hp = $game{players}[$game{human_idx}];
  if ($hp->{total} > 0 || $game{hands_played} > 0) {
    door_submit_score($DOOR_NAME, $hp->{total},
      { hands => $game{hands_played}, wins => $hp->{games} });
    if ($hp->{games} > 0) {
      door_broadcast($DOOR_NAME, "$info{'handle'} scored " .
        $hp->{total} . " in 1000 Miles! (" . $hp->{games} . " hands won)");
    }
  }

  if (door_yesno("View high scores?")) {
    door_show_scores($DOOR_NAME, "1000 Miles High Scores", "Score");
  }

  door_pause("Press any key to return to the BBS...");
  iamat($info{'handle'}, "Finished 1000 Miles");
}

1;
