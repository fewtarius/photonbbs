sub _st_deploy_fighters {
  my ($u, $p) = @_;
  my $sector = $u->{sectors}[$p->{sector}];

  writeline($config{'systemcolor'} . " You have $p->{fighters} fighters." . $RST, 1);
  if ($sector->{fighters} > 0 && $sector->{fighter_owner} eq $p->{name}) {
    writeline($config{'systemcolor'} . " $sector->{fighters} of yours already deployed here." . $RST, 1);
  }

  my @opts = (['D', 'Deploy'], ['R', 'Retrieve'], ['Q', 'Cancel']);
  my $choice = door_menu(\@opts, "Fighters");

  if ($choice eq 'D') {
    my $amt = door_getamount("Deploy how many:", $p->{fighters});
    if ($amt > 0) {
      $p->{fighters} -= $amt;
      $sector->{fighters} += $amt;
      $sector->{fighter_owner} = $p->{name};
      writeline($config{'usercolor'} . " Deployed $amt fighters." . $RST, 1);
    }
  } elsif ($choice eq 'R') {
    if ($sector->{fighter_owner} eq $p->{name} && $sector->{fighters} > 0) {
      my $amt = door_getamount("Retrieve how many:", $sector->{fighters});
      if ($amt > 0) {
        $sector->{fighters} -= $amt;
        $p->{fighters} += $amt;
        $sector->{fighter_owner} = "" if $sector->{fighters} <= 0;
        writeline($config{'usercolor'} . " Retrieved $amt fighters." . $RST, 1);
      }
    } else {
      writeline($config{'errorcolor'} . " No fighters of yours here." . $RST, 1);
    }
  }
  door_pause();
}

sub _st_fighter_combat {
  my ($u, $p, $sector) = @_;
  writeline($config{'errorcolor'} . " $sector->{fighters} fighters from $sector->{fighter_owner} attack!" . $RST, 1);

  my $enemy_f = $sector->{fighters};
  while ($enemy_f > 0 && ($p->{fighters} > 0 || $p->{shields} > 0)) {
    # Each round both sides lose some
    my $our_dmg = 1 + int(rand(int($p->{fighters} / 3) + 1));
    my $their_dmg = 1 + int(rand(int($enemy_f / 3) + 1));

    $enemy_f -= $our_dmg;
    $p->{fighters} -= $their_dmg;
    if ($p->{fighters} < 0) {
      $p->{shields} += $p->{fighters} * 10;
      $p->{fighters} = 0;
    }

    $enemy_f = 0 if $enemy_f < 0;
    $p->{shields} = 0 if $p->{shields} < 0;
  }

  $sector->{fighters} = $enemy_f;
  if ($enemy_f <= 0) {
    $sector->{fighter_owner} = "";
    writeline($config{'usercolor'} . " Enemy fighters destroyed!" . $RST, 1);
    $p->{experience} += 25;
    $p->{kills}++;
  } else {
    writeline($config{'errorcolor'} . " You took heavy damage. $enemy_f enemy fighters remain." . $RST, 1);
  }
  door_pause();
}

# ============================================================================
