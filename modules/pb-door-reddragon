    "Violet sighs. \"I wish someone would slay that awful Dragon.\"",
    "Violet laughs. \"Another brave warrior! Don't die on me.\"",
    "Violet tells you a rumor about hidden gems in the forest.",
  );
  my $line = $chat[int(rand(@chat))];
  writeline($config{'datacolor'} . " $line" . $RST, 1);

