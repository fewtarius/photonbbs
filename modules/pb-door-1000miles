#!/usr/bin/perl
#
# PhotonBBS Door: 1000 Miles
# Classic road racing card game - be the first to reach 1000 km
# Based on the card game by Edmond Dujardin (1954)
# Reference implementation: BSD Games mille (Berkeley, 1982)
#
# Play distance cards to advance, hazards to stop your opponents,
# remedies to fix problems, and safeties for permanent immunity.
# Supports 2-4 players (human or AI).
#

# ============================================================================
# CONSTANTS
# ============================================================================

my $DOOR_NAME = "1000miles";

# Card types
use constant {
  C_25          => 0,
  C_50          => 1,
  C_75          => 2,
  C_100         => 3,
  C_200         => 4,
  C_EMPTY       => 5,   # Out of Gas
  C_FLAT        => 6,   # Flat Tire
  C_CRASH       => 7,   # Accident
  C_STOP        => 8,   # Stop
  C_LIMIT       => 9,   # Speed Limit
  C_GAS         => 10,  # Gasoline (remedy)
  C_SPARE       => 11,  # Spare Tire (remedy)
  C_REPAIRS     => 12,  # Repairs (remedy)
  C_GO          => 13,  # Go (remedy)
  C_END_LIMIT   => 14,  # End of Limit (remedy)
  C_GAS_SAFE    => 15,  # Extra Tank (safety)
  C_SPARE_SAFE  => 16,  # Puncture Proof (safety)
  C_DRIVE_SAFE  => 17,  # Driving Ace (safety)
  C_RIGHT_WAY   => 18,  # Right of Way (safety)
  NUM_CARDS     => 19,
};

use constant {
  S_GAS_SAFE   => 0,  S_SPARE_SAFE => 1,
  S_DRIVE_SAFE => 2,  S_RIGHT_WAY  => 3,
  S_UNKNOWN    => 0,  S_IN_HAND    => 1,  S_PLAYED     => 2,
  S_CONV       => 15,
};

use constant {
  SC_SAFETY    => 100,  SC_ALL_SAFE  => 300,
  SC_COUP      => 300,  SC_TRIP      => 400,
  SC_SAFE_TRIP => 300,  SC_DELAY     => 300,
  SC_EXTENSION => 200,  SC_SHUT_OUT  => 500,
};

my $HAND_SZ    = 7;
my $GOAL       = 1000;
my $GOAL_SHORT = 700;

my @CARD_NAMES = (
  "25 km", "50 km", "75 km", "100 km", "200 km",
  "Out of Gas", "Flat Tire", "Accident", "Stop", "Speed Limit",
  "Gasoline", "Spare Tire", "Repairs", "Go", "End of Limit",
  "Extra Tank", "Puncture Proof", "Driving Ace", "Right of Way",
);

my @NUMCARDS = (
  10, 10, 10, 12, 4,   2, 2, 2, 4, 3,   6, 6, 6, 14, 6,   1, 1, 1, 1,
);

my @VALUE = (25, 50, 75, 100, 200);

my @OPPOSITE = (
  C_25, C_50, C_75, C_100, C_200,
  C_GAS, C_SPARE, C_REPAIRS, C_GO, C_END_LIMIT,
  C_EMPTY, C_FLAT, C_CRASH, C_STOP, C_LIMIT,
  C_EMPTY, C_FLAT, C_CRASH, C_STOP,
);

my @AI_NAMES = ("Claude", "Fritz", "Aria", "Nova", "Rex", "Zara");

# ============================================================================
# CARD TYPE HELPERS
# ============================================================================

sub _mb_is_safety  { return ($_[0] >= C_GAS_SAFE); }
sub _mb_is_distance { return ($_[0] >= C_25 && $_[0] <= C_200); }
sub _mb_is_hazard  { return ($_[0] >= C_EMPTY && $_[0] <= C_LIMIT); }
sub _mb_is_remedy  { return ($_[0] >= C_GAS && $_[0] <= C_END_LIMIT); }
sub _mb_is_repair  { return ($_[0] >= C_GAS && $_[0] <= C_REPAIRS); }

sub _mb_safety_index {
  my ($card) = @_;
  return $card - S_CONV if _mb_is_safety($card);
  return S_GAS_SAFE   if $card == C_EMPTY;
  return S_SPARE_SAFE if $card == C_FLAT;
  return S_DRIVE_SAFE if $card == C_CRASH;
  return S_RIGHT_WAY  if $card == C_STOP || $card == C_LIMIT;
  return -1;
}

sub _mb_card_color {
  my ($card) = @_;
  return $config{'systemcolor'} if $card < 0;
  return $config{'usercolor'}   if _mb_is_distance($card);
  return $config{'errorcolor'}  if _mb_is_hazard($card);
  return $config{'datacolor'}   if _mb_is_remedy($card);
  return $config{'promptcolor'} if _mb_is_safety($card);
  return $config{'systemcolor'};
}

# ============================================================================
# DECK MANAGEMENT
# ============================================================================

sub _mb_build_deck {
  my @deck;
  for my $c (0 .. NUM_CARDS - 1) { push @deck, ($c) x $NUMCARDS[$c]; }
  return \@deck;
}

sub _mb_shuffle {
  my ($deck) = @_;
  for my $i (reverse 1 .. $#$deck) {
    my $j = int(rand($i + 1));
    @{$deck}[$i, $j] = @{$deck}[$j, $i];
  }
}

sub _mb_draw {
  my ($g, $pi) = @_;
  return -1 unless @{$g->{deck}};
  my $card = shift @{$g->{deck}};
  my $p = $g->{players}[$pi];
  for my $i (0 .. $HAND_SZ - 1) {
    if ($p->{hand}[$i] == -1) {
      $p->{hand}[$i] = $card;
      return $card;
    }
  }
  return -1;
}

# ============================================================================
# GAME STATE
# ============================================================================

sub _mb_new_player {
  my ($name, $type) = @_;
  return {
    name       => $name,
    type       => $type,     # 'human' or 'ai'
    hand       => [(-1) x $HAND_SZ],
    mileage    => 0,
    battle     => -1,
    speed      => -1,
    can_go     => 0,
    safety     => [S_UNKNOWN, S_UNKNOWN, S_UNKNOWN, S_UNKNOWN],
    nummiles   => [0, 0, 0, 0, 0],
    new_battle => 0,
    new_speed  => 0,
    coups      => [0, 0, 0, 0],
    hand_tot   => 0,
    total      => 0,
    games      => 0,
  };
}

sub _mb_reset_hand {
  my ($p) = @_;
  $p->{hand}       = [(-1) x $HAND_SZ];
  $p->{mileage}    = 0;
  $p->{battle}     = -1;
  $p->{speed}      = -1;
  $p->{can_go}     = 0;
  $p->{safety}     = [S_UNKNOWN, S_UNKNOWN, S_UNKNOWN, S_UNKNOWN];
  $p->{nummiles}   = [0, 0, 0, 0, 0];
  $p->{new_battle} = 0;
  $p->{new_speed}  = 0;
  $p->{coups}      = [0, 0, 0, 0];
  $p->{hand_tot}   = 0;
}

sub _mb_new_hand {
  my ($g) = @_;
  my $deck = _mb_build_deck();
  _mb_shuffle($deck);
  $g->{deck} = $deck;
  $g->{discard} = -1;
  $g->{goal} = $GOAL_SHORT;
  $g->{extended} = 0;
  $g->{finished} = 0;
  $g->{turn} = 0;
  $g->{last_action} = "";

  for my $pi (0 .. $#{$g->{players}}) {
    _mb_reset_hand($g->{players}[$pi]);
  }

  # Deal 7 cards to each player
  for (1 .. $HAND_SZ) {
    for my $pi (0 .. $#{$g->{players}}) {
      _mb_draw($g, $pi);
    }
  }
}

sub _mb_init_game {
  my ($num_players, $num_humans) = @_;
  $num_players ||= 2;
  $num_humans  ||= 1;

  my %g;
  $g{players} = [];
  $g{quit} = 0;
  $g{hands_played} = 0;
  $g{human_idx} = 0;  # Index of the "main" human player (the one at the terminal)

  # Shuffle AI names
  my @names = @AI_NAMES;
  for my $i (reverse 1 .. $#names) {
    my $j = int(rand($i + 1));
    @names[$i, $j] = @names[$j, $i];
  }

  # Player 0 is always the terminal user
  push @{$g{players}}, _mb_new_player($info{'handle'}, 'human');

  # Add additional human players (hot-seat) or AI
  my $ai_idx = 0;
  for my $i (1 .. $num_players - 1) {
    if ($i < $num_humans) {
      push @{$g{players}}, _mb_new_player("Player " . ($i + 1), 'human');
    } else {
      push @{$g{players}}, _mb_new_player($names[$ai_idx++ % scalar @names], 'ai');
    }
  }

  _mb_new_hand(\%g);
  return %g;
}

# ============================================================================
# CARD LOGIC (multiplayer)
# ============================================================================

# Check if player pi can play card at card_idx
# For hazards, need a valid target - returns 1 if any target exists
sub _mb_can_play {
  my ($g, $pi, $card_idx) = @_;
  my $p = $g->{players}[$pi];
  my $card = $p->{hand}[$card_idx];
  return 0 if $card == -1;
  return 1 if _mb_is_safety($card);

  if (_mb_is_distance($card)) {
    return 0 unless $p->{can_go};
    return 0 if $p->{mileage} + $VALUE[$card] > $g->{goal};
    return 0 if $card == C_200 && $p->{nummiles}[C_200] >= 2;
    return 0 if $p->{speed} == C_LIMIT && $card > C_50;
    return 1;
  }

  if (_mb_is_hazard($card)) {
    # Check if any opponent is a valid target
    for my $ti (0 .. $#{$g->{players}}) {
      next if $ti == $pi;
      return 1 if _mb_can_target($g, $card, $ti);
    }
    return 0;
  }

  if ($card == C_GO) {
    return ($p->{battle} == -1 || $p->{battle} == C_STOP ||
            _mb_is_repair($p->{battle})) ? 1 : 0;
  }
  if ($card == C_END_LIMIT) {
    return ($p->{speed} == C_LIMIT) ? 1 : 0;
  }
  if (_mb_is_repair($card)) {
    return ($p->{battle} == $OPPOSITE[$card]) ? 1 : 0;
  }
  return 0;
}

# Check if a hazard card can target player ti
sub _mb_can_target {
  my ($g, $card, $ti) = @_;
  my $t = $g->{players}[$ti];
  if ($card == C_LIMIT) {
    return 0 if $t->{speed} == C_LIMIT;
    return 0 if $t->{safety}[S_RIGHT_WAY] == S_PLAYED;
    return 1;
  }
  return 0 unless $t->{can_go};
  my $si = _mb_safety_index($card);
  return 0 if $si >= 0 && $t->{safety}[$si] == S_PLAYED;
  return 1;
}

# Get list of valid targets for a hazard card
sub _mb_valid_targets {
  my ($g, $pi, $card) = @_;
  my @targets;
  for my $ti (0 .. $#{$g->{players}}) {
    next if $ti == $pi;
    push @targets, $ti if _mb_can_target($g, $card, $ti);
  }
  return @targets;
}

# Play a distance/remedy card
sub _mb_play_card {
  my ($g, $pi, $card_idx) = @_;
  my $p = $g->{players}[$pi];
  my $card = $p->{hand}[$card_idx];

  if (_mb_is_distance($card)) {
    $p->{nummiles}[$card]++;
    $p->{hand_tot} += $VALUE[$card];
    $p->{mileage}  += $VALUE[$card];
    $p->{hand}[$card_idx] = -1;
    $g->{finished} = 1 if $p->{mileage} >= $g->{goal};
    return 1;
  }

  if ($card == C_GO) {
    $p->{battle} = C_GO; $p->{can_go} = 1;
  } elsif ($card == C_END_LIMIT) {
    $p->{speed} = C_END_LIMIT;
  } elsif (_mb_is_repair($card)) {
    $p->{battle} = $card;
    $p->{can_go} = 1 if $p->{safety}[S_RIGHT_WAY] == S_PLAYED;
  }
  $p->{hand}[$card_idx] = -1;
  return 1;
}

# Play a hazard card on target ti
sub _mb_play_hazard {
  my ($g, $pi, $card_idx, $ti) = @_;
  my $p = $g->{players}[$pi];
  my $t = $g->{players}[$ti];
  my $card = $p->{hand}[$card_idx];

  # Check for Coup Fourre
  if (_mb_check_coup($g, $ti, $card)) {
    $p->{hand}[$card_idx] = -1;
    return 2;  # Coup happened
  }

  if ($card == C_LIMIT) {
    $t->{speed} = C_LIMIT;
    $t->{new_speed} = 1;
  } else {
    $t->{battle} = $card;
    $t->{new_battle} = 1;
    $t->{can_go} = 0;
  }
  $p->{hand}[$card_idx] = -1;
  return 1;
}

sub _mb_play_safety {
  my ($g, $pi, $card_idx) = @_;
  my $p = $g->{players}[$pi];
  my $card = $p->{hand}[$card_idx];
  my $si = $card - S_CONV;

  if ($p->{battle} == $OPPOSITE[$card] ||
      ($card == C_RIGHT_WAY && $p->{speed} == C_LIMIT)) {
    unless ($card == C_RIGHT_WAY && !_mb_is_repair($p->{battle})) {
      $p->{battle} = C_GO; $p->{can_go} = 1;
    }
    $p->{speed} = -1 if $card == C_RIGHT_WAY && $p->{speed} == C_LIMIT;
    if ($p->{new_battle} || ($p->{new_speed} && $card == C_RIGHT_WAY)) {
      $p->{coups}[$si] = 1;
      $p->{hand_tot} += SC_COUP;
    }
  }

  $p->{safety}[$si] = S_PLAYED;
  $p->{hand_tot} += SC_SAFETY;
  if ($card == C_RIGHT_WAY) {
    $p->{speed} = -1 if $p->{speed} == C_LIMIT;
    if ($p->{battle} == C_STOP || $p->{battle} == -1) {
      $p->{can_go} = 1; $p->{battle} = -1;
    }
    $p->{can_go} = 1 if !$p->{can_go} && _mb_is_repair($p->{battle});
  }
  $p->{hand}[$card_idx] = -1;
  return 1;
}

sub _mb_check_coup {
  my ($g, $di, $hazard_card) = @_;
  my $d = $g->{players}[$di];
  my $si = _mb_safety_index($hazard_card);
  return 0 if $si < 0;

  for my $i (0 .. $HAND_SZ - 1) {
    my $card = $d->{hand}[$i];
    next if $card == -1;
    if (_mb_is_safety($card) && ($card - S_CONV) == $si) {
      $d->{coups}[$si] = 1;
      $d->{safety}[$si] = S_PLAYED;
      $d->{hand_tot} += SC_SAFETY + SC_COUP;
      $d->{hand}[$i] = -1;
      if ($hazard_card == C_LIMIT) { $d->{speed} = -1; }
      else { $d->{can_go} = 1; $d->{battle} = C_GO; }
      $d->{speed} = -1 if $card == C_RIGHT_WAY && $d->{speed} == C_LIMIT;
      _mb_draw($g, $di);
      return 1;
    }
  }
  return 0;
}

sub _mb_discard {
  my ($g, $pi, $card_idx) = @_;
  my $card = $g->{players}[$pi]{hand}[$card_idx];
  return 0 if $card == -1 || _mb_is_safety($card);
  $g->{discard} = $card;
  $g->{players}[$pi]{hand}[$card_idx] = -1;
  return 1;
}

# ============================================================================
# STUCK CHECK & SCORING
# ============================================================================

sub _mb_check_stuck {
  my ($g) = @_;
  return 0 if @{$g->{deck}};
  for my $pi (0 .. $#{$g->{players}}) {
    my $p = $g->{players}[$pi];
    for my $i (0 .. $HAND_SZ - 1) {
      return 0 if $p->{hand}[$i] != -1 &&
                  (_mb_is_safety($p->{hand}[$i]) || _mb_can_play($g, $pi, $i));
    }
  }
  return 1;
}

sub _mb_has_cards {
  my ($p) = @_;
  for my $i (0 .. $HAND_SZ - 1) { return 1 if $p->{hand}[$i] >= 0; }
  return 0;
}

sub _mb_score_hand {
  my ($g) = @_;
  my $np = scalar @{$g->{players}};
  for my $pi (0 .. $np - 1) {
    my $p = $g->{players}[$pi];
    my $bonus = 0;
    if ($p->{mileage} >= $g->{goal}) {
      $bonus += SC_TRIP;
      $bonus += SC_SAFE_TRIP if $p->{nummiles}[C_200] == 0;
      $bonus += SC_DELAY     if !@{$g->{deck}};
      $bonus += SC_EXTENSION if $g->{extended};
      # Shut out: all OTHER players at 0
      my $shutout = 1;
      for my $oi (0 .. $np - 1) {
        next if $oi == $pi;
        $shutout = 0 if $g->{players}[$oi]{mileage} > 0;
      }
      $bonus += SC_SHUT_OUT if $shutout;
    }
    my $safe_count = grep { $_ == S_PLAYED } @{$p->{safety}};
    $bonus += SC_ALL_SAFE if $safe_count == 4;
    $p->{total} += $p->{hand_tot} + $bonus;
    $p->{games}++ if $p->{mileage} >= $g->{goal};
  }
}

# ============================================================================
# DISPLAY
# ============================================================================

sub _mb_show_board {
  my ($g, $viewer) = @_;
  $viewer //= $g->{human_idx};
  door_clear();

  my $np = scalar @{$g->{players}};
  writeline($config{'themecolor'} . " 1 0 0 0   M I L E S" .
    $config{'systemcolor'} . "  (Goal: $g->{goal} km, $np players)" . $RST, 1);
  writeline($config{'linecolor'} . " " . ("-" x 55) . $RST, 1);

  # Show all players' status
  for my $pi (0 .. $np - 1) {
    my $p = $g->{players}[$pi];
    my $is_current = ($pi == $g->{turn});
    my $is_viewer  = ($pi == $viewer);
    my $marker = $is_current ? "> " : "  ";
    my $name_color = $is_viewer ? $config{'usercolor'} : $config{'systemcolor'};
    my $tag = $p->{type} eq 'ai' ? " [AI]" : "";

    writeline($marker . $name_color . $p->{name} . $tag . $RST, 1);
    _mb_show_status_line($g, $pi);

    if ($pi < $np - 1) {
      writeline($config{'linecolor'} . "  " . ("-" x 50) . $RST, 1);
    }
  }

  writeline($config{'linecolor'} . " " . ("-" x 55) . $RST, 1);

  # Show viewer's hand
  my $vp = $g->{players}[$viewer];
  writeline($config{'themecolor'} . " Your Hand:" . $RST, 1);
  for my $i (0 .. $HAND_SZ - 1) {
    my $card = $vp->{hand}[$i];
    if ($card >= 0) {
      my $playable = _mb_can_play($g, $viewer, $i) ? "*" : " ";
      writeline(sprintf("  %s%d%s%s %s%-18s%s",
        $config{'promptcolor'}, $i + 1, $config{'themecolor'}, $playable,
        _mb_card_color($card), $CARD_NAMES[$card], $RST), 1);
    }
  }

  my $deck_left = scalar @{$g->{deck}};
  my $disc = $g->{discard} >= 0 ? $CARD_NAMES[$g->{discard}] : "---";
  writeline("", 1);
  writeline($config{'systemcolor'} . " Deck: " . $config{'datacolor'} .
    "$deck_left" . $config{'systemcolor'} . "  Discard: " .
    $config{'datacolor'} . $disc . $RST, 1);
}

sub _mb_show_status_line {
  my ($g, $pi) = @_;
  my $p = $g->{players}[$pi];

  # Mileage bar
  my $bar_len = 25;
  my $filled = int(($p->{mileage} / $g->{goal}) * $bar_len);
  $filled = $bar_len if $filled > $bar_len;
  my $bar = ("#" x $filled) . ("-" x ($bar_len - $filled));
  writeline(sprintf("  %s%4d km%s [%s%s%s]",
    $config{'datacolor'}, $p->{mileage},
    $config{'systemcolor'}, $config{'usercolor'}, $bar,
    $config{'systemcolor'}) . $RST, 1);

  # Battle & speed
  my $battle_str = "Rolling";
  if (!$p->{can_go}) {
    if ($p->{battle} == -1) { $battle_str = "Need Go"; }
    elsif (_mb_is_hazard($p->{battle})) { $battle_str = $CARD_NAMES[$p->{battle}]; }
    elsif (_mb_is_repair($p->{battle})) { $battle_str = "Repaired (need Go)"; }
  }
  my $speed_str = ($p->{speed} == C_LIMIT) ? "LIMIT" : "";

  my $status_clr = $p->{can_go} ? $config{'usercolor'} : $config{'errorcolor'};
  writeline(sprintf("  %s%-20s%s%s%s",
    $status_clr, $battle_str, $RST,
    ($speed_str ? " " . $config{'errorcolor'} . $speed_str . $RST : ""),
    "") . $RST, 1);

  # Safeties
  my @safe_names = ("ETk", "PPr", "DAc", "RoW");
  my @played;
  for my $s (0 .. 3) { push @played, $safe_names[$s] if $p->{safety}[$s] == S_PLAYED; }
  if (@played) {
    writeline("  " . $config{'promptcolor'} . join(" ", @played) . $RST, 1);
  }
}

sub _mb_show_scores {
  my ($g) = @_;
  writeline("", 1);
  writeline($config{'themecolor'} . " Scores:" . $RST, 1);
  writeline($config{'linecolor'} . " " . ("-" x 40) . $RST, 1);
  for my $p (@{$g->{players}}) {
    writeline(sprintf("  %s%-12s%s %s%5d%s  Wins: %s%d%s",
      $config{'usercolor'}, $p->{name}, $config{'systemcolor'},
      $config{'datacolor'}, $p->{total}, $config{'systemcolor'},
      $config{'datacolor'}, $p->{games}, $RST), 1);
  }
}

# ============================================================================
# AI LOGIC
# ============================================================================

sub _mb_ai_move {
  my ($g, $pi) = @_;
  my $p = $g->{players}[$pi];

  # Draw first
  _mb_draw($g, $pi);

  # Always play safety if it counters current problem
  for my $i (0 .. $HAND_SZ - 1) {
    my $card = $p->{hand}[$i];
    next if $card == -1 || !_mb_is_safety($card);
    if ($p->{battle} == $OPPOSITE[$card] ||
        ($card == C_RIGHT_WAY && $p->{speed} == C_LIMIT) ||
        $p->{new_battle} || ($p->{new_speed} && $card == C_RIGHT_WAY)) {
      return { action => 'safety', idx => $i };
    }
  }

  # Score each play
  my $best_idx = -1;
  my $best_score = -999;
  my $best_action = 'discard';
  my $best_target = -1;

  for my $i (0 .. $HAND_SZ - 1) {
    my $card = $p->{hand}[$i];
    next if $card == -1;

    if (_mb_is_safety($card)) {
      # Play safeties conservatively unless needed
      next;
    }

    if (_mb_is_hazard($card)) {
      my @targets = _mb_valid_targets($g, $pi, $card);
      for my $ti (@targets) {
        my $val = _mb_ai_hazard_value($g, $pi, $card, $ti);
        if ($val > $best_score) {
          $best_score = $val; $best_idx = $i;
          $best_action = 'hazard'; $best_target = $ti;
        }
      }
      next;
    }

    if (_mb_can_play($g, $pi, $i)) {
      my $val = _mb_ai_play_value($g, $pi, $card);
      if ($val > $best_score) {
        $best_score = $val; $best_idx = $i;
        $best_action = 'play'; $best_target = -1;
      }
    }
  }

  # Found something to play
  if ($best_idx >= 0 && $best_score > 0) {
    return { action => $best_action, idx => $best_idx, target => $best_target };
  }

  # Discard least valuable
  my $worst_idx = -1; my $worst_val = 999;
  for my $i (0 .. $HAND_SZ - 1) {
    my $card = $p->{hand}[$i];
    next if $card == -1 || _mb_is_safety($card);
    my $val = _mb_ai_hold_value($g, $pi, $card);
    if ($val < $worst_val) { $worst_val = $val; $worst_idx = $i; }
  }

  if ($worst_idx < 0) {
    for my $i (0 .. $HAND_SZ - 1) {
      if ($p->{hand}[$i] >= 0) { $worst_idx = $i; last; }
    }
  }

  return $worst_idx >= 0 ? { action => 'discard', idx => $worst_idx } : undef;
}

sub _mb_ai_play_value {
  my ($g, $pi, $card) = @_;
  my $p = $g->{players}[$pi];

  if (_mb_is_distance($card)) {
    return 100 if $p->{mileage} + $VALUE[$card] == $g->{goal};
    my $base = $VALUE[$card] / 10;
    $base += 5 if $p->{speed} == C_LIMIT && $card <= C_50;
    return $base;
  }
  return 20 if $card == C_GO && !$p->{can_go};
  return 15 if $card == C_END_LIMIT && $p->{speed} == C_LIMIT;
  return 20 if _mb_is_repair($card) && $p->{battle} == $OPPOSITE[$card];
  return 2;
}

sub _mb_ai_hazard_value {
  my ($g, $pi, $card, $ti) = @_;
  my $t = $g->{players}[$ti];
  # Prefer targeting the leader
  my $lead_bonus = $t->{mileage} >= 400 ? 5 : 0;
  return 15 + $lead_bonus if $card == C_STOP;
  return 12 + $lead_bonus if $card == C_CRASH;
  return 10 + $lead_bonus if $card == C_FLAT || $card == C_EMPTY;
  return 8 + $lead_bonus  if $card == C_LIMIT;
  return 5;
}

sub _mb_ai_hold_value {
  my ($g, $pi, $card) = @_;
  return 50 if $card == C_GO;
  return 30 if _mb_is_repair($card);
  return 25 if $card == C_END_LIMIT;
  return 20 if _mb_is_hazard($card);
  return $VALUE[$card] / 10 if _mb_is_distance($card);
  return 5;
}

# ============================================================================
# AI TURN EXECUTION
# ============================================================================

sub _mb_do_ai_turn {
  my ($g, $pi) = @_;
  my $p = $g->{players}[$pi];
  my $move = _mb_ai_move($g, $pi);
  return unless $move;

  my $card = $p->{hand}[$move->{idx}];
  my $name = $p->{name};

  if ($move->{action} eq 'discard') {
    _mb_discard($g, $pi, $move->{idx});
    $g->{last_action} = "$name discarded " . $CARD_NAMES[$card];
  } elsif ($move->{action} eq 'safety') {
    _mb_play_safety($g, $pi, $move->{idx});
    $g->{last_action} = "$name played " . $CARD_NAMES[$card] . "!";
  } elsif ($move->{action} eq 'hazard') {
    my $ti = $move->{target};
    my $tname = $g->{players}[$ti]{name};
    my $result = _mb_play_hazard($g, $pi, $move->{idx}, $ti);
    if ($result == 2) {
      $g->{last_action} = "$name played " . $CARD_NAMES[$card] .
        " on $tname - COUP FOURRE!";
    } else {
      $g->{last_action} = "$name played " . $CARD_NAMES[$card] . " on $tname!";
    }
  } else {
    _mb_play_card($g, $pi, $move->{idx});
    if (_mb_is_distance($card)) {
      $g->{last_action} = "$name played " . $CARD_NAMES[$card] .
        " (" . $p->{mileage} . " km)";
    } else {
      $g->{last_action} = "$name played " . $CARD_NAMES[$card];
    }
  }
}

# ============================================================================
# HUMAN TURN
# ============================================================================

sub _mb_do_human_turn {
  my ($g, $pi) = @_;
  my $p = $g->{players}[$pi];
  my $drawn = _mb_draw($g, $pi);

  if ($drawn < 0 && !_mb_has_cards($p)) { return 0; }

  while (1) {
    _mb_show_board($g, $pi);
    writeline("", 1);

    if ($g->{last_action}) {
      writeline($config{'systemcolor'} . " " . $g->{last_action} . $RST, 1);
    }
    if ($drawn >= 0) {
      writeline($config{'datacolor'} . " Drew: " .
        _mb_card_color($drawn) . $CARD_NAMES[$drawn] . $RST, 1);
    }

    writeline("", 1);
    writeline($config{'systemcolor'} . " [1-7] Play  [D+#] Discard  [S] Scores  [Q] Quit" . $RST, 1);
    writeline($config{'promptcolor'} . " > " . $RST);
    my $input = uc(waitkey(""));
    writeline("", 1);

    if ($input eq 'Q') { $g->{quit} = 1; return 0; }
    if ($input eq 'S') { _mb_show_scores($g); door_pause(); next; }

    # Discard
    if ($input eq 'D') {
      writeline($config{'systemcolor'} . " Discard (1-7): " . $RST);
      my $num = waitkey(""); writeline("", 1);
      my $idx = int($num // 0) - 1;
      if ($idx >= 0 && $idx < $HAND_SZ) {
        my $card = $p->{hand}[$idx];
        if ($card == -1) {
          writeline($config{'errorcolor'} . " No card there." . $RST, 1);
          door_pause(); next;
        }
        if (_mb_is_safety($card)) {
          writeline($config{'errorcolor'} . " Cannot discard a safety!" . $RST, 1);
          door_pause(); next;
        }
        _mb_discard($g, $pi, $idx);
        $g->{last_action} = $p->{name} . " discarded " . $CARD_NAMES[$card];
        return 1;
      }
      next;
    }

    # Play card
    my $idx = int($input // 0) - 1;
    if ($idx >= 0 && $idx < $HAND_SZ) {
      my $card = $p->{hand}[$idx];
      if ($card == -1) {
        writeline($config{'errorcolor'} . " No card there." . $RST, 1);
        door_pause(); next;
      }

      # Safety
      if (_mb_is_safety($card)) {
        _mb_play_safety($g, $pi, $idx);
        $g->{last_action} = $p->{name} . " played " . $CARD_NAMES[$card] . "!";
        door_pause(); return 1;
      }

      # Hazard - choose target
      if (_mb_is_hazard($card)) {
        my @targets = _mb_valid_targets($g, $pi, $card);
        if (!@targets) {
          writeline($config{'errorcolor'} . " No valid target for " .
            $CARD_NAMES[$card] . "." . $RST, 1);
          door_pause(); next;
        }
        my $ti;
        if (@targets == 1) {
          $ti = $targets[0];
        } else {
          writeline($config{'systemcolor'} . " Target:" . $RST, 1);
          for my $j (0 .. $#targets) {
            writeline("  " . $config{'promptcolor'} . ($j + 1) .
              $config{'themecolor'} . " " .
              $g->{players}[$targets[$j]]{name} . $RST, 1);
          }
          writeline($config{'systemcolor'} . " Which? " . $RST);
          my $tch = waitkey(""); writeline("", 1);
          my $tidx = int($tch // 0) - 1;
          if ($tidx < 0 || $tidx > $#targets) { next; }
          $ti = $targets[$tidx];
        }
        my $tname = $g->{players}[$ti]{name};
        my $result = _mb_play_hazard($g, $pi, $idx, $ti);
        if ($result == 2) {
          $g->{last_action} = $p->{name} . " played " . $CARD_NAMES[$card] .
            " on $tname - COUP FOURRE!";
          writeline($config{'promptcolor'} . " $tname played COUP FOURRE!" . $RST, 1);
        } else {
          $g->{last_action} = $p->{name} . " played " . $CARD_NAMES[$card] .
            " on $tname!";
        }
        door_pause(); return 1;
      }

      # Distance/Remedy
      unless (_mb_can_play($g, $pi, $idx)) {
        writeline($config{'errorcolor'} . " Can't play " .
          $CARD_NAMES[$card] . " right now." . $RST, 1);
        _mb_explain_why($g, $pi, $card);
        door_pause(); next;
      }

      _mb_play_card($g, $pi, $idx);
      if (_mb_is_distance($card)) {
        $g->{last_action} = $p->{name} . " played " . $CARD_NAMES[$card] .
          " (" . $p->{mileage} . " km)";
      } else {
        $g->{last_action} = $p->{name} . " played " . $CARD_NAMES[$card];
      }
      return 1;
    }
  }
}

sub _mb_explain_why {
  my ($g, $pi, $card) = @_;
  my $p = $g->{players}[$pi];
  if (_mb_is_distance($card)) {
    if (!$p->{can_go}) {
      writeline($config{'systemcolor'} . "   (Need a Go card first)" . $RST, 1);
    } elsif ($p->{speed} == C_LIMIT && $card > C_50) {
      writeline($config{'systemcolor'} . "   (Speed Limit - max 50 km)" . $RST, 1);
    } elsif ($p->{mileage} + $VALUE[$card] > $g->{goal}) {
      writeline($config{'systemcolor'} . "   (Would exceed " . $g->{goal} . " km)" . $RST, 1);
    } elsif ($card == C_200 && $p->{nummiles}[C_200] >= 2) {
      writeline($config{'systemcolor'} . "   (Max two 200s per hand)" . $RST, 1);
    }
  } elsif ($card == C_GO && $p->{battle} != -1 && $p->{battle} != C_STOP && !_mb_is_repair($p->{battle})) {
    writeline($config{'systemcolor'} . "   (Fix " . $CARD_NAMES[$p->{battle}] . " first)" . $RST, 1);
  }
}

# ============================================================================
# EXTENSION CHECK
# ============================================================================

sub _mb_check_extension {
  my ($g, $pi) = @_;
  return if $g->{extended} || $g->{goal} != $GOAL_SHORT;
  return unless $g->{players}[$pi]{mileage} >= $GOAL_SHORT;

  my $p = $g->{players}[$pi];
  if ($p->{type} eq 'human') {
    writeline("", 1);
    writeline($config{'promptcolor'} . " " . $p->{name} . " reached $GOAL_SHORT km!" . $RST, 1);
    writeline($config{'systemcolor'} . " Extend to $GOAL km for " .
      SC_EXTENSION . " bonus? (Y/N) " . $RST);
    my $ch = uc(waitkey("")); writeline("", 1);
    if ($ch eq 'Y') {
      $g->{goal} = $GOAL; $g->{extended} = 1; $g->{finished} = 0;
      $g->{last_action} = $p->{name} . " extended to $GOAL km!";
      door_pause();
    }
  } else {
    # AI extends if leading and no opponent is close
    my $extend = 1;
    for my $oi (0 .. $#{$g->{players}}) {
      next if $oi == $pi;
      $extend = 0 if $g->{players}[$oi]{mileage} > 500;
    }
    if ($extend) {
      $g->{goal} = $GOAL; $g->{extended} = 1; $g->{finished} = 0;
      $g->{last_action} = $p->{name} . " extended to $GOAL km!";
    }
  }
}

# ============================================================================
# HAND RESULT
# ============================================================================

sub _mb_show_hand_result {
  my ($g) = @_;
  door_clear();
  writeline("", 1);

  # Find winner
  my $winner = -1;
  my $best_miles = -1;
  for my $pi (0 .. $#{$g->{players}}) {
    my $m = $g->{players}[$pi]{mileage};
    if ($m >= $g->{goal}) { $winner = $pi; last; }
    if ($m > $best_miles) { $best_miles = $m; $winner = $pi; }
  }

  if ($winner >= 0 && $g->{players}[$winner]{mileage} >= $g->{goal}) {
    writeline($config{'promptcolor'} . " " . $g->{players}[$winner]{name} .
      " reached " . $g->{players}[$winner]{mileage} . " km! Winner!" . $RST, 1);
  } else {
    writeline($config{'systemcolor'} . " Hand over - deck exhausted." . $RST, 1);
    writeline($config{'datacolor'} . " " . $g->{players}[$winner]{name} .
      " wins with " . $best_miles . " km." . $RST, 1) if $winner >= 0;
  }

  writeline("", 1);
  writeline($config{'themecolor'} . " Hand Scoring:" . $RST, 1);
  writeline($config{'linecolor'} . " " . ("-" x 45) . $RST, 1);

  for my $pi (0 .. $#{$g->{players}}) {
    my $p = $g->{players}[$pi];
    writeline("", 1);
    writeline($config{'usercolor'} . " " . $p->{name} . ":" . $RST, 1);
    writeline(sprintf("  %sMileage:     %s%4d%s",
      $config{'systemcolor'}, $config{'datacolor'}, $p->{mileage}, $RST), 1);

    if ($p->{mileage} >= $g->{goal}) {
      writeline(sprintf("  %sTrip bonus:  %s%4d%s",
        $config{'systemcolor'}, $config{'datacolor'}, SC_TRIP, $RST), 1);
      if ($p->{nummiles}[C_200] == 0) {
        writeline(sprintf("  %sSafe trip:   %s%4d%s",
          $config{'systemcolor'}, $config{'datacolor'}, SC_SAFE_TRIP, $RST), 1);
      }
      if (!@{$g->{deck}}) {
        writeline(sprintf("  %sDelayed:     %s%4d%s",
          $config{'systemcolor'}, $config{'datacolor'}, SC_DELAY, $RST), 1);
      }
      if ($g->{extended}) {
        writeline(sprintf("  %sExtension:   %s%4d%s",
          $config{'systemcolor'}, $config{'datacolor'}, SC_EXTENSION, $RST), 1);
      }
    }
    my $safe_count = grep { $_ == S_PLAYED } @{$p->{safety}};
    if ($safe_count) {
      writeline(sprintf("  %sSafeties:    %s%4d%s (%d x %d)",
        $config{'systemcolor'}, $config{'datacolor'},
        $safe_count * SC_SAFETY, $RST, $safe_count, SC_SAFETY), 1);
    }
    my $coup_count = grep { $_ } @{$p->{coups}};
    if ($coup_count) {
      writeline(sprintf("  %sCoup fourre: %s%4d%s",
        $config{'systemcolor'}, $config{'datacolor'},
        $coup_count * SC_COUP, $RST), 1);
    }
  }
}

